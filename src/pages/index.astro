---
import ShowcaseBase from '../layouts/ShowcaseBase.astro';

const categories = [
  {
    slug: 'psychologos',
    label: 'Ψυχολόγος',
    subtitle: 'Psychologist',
    count: 2,
    description: 'Ζεστή αισθητική για επαγγελματίες ψυχικής υγείας.',
  },
  {
    slug: 'architect',
    label: 'Αρχιτέκτονας',
    subtitle: 'Architect',
    count: 1,
    description: 'Swiss minimalism για αρχιτεκτονικά γραφεία.',
  },
  {
    slug: 'lawyer',
    label: 'Δικηγόρος',
    subtitle: 'Lawyer',
    count: 0,
    description: 'Σύντομα.',
  },
  {
    slug: 'doctor',
    label: 'Ιατρός',
    subtitle: 'Doctor',
    count: 0,
    description: 'Σύντομα.',
  },
  {
    slug: 'yoga',
    label: 'Yoga / Pilates',
    subtitle: 'Yoga Instructor',
    count: 1,
    description: 'Editorial somatic αισθητική για δασκάλες yoga και pilates.',
  },
  {
    slug: 'cafe',
    label: 'Καφετέρια',
    subtitle: 'Specialty Café',
    count: 1,
    description: 'Warm corner-store αισθητική για specialty coffee και brunch.',
  },
  {
    slug: 'coach',
    label: 'Life / Executive Coach',
    subtitle: 'Coach',
    count: 1,
    description: 'Corporate realism για independent life coaches και executive coaches.',
  },
];
---

<ShowcaseBase title="Instatok Demos">
  <main style="min-height:100dvh; display:flex; flex-direction:column; background:#FAFAFA;">

    <!-- Header -->
    <header style="padding:2.5rem; border-bottom:1px solid #E8E8E8; display:flex; align-items:baseline; justify-content:space-between; gap:1.5rem; flex-wrap:wrap;">
      <div style="display:flex; align-items:baseline; gap:1rem;">
        <span style="font-size:0.6875rem; font-weight:700; letter-spacing:0.2em; color:#0A0A0A;">INSTATOK</span>
        <span style="font-size:0.625rem; font-weight:400; letter-spacing:0.08em; color:#ABABAB;">demos</span>
      </div>
      <p style="font-size:0.625rem; font-weight:400; letter-spacing:0.1em; color:#ABABAB; text-transform:uppercase;">demo.instatok.gr</p>
    </header>

    <!-- Hero text -->
    <section style="padding:5rem 2.5rem 3rem; max-width:72rem; margin:0 auto; width:100%;">
      <p style="font-size:0.625rem; font-weight:500; letter-spacing:0.18em; text-transform:uppercase; color:#ABABAB; margin-bottom:1.25rem;">Βιτρίνα Demos</p>
      <h1 style="font-size:clamp(2rem, 6vw, 4rem); font-weight:300; letter-spacing:-0.02em; line-height:1.1; color:#0A0A0A; margin-bottom:1.5rem;">
        Δείγματα ψηφιακής<br />παρουσίας.
      </h1>
      <p style="font-size:0.9375rem; font-weight:300; line-height:1.7; color:#6B6B6B; max-width:38rem;">
        Έτοιμα demos για Έλληνες επαγγελματίες. Κάθε κατηγορία περιέχει 1–3 διαφορετικές αισθητικές κατευθύνσεις.
      </p>
    </section>

    <!-- Categories grid -->
    <section style="padding:0 2.5rem 6rem; max-width:72rem; margin:0 auto; width:100%;">
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(min(100%, 16rem), 1fr)); gap:1px; border:1px solid #E8E8E8; background:#E8E8E8;">
        {categories.map(cat => (
          <a
            href={cat.count > 0 ? `/${cat.slug}` : '#'}
            style={`display:flex; flex-direction:column; gap:1.5rem; padding:2.5rem 2rem; background:#FAFAFA; text-decoration:none; transition:background 0.15s;${cat.count === 0 ? ' cursor:default;' : ''}`}
            class={cat.count > 0 ? 'cat-card' : 'cat-card cat-card--inactive'}
          >
            <div style="display:flex; align-items:baseline; justify-content:space-between; gap:1rem;">
              <div style="display:flex; flex-direction:column; gap:0.25rem;">
                <span style="font-size:1.125rem; font-weight:400; color:#0A0A0A; line-height:1.2;">{cat.label}</span>
                <span style="font-size:0.5625rem; font-weight:400; letter-spacing:0.12em; text-transform:uppercase; color:#ABABAB;">{cat.subtitle}</span>
              </div>
              {cat.count > 0
                ? <span style="font-family:ui-monospace,'JetBrains Mono','Courier New',monospace; font-size:0.625rem; color:#ABABAB;">{cat.count} demo{cat.count !== 1 ? 's' : ''}</span>
                : <span style="font-size:0.5rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:#DCDCDC;">Soon</span>
              }
            </div>
            <p style="font-size:0.75rem; font-weight:300; line-height:1.6; color:#6B6B6B;">{cat.description}</p>
            {cat.count > 0 && (
              <div style="display:flex; align-items:center; gap:0.5rem; margin-top:auto;">
                <span style="font-size:0.5625rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:#0A0A0A;">Δες τα demos</span>
                <div style="flex:1; height:1px; background:#0A0A0A; max-width:1.5rem;"></div>
              </div>
            )}
          </a>
        ))}
      </div>
    </section>

    <!-- Footer -->
    <footer style="margin-top:auto; padding:1.5rem 2.5rem; border-top:1px solid #E8E8E8; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
      <p style="font-size:0.5625rem; font-weight:400; color:#DCDCDC; letter-spacing:0.08em;">© {new Date().getFullYear()} Instatok</p>
      <p style="font-size:0.5625rem; font-weight:400; color:#DCDCDC; letter-spacing:0.08em;">Demos for review only — not for public distribution</p>
    </footer>

  </main>
</ShowcaseBase>

<style>
  .cat-card:hover {
    background: #F4F4F4 !important;
  }
  .cat-card--inactive:hover {
    background: #FAFAFA !important;
  }
</style>
