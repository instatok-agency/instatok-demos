---
import ShowcaseBase from '../../layouts/ShowcaseBase.astro';

const variants = [
  {
    num: '01',
    href: '/hotel/1',
    title: 'Island Resort',
    palette: 'Forest Green · Warm Cream · Gold',
    fonts: 'Playfair Display + Outfit',
    mood: 'Boutique island resort εμπνευσμένο από το CozyStay Island Resort. Κεφαλονιά, Ιόνιο. Hero booking widget, 4 δωμάτια, spa, γαστρονομία.',
    active: true,
  },
];
---

<ShowcaseBase title="Hotel / Resort Demos — Instatok">
  <main style="min-height:100dvh; display:flex; flex-direction:column; background:#FAFAFA;">

    <header style="padding:2rem 2.5rem; border-bottom:1px solid #E8E8E8; display:flex; align-items:center; gap:1.5rem;">
      <a href="/" style="font-size:0.5625rem; font-weight:400; letter-spacing:0.14em; text-transform:uppercase; color:#ABABAB; text-decoration:none; transition:color 0.2s;"
        onmouseover="this.style.color='#0A0A0A'" onmouseout="this.style.color='#ABABAB'">← Demos</a>
      <span style="width:1px; height:0.875rem; background:#E8E8E8;"></span>
      <span style="font-size:0.6875rem; font-weight:400; color:#0A0A0A;">Hotel / Resort</span>
    </header>

    <section style="padding:4rem 2.5rem 3rem; max-width:72rem; margin:0 auto; width:100%;">
      <p style="font-size:0.625rem; font-weight:500; letter-spacing:0.18em; text-transform:uppercase; color:#ABABAB; margin-bottom:1rem;">Κατηγορία</p>
      <h1 style="font-size:clamp(1.75rem, 5vw, 3rem); font-weight:300; letter-spacing:-0.02em; line-height:1.15; color:#0A0A0A; margin-bottom:1rem;">
        Hotel / Resort
      </h1>
      <p style="font-size:0.875rem; font-weight:300; line-height:1.7; color:#6B6B6B; max-width:34rem;">
        Πολυτελή ξενοδοχεία και boutique resorts. Booking widget, δωμάτια με τιμές, εμπειρίες, υπηρεσίες.
      </p>
    </section>

    <section style="padding:0 2.5rem 6rem; max-width:72rem; margin:0 auto; width:100%;">
      <div style="display:flex; flex-direction:column; gap:0; border-top:1px solid #E8E8E8;">
        {variants.map(v => (
          <div style={`display:flex; align-items:baseline; gap:2rem; padding:2rem 0; border-bottom:1px solid #E8E8E8; flex-wrap:wrap;${!v.active ? ' opacity:0.45;' : ''}`}>
            <span style="font-family:ui-monospace,'JetBrains Mono','Courier New',monospace; font-size:0.625rem; color:#DCDCDC; flex-shrink:0; width:1.5rem;">{v.num}</span>
            <div style="flex:1; display:flex; flex-direction:column; gap:0.375rem; min-width:12rem;">
              <span style="font-size:1rem; font-weight:400; color:#0A0A0A;">{v.title}</span>
              <div style="display:flex; gap:1.5rem; flex-wrap:wrap;">
                <span style="font-size:0.625rem; font-weight:400; letter-spacing:0.08em; color:#ABABAB;">{v.palette}</span>
                <span style="font-size:0.625rem; font-weight:400; letter-spacing:0.08em; color:#ABABAB;">{v.fonts}</span>
              </div>
              <span style="font-size:0.75rem; font-weight:300; color:#6B6B6B;">{v.mood}</span>
            </div>
            {v.active
              ? <a href={v.href} style="font-size:0.5625rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:#0A0A0A; text-decoration:none; white-space:nowrap; border-bottom:1px solid #0A0A0A; padding-bottom:0.125rem;">Άνοιγμα demo →</a>
              : <span style="font-size:0.5rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:#DCDCDC;">Soon</span>
            }
          </div>
        ))}
      </div>
    </section>

  </main>
</ShowcaseBase>
