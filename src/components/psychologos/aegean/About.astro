---
---

<section class="about" id="about" aria-labelledby="about-heading">
  <div class="about__inner aegean-section-inner">

    <div class="about__card-col" data-about-anim="card">
      <div class="about__card">
        <svg class="about__botanical" viewBox="0 0 80 120" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" aria-hidden="true">
          <path d="M40,112 L40,20" />
          <path d="M40,88 C30,76 16,74 13,68" />
          <ellipse cx="14" cy="67" rx="8" ry="4.5" transform="rotate(-28 14 67)" />
          <path d="M40,72 C50,60 64,58 67,52" />
          <ellipse cx="66" cy="51" rx="8" ry="4.5" transform="rotate(22 66 51)" />
          <path d="M40,56 C31,46 18,44 15,38" />
          <ellipse cx="16" cy="37" rx="7" ry="4" transform="rotate(-24 16 37)" />
          <path d="M40,40 C49,32 61,30 63,24" />
          <ellipse cx="62" cy="23" rx="7" ry="4" transform="rotate(18 62 23)" />
        </svg>
        <div class="about__card-text">
          <p class="about__card-name">Δρ. Άννα Δημητρίου</p>
          <p class="about__card-role">Ψυχοθεραπεύτρια</p>
          <p class="about__card-spec">Ειδίκευση: Τραύμα</p>
        </div>
        <div class="about__card-loc">
          <span class="about__card-dot"></span>
          Παγκράτι, Αθήνα
        </div>
      </div>
    </div>

    <div class="about__content-col">
      <header class="about__header" data-about-anim="header">
        <div class="about__eyebrow">
          <span class="about__eyebrow-line"></span>
          <span>Ποια είμαι</span>
        </div>
        <h2 class="about__heading" id="about-heading">
          Γιατί έγινα<br><em>θεραπεύτρια</em>
        </h2>
      </header>

      <div class="about__text-block" data-about-anim="text">
        <p>
          Έγινα θεραπεύτρια επειδή για χρόνια ήμουν εγώ αυτή που κράταγε
          τα πάντα μέσα. Τα διάβαζα, τα ανέλυα, τα «διαχειριζόμουν» —
          αλλά δεν τα έλεγα ποτέ. Η θεραπεία με δίδαξε ότι όταν ονομάζεις
          κάτι, μειώνεις την εξουσία του. Αυτό κάνω τώρα μαζί σου.
        </p>
        <p>
          Δεν πιστεύω στη θεραπεία ως «επίλυση προβλημάτων». Πιστεύω σε
          έναν χώρο όπου ακούγεσαι — χωρίς να βιαστείς, χωρίς να κριθείς,
          χωρίς να χρειαστεί να εξηγήσεις γιατί αισθάνεσαι αυτό που αισθάνεσαι.
        </p>
      </div>

      <dl class="about__contrasts" data-about-anim="contrasts">
        <div class="about__contrast-pair">
          <dt>Δεν δίνω συμβουλές</dt>
          <dd>Ακούω πρότυπα</dd>
        </div>
        <div class="about__contrast-pair">
          <dt>Δεν σε «διορθώνω»</dt>
          <dd>Ανακαλύπτουμε μαζί</dd>
        </div>
        <div class="about__contrast-pair">
          <dt>Δεν απαιτώ γραμμική πρόοδο</dt>
          <dd>Εκτιμώ κάθε επιστροφή</dd>
        </div>
      </dl>

      <div class="about__credentials" data-about-anim="credentials">
        <span>MSc Κλινική Ψυχολογία, Παν. Αθηνών</span>
        <span>&middot;</span>
        <span>Εκπαίδευση EMDR Europe</span>
        <span>&middot;</span>
        <span>ΕΛΨΕ #ΧΧΧΧΧ</span>
        <span>&middot;</span>
        <span>Somatic Experiencing® Practitioner</span>
      </div>
    </div>

  </div>
</section>

<style>
  .about {
    padding-block: var(--s-8);
    background:
      radial-gradient(ellipse 60% 40% at 5% 50%, rgba(122, 132, 113, 0.15) 0%, transparent 60%),
      var(--c-clay-3);
    position: relative; overflow: hidden;
  }

  .about__inner {
    display: grid;
    gap: var(--s-7);
    align-items: start;
  }

  .about__card {
    position: relative;
    background: var(--c-sage);
    border-radius: 4px;
    padding: var(--s-6) var(--s-5);
    transform: rotate(-2.5deg);
    transform-origin: center;
    display: flex; flex-direction: column;
    align-items: center; gap: var(--s-4);
    max-width: 260px; margin-inline: auto;
    box-shadow:
      4px 6px 0 0 var(--c-clay-2),
      8px 12px 24px -4px color-mix(in srgb, var(--c-ink) 20%, transparent);
  }
  .about__card::before {
    content: "";
    position: absolute; inset: 6px;
    border: 1px dashed color-mix(in srgb, var(--c-bone) 30%, transparent);
    border-radius: 2px; pointer-events: none;
  }
  .about__botanical {
    width: 52px; height: auto; color: var(--c-bone); opacity: 0.7;
  }
  .about__card-text { text-align: center; }
  .about__card-name {
    font-family: var(--f-display); font-size: 1.15rem;
    color: var(--c-bone); line-height: 1.2; margin-bottom: 0.3rem;
  }
  .about__card-role {
    font-family: var(--f-mono); font-size: 0.7rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: color-mix(in srgb, var(--c-bone) 70%, transparent);
    margin-bottom: 0.2rem;
  }
  .about__card-spec {
    font-family: var(--f-mono); font-size: 0.65rem;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: color-mix(in srgb, var(--c-bone) 50%, transparent);
  }
  .about__card-loc {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--f-mono); font-size: 0.65rem;
    letter-spacing: 0.06em; color: color-mix(in srgb, var(--c-bone) 55%, transparent);
  }
  .about__card-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--c-terra);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--c-terra) 25%, transparent);
  }

  .about__header { margin-bottom: var(--s-6); }
  .about__eyebrow {
    display: flex; align-items: center; gap: var(--s-3);
    font-family: var(--f-mono); font-size: 0.7rem;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--c-ink-soft); margin-bottom: var(--s-4);
  }
  .about__eyebrow-line { width: 28px; height: 1px; background: var(--c-terra); }
  .about__heading {
    font-family: var(--f-display); font-weight: 400;
    font-size: clamp(2.2rem, 8vw, 3.2rem); line-height: 1;
    letter-spacing: -0.01em;
  }
  .about__heading em {
    font-family: var(--f-body); font-style: italic;
    font-weight: 300; color: var(--c-ink-soft);
  }

  .about__text-block {
    display: grid; gap: var(--s-4);
    margin-bottom: var(--s-6);
  }
  .about__text-block p {
    font-size: 1.0625rem; line-height: 1.65; color: var(--c-ink-soft);
    max-width: 42ch;
  }

  .about__contrasts {
    margin-bottom: var(--s-6);
    display: grid; gap: 0;
  }
  .about__contrast-pair {
    display: grid; grid-template-columns: 1fr auto 1fr;
    align-items: center; gap: var(--s-3);
    padding-block: 0.75rem;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 10%, transparent);
  }
  .about__contrast-pair:first-child {
    border-top: 1px solid color-mix(in srgb, var(--c-ink) 10%, transparent);
  }
  .about__contrast-pair dt {
    font-size: 0.9rem; color: var(--c-ink-soft); font-style: italic;
    font-family: var(--f-body);
  }
  .about__contrast-pair::after {
    content: "→";
    font-family: var(--f-mono); font-size: 0.8rem;
    color: var(--c-terra); text-align: center;
  }
  .about__contrast-pair dd {
    font-size: 0.9rem; font-weight: 500;
    color: var(--c-ink); font-family: var(--f-body);
  }

  .about__credentials {
    display: flex; flex-wrap: wrap; gap: 0.4rem 0.6rem;
    font-family: var(--f-mono); font-size: 0.68rem;
    letter-spacing: 0.06em; color: var(--c-ink-soft); line-height: 1.6;
  }
  .about__credentials span:nth-child(even) { opacity: 0.4; }

  @media (min-width: 1024px) {
    .about__inner {
      grid-template-columns: 280px 1fr;
      gap: var(--s-8);
    }
    .about__card { margin-inline: 0; }
    .about__card-col { padding-top: var(--s-7); }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initGSAP } from '../../../scripts/gsap-aegean';

  initGSAP();
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    const section = document.querySelector('.about');
    if (!section) return;

    gsap.from('[data-about-anim="card"]', {
      autoAlpha: 0, x: -30, rotation: -6,
      duration: 1.2, ease: 'power3.out',
      scrollTrigger: { trigger: section, start: 'top 80%', once: true },
    });

    gsap.from('[data-about-anim="header"]', {
      autoAlpha: 0, y: 24, duration: 1,
      scrollTrigger: { trigger: section, start: 'top 78%', once: true },
    });

    gsap.from('[data-about-anim="text"] p', {
      autoAlpha: 0, y: 18, stagger: 0.12, duration: 0.9,
      scrollTrigger: { trigger: section, start: 'top 72%', once: true },
    });

    gsap.from('[data-about-anim="contrasts"] .about__contrast-pair', {
      autoAlpha: 0, x: -12, stagger: 0.1, duration: 0.8,
      scrollTrigger: { trigger: '[data-about-anim="contrasts"]', start: 'top 85%', once: true },
    });

    gsap.from('[data-about-anim="credentials"]', {
      autoAlpha: 0, y: 8, duration: 0.7,
      scrollTrigger: { trigger: '[data-about-anim="credentials"]', start: 'top 88%', once: true },
    });
  });
</script>
