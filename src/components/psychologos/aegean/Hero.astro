---
---

<section class="hero" aria-labelledby="hero-headline">
  <div class="hero__atmosphere" aria-hidden="true">
    <svg class="hero__blob hero__blob--1" viewBox="0 0 400 400" preserveAspectRatio="none">
      <path d="M210,60 C310,40 372,138 350,242 C334,332 230,366 142,322 C68,286 38,184 78,116 C108,66 168,68 210,60 Z" />
    </svg>
    <svg class="hero__blob hero__blob--2" viewBox="0 0 200 200" preserveAspectRatio="none">
      <path d="M104,28 C156,22 184,72 172,124 C162,170 112,184 72,162 C32,140 18,88 50,58 C76,32 90,30 104,28 Z" />
    </svg>
    <svg class="hero__squiggle" viewBox="0 0 220 70" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
      <path d="M6,40 Q28,10 50,40 T94,40 T138,40 T182,40 T214,40" />
    </svg>
    <svg class="hero__leaf" viewBox="0 0 80 140" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
      <path d="M40,8 C40,8 14,40 14,80 C14,108 28,128 40,132 C52,128 66,108 66,80 C66,40 40,8 40,8 Z" />
      <path d="M40,18 L40,128" />
      <path d="M40,40 L22,56 M40,52 L20,72 M40,66 L22,86 M40,80 L24,98" stroke-width="0.8" />
      <path d="M40,40 L58,56 M40,52 L60,72 M40,66 L58,86 M40,80 L56,98" stroke-width="0.8" />
    </svg>
    <div class="hero__grain"></div>
  </div>

  <div class="hero__inner aegean-section-inner">
    <div class="hero__stamp" data-anim="stamp">
      <span class="hero__stamp-rule"></span>
      <span>Αθήνα · Παγκράτι · est. 2019</span>
    </div>

    <p class="hero__eyebrow" data-anim="eyebrow">
      <span class="hero__eyebrow-mark"></span>
      <span>Ψυχοθεραπεία &middot; Trauma-informed</span>
    </p>

    <h1 class="hero__headline" id="hero-headline">
      <span class="hero__line">
        <span class="hero__word" data-anim="word">Όχι,</span>
      </span>
      <span class="hero__line">
        <span class="hero__word hero__word--em" data-anim="word"><em>δεν&nbsp;είσαι</em></span>
      </span>
      <span class="hero__line">
        <span class="hero__word" data-anim="word">«υπερβολικά».</span>
      </span>
      <span class="hero__line hero__line--coda">
        <span class="hero__word hero__word--coda" data-anim="word">
          Απλώς δεν είχες ποτέ τον χώρο.
        </span>
      </span>
    </h1>

    <p class="hero__lead" data-anim="lead">
      Είμαι η <strong>Άννα Δημητρίου</strong> — ψυχοθεραπεύτρια με ειδίκευση στο τραύμα.
      Αν τα δίκτυα σε εξουθενώνουν, η δουλειά τρώει το νόημά σου ή οι σχέσεις σου
      γυρίζουν στους ίδιους κύκλους — εδώ ακούμε αργά.
    </p>

    <ol class="hero__list" data-anim="list">
      <li><span class="hero__num">01</span><span>Burnout που δεν λύνεται με Σαββατοκύριακο</span></li>
      <li><span class="hero__num">02</span><span>Άγχος από social media &amp; σύγκριση</span></li>
      <li><span class="hero__num">03</span><span>Σχέσεις που μοιάζουν με επανάληψη</span></li>
      <li><span class="hero__num">04</span><span>Ταυτότητα, πένθος, αλλαγές στα 30</span></li>
    </ol>

    <div class="hero__actions" data-anim="actions">
      <a href="#booking" class="hero__cta hero__cta--primary">
        <span>Ας μιλήσουμε</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#method" class="hero__cta hero__cta--ghost">Πώς δουλεύουμε</a>
    </div>

    <p class="hero__availability" data-anim="availability">
      <span class="hero__pulse" aria-hidden="true"></span>
      <span><strong>Δύο νέες θέσεις</strong> ανοιχτές αυτή την εβδομάδα · διά ζώσης &amp; online</span>
    </p>
  </div>

  <div class="hero__corner" aria-hidden="true">
    <span>N°</span><span>01</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    padding-block: var(--s-7) var(--s-6);
    background:
      radial-gradient(ellipse 80% 60% at 85% 5%,  rgba(232, 165, 152, 0.48) 0%, transparent 55%),
      radial-gradient(ellipse 70% 50% at 0%  95%, rgba(122, 132, 113, 0.22) 0%, transparent 55%),
      linear-gradient(178deg, var(--c-clay) 0%, var(--c-clay-2) 100%);
    overflow: hidden;
    isolation: isolate;
  }

  .hero__atmosphere {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
  }
  .hero__blob {
    position: absolute;
    fill: var(--c-rose);
    mix-blend-mode: multiply;
    filter: blur(30px);
    opacity: 0.55;
  }
  .hero__blob--1 { top: -10%; right: -28%; width: 90%; aspect-ratio: 1; }
  .hero__blob--2 {
    bottom: -12%; left: -32%; width: 78%; aspect-ratio: 1;
    fill: var(--c-sage); opacity: 0.38;
  }
  .hero__squiggle {
    position: absolute; top: 38%; right: -6%; width: 36%;
    color: var(--c-terra); opacity: 0.4; transform: rotate(-12deg);
  }
  .hero__leaf {
    position: absolute; bottom: 5%; right: 5%;
    width: 52px; color: var(--c-sage); opacity: 0.5;
  }
  .hero__grain {
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.18 0 0 0 0 0.12 0 0 0 0 0.14 0 0 0 0.55 0'/></filter><rect width='100%' height='100%' filter='url(%23n)' opacity='0.5'/></svg>");
    background-size: 180px 180px; mix-blend-mode: multiply; opacity: 0.3;
  }

  .hero__corner {
    position: absolute; top: var(--s-5); right: var(--s-5); z-index: 2;
    font-family: var(--f-mono); font-size: 11px; color: var(--c-ink-soft);
    display: flex; gap: 4px; letter-spacing: 0.04em; transform: rotate(2deg);
  }
  .hero__corner span:last-child { color: var(--c-terra); }

  .hero__inner {
    position: relative; z-index: 1; padding-block: 0;
    display: grid; gap: var(--s-6);
  }

  .hero__stamp {
    display: flex; align-items: center; gap: var(--s-3);
    font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.08em;
    color: var(--c-ink-soft); text-transform: uppercase;
    transform: rotate(-1.5deg); transform-origin: left center;
    margin-bottom: calc(var(--s-5) * -1);
  }
  .hero__stamp-rule { flex: 0 0 28px; height: 1px; background: var(--c-terra); }

  .hero__eyebrow {
    display: inline-flex; align-items: center; gap: var(--s-3); align-self: start;
    padding: 0.5rem 0.9rem; border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--c-ink) 18%, transparent);
    background: color-mix(in srgb, var(--c-bone) 60%, transparent);
    font-family: var(--f-mono); font-size: 0.7rem;
    letter-spacing: 0.12em; text-transform: uppercase;
    backdrop-filter: blur(6px);
  }
  .hero__eyebrow-mark {
    width: 7px; height: 7px; border-radius: 50%; background: var(--c-terra);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--c-terra) 18%, transparent);
  }

  .hero__headline {
    font-family: var(--f-display); font-weight: 400;
    font-size: clamp(2.7rem, 13vw, 4rem);
    line-height: 0.97; letter-spacing: -0.01em; margin: 0; max-width: 14ch;
  }
  .hero__line { display: block; overflow: hidden; padding-bottom: 0.06em; }
  .hero__line--coda { margin-top: var(--s-3); }
  .hero__word { display: inline-block; will-change: transform, opacity; }
  .hero__word--em em {
    font-family: var(--f-body); font-style: italic; font-weight: 400;
    color: var(--c-terra); position: relative;
  }
  .hero__word--em em::after {
    content: ""; position: absolute; left: -2%; right: -2%; bottom: 0.06em;
    height: 0.09em; background: color-mix(in srgb, var(--c-terra) 30%, transparent);
    border-radius: 999px; z-index: -1;
  }
  .hero__word--coda {
    font-family: var(--f-body); font-style: italic; font-weight: 300;
    font-size: 1.2rem; line-height: 1.4; color: var(--c-ink-soft); letter-spacing: 0;
  }

  .hero__lead {
    font-size: 1.0625rem; line-height: 1.6; color: var(--c-ink-soft);
    max-width: 38ch; margin: 0;
  }
  .hero__lead strong { color: var(--c-ink); font-weight: 500; }

  .hero__list {
    list-style: none; display: grid; gap: 0.6rem;
    padding-block: var(--s-5);
    border-top: 1px solid color-mix(in srgb, var(--c-ink) 14%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 14%, transparent);
  }
  .hero__list li {
    display: grid; grid-template-columns: 2.25rem 1fr;
    align-items: baseline; gap: var(--s-3);
    font-size: 0.95rem; line-height: 1.4;
  }
  .hero__num {
    font-family: var(--f-mono); font-size: 0.72rem;
    color: var(--c-terra); letter-spacing: 0.05em; padding-top: 0.2em;
  }

  .hero__actions { display: flex; flex-direction: column; gap: var(--s-3); }
  .hero__cta {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.6rem; padding: 1.05rem 1.4rem; border-radius: 999px;
    font-family: var(--f-body); font-size: 1rem; font-weight: 500;
    text-decoration: none;
    transition: transform 0.32s cubic-bezier(0.34, 1.4, 0.5, 1), background 0.22s, color 0.22s;
  }
  .hero__cta svg { width: 18px; height: 18px; }
  .hero__cta--primary {
    background: var(--c-ink); color: var(--c-bone);
    box-shadow: 0 12px 32px -8px color-mix(in srgb, var(--c-ink) 30%, transparent);
  }
  .hero__cta--primary:hover { background: var(--c-terra); transform: translateY(-2px); }
  .hero__cta--ghost {
    background: transparent; color: var(--c-ink);
    border: 1px solid color-mix(in srgb, var(--c-ink) 25%, transparent);
  }
  .hero__cta--ghost:hover {
    background: color-mix(in srgb, var(--c-bone) 70%, transparent);
  }

  .hero__availability {
    display: flex; align-items: center; gap: var(--s-3);
    font-size: 0.85rem; line-height: 1.45; color: var(--c-ink-soft); margin: 0;
  }
  .hero__availability strong { color: var(--c-ink); font-weight: 500; }
  .hero__pulse {
    flex-shrink: 0; width: 8px; height: 8px; border-radius: 50%;
    background: var(--c-sage); position: relative;
  }
  .hero__pulse--live { background: var(--c-terra); animation: pulse-dot 2.4s ease-out infinite; }
  .hero__pulse--live::before {
    content: ""; position: absolute; inset: -3px; border-radius: 50%;
    background: var(--c-terra); opacity: 0; animation: pulse-ring 2.4s ease-out infinite;
  }
  @keyframes pulse-ring {
    0% { transform: scale(0.7); opacity: 0.55; }
    80%, 100% { transform: scale(2.2); opacity: 0; }
  }
  @keyframes pulse-dot {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.12); }
  }

  @media (min-width: 640px) {
    .hero { padding-block: var(--s-8) var(--s-7); }
    .hero__headline { font-size: clamp(3.6rem, 9vw, 5.5rem); }
    .hero__actions { flex-direction: row; }
  }

  @media (min-width: 1024px) {
    .hero { padding-block: 6rem 4rem; }
    .hero__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 0.85fr);
      column-gap: var(--s-8);
      grid-template-areas:
        "stamp     stamp"
        "eyebrow   eyebrow"
        "headline  lead"
        "headline  list"
        "actions   availability";
    }
    .hero__stamp      { grid-area: stamp; }
    .hero__eyebrow    { grid-area: eyebrow; }
    .hero__headline   { grid-area: headline; font-size: clamp(4rem, 7vw, 6.5rem); }
    .hero__lead       { grid-area: lead; align-self: end; }
    .hero__list       { grid-area: list; }
    .hero__actions    { grid-area: actions; }
    .hero__availability { grid-area: availability; align-self: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__pulse--live,
    .hero__pulse--live::before { animation: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initGSAP } from '../../../scripts/gsap-aegean';

  initGSAP();
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add(
    {
      isMotion: '(prefers-reduced-motion: no-preference)',
      isReduced: '(prefers-reduced-motion: reduce)',
    },
    (ctx) => {
      const { isReduced } = ctx.conditions ?? {};

      const allTargets = '.hero__blob, .hero__squiggle, .hero__leaf, [data-anim="stamp"], [data-anim="eyebrow"], [data-anim="word"], [data-anim="lead"], [data-anim="list"] li, [data-anim="actions"], [data-anim="availability"]';

      gsap.set(allTargets, { autoAlpha: 0 });

      if (isReduced) {
        gsap.set(allTargets, { autoAlpha: 1 });
        document.querySelector('.hero__pulse')?.classList.add('hero__pulse--live');
        return;
      }

      const tl = gsap.timeline();

      tl.fromTo('.hero__blob, .hero__squiggle, .hero__leaf',
          { autoAlpha: 0, scale: 0.93 },
          { autoAlpha: 1, scale: 1, duration: 1.8, stagger: 0.15, ease: 'power2.out' }, 0)
        .fromTo('[data-anim="stamp"]',
          { autoAlpha: 0, y: -8 },
          { autoAlpha: 1, y: 0, duration: 0.85 }, 0.4)
        .fromTo('[data-anim="eyebrow"]',
          { autoAlpha: 0, y: 14 },
          { autoAlpha: 1, y: 0, duration: 0.8 }, 0.5)
        .fromTo('[data-anim="word"]',
          { autoAlpha: 0, yPercent: 115 },
          { autoAlpha: 1, yPercent: 0, duration: 1, stagger: 0.13, ease: 'power4.out' }, 0.58)
        .fromTo('[data-anim="lead"]',
          { autoAlpha: 0, y: 18 },
          { autoAlpha: 1, y: 0, duration: 0.9 }, '-=0.5')
        .fromTo('[data-anim="list"] li',
          { autoAlpha: 0, y: 14 },
          { autoAlpha: 1, y: 0, duration: 0.65, stagger: 0.08 }, '-=0.55')
        .fromTo('[data-anim="actions"]',
          { autoAlpha: 0, y: 14 },
          { autoAlpha: 1, y: 0, duration: 0.7 }, '-=0.38')
        .fromTo('[data-anim="availability"]',
          { autoAlpha: 0, y: 8 },
          { autoAlpha: 1, y: 0, duration: 0.7 }, '-=0.42')
        .add(() => {
          document.querySelector('.hero__pulse')?.classList.add('hero__pulse--live');
        }, '-=0.15');

      gsap.to('.hero__blob--1', {
        yPercent: 24, ease: 'none',
        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 0.6 },
      });
      gsap.to('.hero__blob--2', {
        yPercent: -30, xPercent: 10, ease: 'none',
        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 0.8 },
      });
      gsap.to('.hero__squiggle', {
        yPercent: 40, ease: 'none',
        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 0.7 },
      });
    }
  );
</script>
