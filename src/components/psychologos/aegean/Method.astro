---
const steps = [
  {
    num: '01',
    title: 'Παρατηρούμε',
    body: 'Πριν μιλήσουμε για το τι συνέβη, ακούμε τι κάνει το σώμα σου τώρα. Ένα σφίξιμο στο στήθος. Μια ανάσα που κρατάς. Αυτά δεν λένε ψέματα — και συχνά ξέρουν περισσότερα από τις λέξεις.',
  },
  {
    num: '02',
    title: 'Ονομάζουμε',
    body: 'Δίνουμε λέξεις σε πράγματα που δεν είχαν. Όχι για να τα «λύσουμε» — αλλά επειδή αυτό που δεν έχει όνομα τρομάζει περισσότερο από αυτό που έχει. Η γλώσσα δημιουργεί χώρο.',
  },
  {
    num: '03',
    title: 'Ξαναβρισκόμαστε',
    body: 'Η θεραπεία δεν σε αλλάζει. Σε επαναφέρει σε κάτι που ήταν πάντα εκεί — κάτω από το burnout, τον θόρυβο, τις προσδοκίες. Κάτι που έχεις ήδη, που απλώς δεν άκουγε για καιρό.',
  },
];
---

<section class="method" id="method" aria-labelledby="method-heading">
  <div class="method__inner aegean-section-inner">

    <header class="method__header" data-method-anim="header">
      <div class="method__eyebrow">
        <span class="method__eyebrow-line"></span>
        <span>Η προσέγγιση</span>
      </div>
      <h2 class="method__heading" id="method-heading">
        Πώς δουλεύουμε
      </h2>
      <p class="method__subhead">
        Τρία αργά βήματα — και δεν είναι γραμμικά.
      </p>
    </header>

    <ol class="method__steps" role="list">
      {steps.map((step, i) => (
        <li class="method__step" data-method-anim="step" data-step-index={i}>
          <div class="method__step-marker">
            <span class="method__step-num">{step.num}</span>
            <div class="method__step-connector" aria-hidden="true"></div>
          </div>
          <div class="method__step-body">
            <h3 class="method__step-title">{step.title}</h3>
            <p class="method__step-text">{step.body}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="method__coda" data-method-anim="coda">
      <svg class="method__coda-ornament" viewBox="0 0 40 12" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
        <path d="M2,6 Q10,1 20,6 T38,6" stroke-linecap="round"/>
      </svg>
      <p>
        Δεν είναι γραμμικό. Κάποιες εβδομάδες επιστρέφουμε στο βήμα ένα.
        <em>Αυτό δεν σημαίνει ότι αποτυγχάνουμε — σημαίνει ότι κάνουμε δουλειά.</em>
      </p>
    </div>

  </div>
</section>

<style>
  .method {
    padding-block: var(--s-8);
    background:
      radial-gradient(ellipse 70% 50% at 95% 20%, rgba(232, 165, 152, 0.2) 0%, transparent 55%),
      var(--c-clay-4);
    position: relative; overflow: hidden;
  }
  .method::before {
    content: "";
    position: absolute; top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--c-clay-2), transparent);
  }

  .method__inner { display: grid; gap: var(--s-7); }

  .method__eyebrow {
    display: flex; align-items: center; gap: var(--s-3); margin-bottom: var(--s-4);
    font-family: var(--f-mono); font-size: 0.7rem;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--c-ink-soft);
  }
  .method__eyebrow-line { width: 28px; height: 1px; background: var(--c-sage); }
  .method__heading {
    font-family: var(--f-display); font-weight: 400;
    font-size: clamp(2rem, 7vw, 3rem); line-height: 1.05;
    letter-spacing: -0.01em; margin-bottom: var(--s-4);
  }
  .method__subhead {
    font-family: var(--f-body); font-style: italic; font-weight: 300;
    font-size: 1.1rem; color: var(--c-ink-soft); line-height: 1.5;
  }

  .method__steps {
    list-style: none; display: grid; gap: 0;
    position: relative;
  }
  .method__step {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: var(--s-5);
    padding-bottom: var(--s-7);
    position: relative;
  }
  .method__step:last-child { padding-bottom: 0; }

  .method__step-marker {
    display: flex; flex-direction: column; align-items: center; gap: 0;
  }
  .method__step-num {
    font-family: var(--f-mono); font-size: 0.72rem;
    color: var(--c-terra); letter-spacing: 0.06em;
    background: var(--c-clay-4);
    padding: 0.25rem 0; z-index: 1;
    flex-shrink: 0; width: 2rem; text-align: center;
  }
  .method__step-connector {
    flex: 1; width: 1px; margin-top: 0.5rem;
    background: linear-gradient(to bottom, var(--c-sage) 0%, color-mix(in srgb, var(--c-sage) 20%, transparent) 100%);
  }
  .method__step:last-child .method__step-connector { display: none; }

  .method__step-body { padding-top: 0.1rem; }
  .method__step-title {
    font-family: var(--f-display); font-weight: 400;
    font-size: clamp(1.6rem, 5vw, 2.2rem); line-height: 1.1;
    letter-spacing: -0.01em; margin-bottom: var(--s-4);
  }
  .method__step-text {
    font-size: 1rem; line-height: 1.7; color: var(--c-ink-soft); max-width: 40ch;
  }

  .method__coda {
    display: flex; flex-direction: column; align-items: flex-start; gap: var(--s-3);
    padding: var(--s-5) var(--s-5);
    background: color-mix(in srgb, var(--c-bone) 40%, transparent);
    border-left: 2px solid var(--c-sage);
    border-radius: 0 4px 4px 0;
  }
  .method__coda-ornament { width: 40px; color: var(--c-sage); opacity: 0.7; }
  .method__coda p {
    font-size: 0.95rem; line-height: 1.65; color: var(--c-ink-soft);
  }
  .method__coda em { font-style: italic; color: var(--c-ink); font-weight: 400; }

  @media (min-width: 1024px) {
    .method__inner {
      grid-template-columns: 1fr 2fr;
      gap: var(--s-8);
    }
    .method__header { position: sticky; top: var(--s-7); align-self: start; }
    .method__steps { grid-column: 2; }
    .method__coda { grid-column: 2; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initGSAP } from '../../../scripts/gsap-aegean';

  initGSAP();
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    const section = document.querySelector('.method');
    if (!section) return;

    gsap.from('[data-method-anim="header"] > *', {
      autoAlpha: 0, y: 20, stagger: 0.1, duration: 1,
      scrollTrigger: { trigger: section, start: 'top 80%', once: true },
    });

    gsap.from('[data-method-anim="step"]', {
      autoAlpha: 0, x: -20, stagger: 0.18, duration: 1.1,
      scrollTrigger: { trigger: '.method__steps', start: 'top 82%', once: true },
    });

    document.querySelectorAll('.method__step-connector').forEach((connector) => {
      gsap.from(connector, {
        scaleY: 0, transformOrigin: 'top center', duration: 0.9,
        scrollTrigger: {
          trigger: connector.closest('.method__step'),
          start: 'top 80%', once: true,
        },
      });
    });

    gsap.from('[data-method-anim="coda"]', {
      autoAlpha: 0, x: -16, duration: 1,
      scrollTrigger: { trigger: '[data-method-anim="coda"]', start: 'top 88%', once: true },
    });
  });
</script>
