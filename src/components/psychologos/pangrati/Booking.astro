---
---

<section class="booking" id="booking" aria-labelledby="booking-heading">
  <hr class="section-rule booking__top-rule" aria-hidden="true" />

  <div class="booking__inner pangrati-section-inner">

    <header class="booking__header">
      <p class="eyebrow booking__eyebrow" data-anim="reveal">Κλείσε ραντεβού</p>
      <h2 class="booking__heading" id="booking-heading" data-anim="reveal">
        Το πρώτο σου μήνυμα
      </h2>
      <p class="booking__subtitle" data-anim="reveal">
        Δεν χρειάζεται να είναι τέλειο.<br />
        <em>Αρκεί να είναι αληθινό.</em>
      </p>
    </header>

    <div class="booking__body">
      <!-- Form -->
      <form class="booking__form" novalidate aria-label="Φόρμα επικοινωνίας" data-anim="form">
        <div class="booking__row booking__row--inline">
          <label class="booking__prose-label" for="field-name">Με λένε</label>
          <div class="booking__field-wrap">
            <input
              type="text"
              id="field-name"
              name="name"
              class="booking__input"
              autocomplete="given-name"
              aria-required="true"
              placeholder="το όνομά σου"
            />
          </div>
          <span class="booking__prose-label" aria-hidden="true">.</span>
        </div>

        <div class="booking__row booking__row--inline">
          <label class="booking__prose-label" for="field-age">Είμαι</label>
          <div class="booking__field-wrap booking__field-wrap--narrow">
            <input
              type="number"
              id="field-age"
              name="age"
              class="booking__input"
              min="16"
              max="99"
              placeholder="ηλικία"
              aria-label="Ηλικία σε χρόνια"
            />
          </div>
          <span class="booking__prose-label" aria-hidden="true">χρονών.</span>
        </div>

        <div class="booking__row booking__row--block">
          <label class="booking__label" for="field-message">
            Θέλω να μιλήσουμε για:
          </label>
          <textarea
            id="field-message"
            name="message"
            class="booking__textarea"
            rows="5"
            placeholder="Δεν χρειάζεται να είναι οργανωμένο. Γράψε όπως έρχεται…"
            aria-required="true"
          ></textarea>
        </div>

        <div class="booking__row booking__row--block">
          <fieldset class="booking__fieldset" aria-label="Τρόπος συνεδρίας">
            <legend class="booking__label">Προτιμώ:</legend>
            <div class="booking__pills">
              <label class="booking__pill">
                <input type="radio" name="mode" value="pangrati" checked />
                <span>Παγκράτι</span>
              </label>
              <label class="booking__pill">
                <input type="radio" name="mode" value="online" />
                <span>Online</span>
              </label>
              <label class="booking__pill">
                <input type="radio" name="mode" value="unsure" />
                <span>Δεν ξέρω ακόμα</span>
              </label>
            </div>
          </fieldset>
        </div>

        <div class="booking__row booking__row--block">
          <label class="booking__label" for="field-contact">
            Με βρίσκετε στο:
          </label>
          <div class="booking__field-wrap">
            <input
              type="text"
              id="field-contact"
              name="contact"
              class="booking__input"
              autocomplete="email"
              aria-required="true"
              placeholder="email ή τηλέφωνο"
            />
          </div>
        </div>

        <div class="booking__submit-row" data-anim="reveal">
          <button type="submit" class="booking__submit">
            <span>Στέλνω το πρώτο μήνυμα</span>
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M4 10h12M11 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <ul class="booking__reassurance eyebrow" aria-label="Δεσμεύσεις επικοινωνίας">
            <li>Απάντηση εντός 48 ωρών</li>
            <li>Χωρίς chatbot</li>
            <li>Απόλυτη εχεμύθεια</li>
          </ul>
        </div>

        <p class="booking__mock eyebrow" role="note">
          Mockup mode · Επικοινωνία: anna@example.com
        </p>
      </form>

      <!-- Side note (desktop only) -->
      <aside class="booking__aside" aria-label="Σημείωση" data-anim="reveal">
        <blockquote class="booking__quote">
          <p>«Δεν χρειάζεται να ξέρεις τι θέλεις να πεις. Αρκεί να στείλεις το πρώτο μήνυμα.»</p>
          <footer class="booking__quote-footer">
            <cite>Άννα Δημητρίου</cite>
          </footer>
        </blockquote>
        <div class="booking__contact-info eyebrow">
          <p>anna@example.com</p>
          <p>+30 210 123 4567</p>
          <p>Signal: διαθέσιμη</p>
        </div>
      </aside>
    </div>

  </div>
</section>

<style>
  .booking {
    background: var(--c-bg);
    padding-block: 0 var(--s-9);
  }

  .booking__inner { padding-block-start: var(--s-7); }

  /* ── Header ─────────────────────────────── */
  .booking__header { margin-bottom: var(--s-7); }
  .booking__eyebrow { margin-bottom: var(--s-3); }
  .booking__heading {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2.2rem, 5vw, 3.25rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: var(--s-4);
  }
  .booking__subtitle {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--c-ink-2);
  }
  .booking__subtitle em {
    font-family: var(--f-display);
    font-style: italic;
    color: var(--c-ink);
  }

  /* ── Body grid ──────────────────────────── */
  .booking__body {
    display: grid;
    gap: var(--s-8);
  }

  /* ── Form ───────────────────────────────── */
  .booking__form { display: grid; gap: var(--s-6); }

  .booking__row { display: grid; gap: var(--s-2); }

  .booking__row--inline {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--s-2) var(--s-3);
  }

  .booking__prose-label {
    font-family: var(--f-display);
    font-size: 1.125rem;
    font-style: italic;
    color: var(--c-ink-2);
    white-space: nowrap;
  }

  .booking__label {
    font-family: var(--f-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-ink-3);
  }

  /* ── Inputs ─────────────────────────────── */
  .booking__field-wrap { flex: 1; min-width: 10rem; }
  .booking__field-wrap--narrow { flex: 0 0 5rem; min-width: 5rem; }

  .booking__input {
    width: 100%;
    padding: 0.5rem 0;
    border: none;
    border-bottom: 1.5px solid var(--c-border);
    background: transparent;
    font-family: var(--f-body);
    font-size: 1rem;
    color: var(--c-ink);
    outline: none;
    transition: border-color 0.18s;
    appearance: textfield;
    -moz-appearance: textfield;
  }
  .booking__input::placeholder { color: var(--c-ink-3); }
  .booking__input:focus { border-bottom-color: var(--c-ink); }

  .booking__textarea {
    width: 100%;
    padding: var(--s-3) 0;
    border: none;
    border-bottom: 1.5px solid var(--c-border);
    background: transparent;
    font-family: var(--f-body);
    font-size: 1rem;
    color: var(--c-ink);
    outline: none;
    resize: vertical;
    min-height: 8rem;
    transition: border-color 0.18s;
  }
  .booking__textarea::placeholder { color: var(--c-ink-3); }
  .booking__textarea:focus { border-bottom-color: var(--c-ink); }

  /* ── Fieldset / pills ───────────────────── */
  .booking__fieldset {
    border: none;
    padding: 0;
    display: grid;
    gap: var(--s-2);
  }
  .booking__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-2);
  }
  .booking__pill {
    display: flex;
    align-items: center;
    cursor: pointer;
  }
  .booking__pill input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .booking__pill span {
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--c-border);
    font-family: var(--f-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-ink-2);
    transition: background 0.18s, color 0.18s, border-color 0.18s;
  }
  .booking__pill input:checked + span {
    background: var(--c-ink);
    color: var(--c-bg);
    border-color: var(--c-ink);
  }
  .booking__pill:hover span { border-color: var(--c-ink-2); }

  /* ── Submit row ─────────────────────────── */
  .booking__submit-row {
    display: grid;
    gap: var(--s-4);
    align-items: start;
  }
  .booking__submit {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.5rem;
    background: var(--c-terra);
    color: var(--c-bg);
    border: 1px solid var(--c-terra);
    font-family: var(--f-body);
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .booking__submit svg { width: 16px; height: 16px; flex-shrink: 0; }
  .booking__submit:hover {
    background: var(--c-terra-deep);
    border-color: var(--c-terra-deep);
  }

  .booking__reassurance {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2) var(--s-4);
    color: var(--c-ink-3);
  }
  .booking__reassurance li { position: relative; }
  .booking__reassurance li + li::before {
    content: "·";
    position: absolute;
    left: calc(var(--s-4) * -1 - 0.4ch);
    color: var(--c-terra);
  }

  .booking__mock {
    color: var(--c-ink-3);
    font-size: 0.62rem;
    padding-top: var(--s-3);
    border-top: 1px solid var(--c-rule);
  }

  /* ── Aside ──────────────────────────────── */
  .booking__aside { display: none; }

  .booking__quote {
    border-left: 2px solid var(--c-terra);
    padding-left: var(--s-5);
    margin-bottom: var(--s-6);
  }
  .booking__quote p {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--c-ink-2);
    margin-bottom: var(--s-3);
  }
  .booking__quote-footer cite {
    font-family: var(--f-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-ink-3);
    font-style: normal;
  }

  .booking__contact-info {
    display: grid;
    gap: var(--s-2);
    color: var(--c-ink-2);
    font-size: 0.72rem;
  }

  /* ── ≥1024px ────────────────────────────── */
  @media (min-width: 1024px) {
    .booking__body {
      grid-template-columns: 1fr 300px;
      align-items: start;
    }
    .booking__aside {
      display: block;
      padding-top: calc(var(--s-7) + var(--s-4));
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  /* Submit handler (mockup) */
  const form = document.querySelector<HTMLFormElement>('.booking__form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector<HTMLButtonElement>('.booking__submit');
    if (!btn) return;
    const originalText = btn.querySelector('span')!.textContent;
    btn.querySelector('span')!.textContent = 'Στάλθηκε ✓';
    btn.disabled = true;
    setTimeout(() => {
      btn.querySelector('span')!.textContent = originalText;
      btn.disabled = false;
      form.reset();
    }, 3000);
  });

  /* Scroll animations */
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('.booking__top-rule',
      { scaleX: 0 },
      {
        scaleX: 1, duration: 1.2, ease: 'power3.out',
        scrollTrigger: { trigger: '.booking', start: 'top 90%' },
      }
    );

    gsap.utils.toArray<HTMLElement>('.booking [data-anim="reveal"]').forEach(el => {
      gsap.fromTo(el,
        { autoAlpha: 0, y: 20 },
        {
          autoAlpha: 1, y: 0, duration: 0.85,
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
        }
      );
    });

    gsap.fromTo('.booking__form',
      { autoAlpha: 0, y: 28 },
      {
        autoAlpha: 1, y: 0, duration: 1.0, ease: 'power3.out',
        scrollTrigger: { trigger: '.booking__form', start: 'top 86%' },
      }
    );
  });
</script>
