---
---

<footer class="footer" role="contentinfo">
  <hr class="section-rule footer__top-rule" aria-hidden="true" />

  <div class="footer__inner pangrati-section-inner">

    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <p class="footer__name">Δρ. Άννα Δημητρίου</p>
        <p class="footer__role eyebrow">Ψυχοθεραπεύτρια</p>
        <p class="footer__cert eyebrow">ΕΛΨΕ #ΧΧΧΧΧ · Somatic Experiencing®</p>
      </div>

      <!-- Office -->
      <div class="footer__col">
        <p class="footer__col-heading eyebrow">Γραφείο</p>
        <address class="footer__address">
          <p>Αλεξάνδρας 44</p>
          <p>Παγκράτι, Αθήνα 11635</p>
          <p>Δευτ–Παρ · 10:00–19:00</p>
        </address>
      </div>

      <!-- Contact -->
      <div class="footer__col">
        <p class="footer__col-heading eyebrow">Επικοινωνία</p>
        <ul class="footer__contact" role="list">
          <li><a href="mailto:anna@example.com">anna@example.com</a></li>
          <li><a href="tel:+302101234567">+30 210 123 4567</a></li>
          <li>Signal: διαθέσιμη</li>
        </ul>
      </div>

      <!-- Legal -->
      <div class="footer__col">
        <p class="footer__col-heading eyebrow">Νομικά</p>
        <ul class="footer__legal" role="list">
          <li><a href="#">Πολιτική Απορρήτου</a></li>
          <li><a href="#">Όροι Χρήσης</a></li>
          <li><a href="#">GDPR</a></li>
        </ul>
        <p class="footer__ethics eyebrow">
          Δεσμευμένη από τον Κώδικα Δεοντολογίας της ΕΛΨΕ.
        </p>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy eyebrow">
        © 2026 · Δρ. Άννα Δημητρίου · Made slowly in Athens
      </p>
      <a href="#" class="footer__top eyebrow" aria-label="Επιστροφή στην κορυφή">
        Επάνω
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M7 11V3M3 7l4-4 4 4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</footer>

<style>
  .footer {
    background: var(--c-bg-2);
    padding-block: 0 var(--s-7);
  }

  .footer__inner { padding-block-start: var(--s-6); }

  /* ── Grid ───────────────────────────────── */
  .footer__grid {
    display: grid;
    gap: var(--s-6);
    padding-bottom: var(--s-6);
  }

  /* ── Brand ──────────────────────────────── */
  .footer__name {
    font-family: var(--f-display);
    font-weight: 500;
    font-size: 1.125rem;
    letter-spacing: -0.01em;
    color: var(--c-ink);
    margin-bottom: var(--s-2);
  }
  .footer__role {
    color: var(--c-ink-3);
    margin-bottom: var(--s-2);
  }
  .footer__cert {
    color: var(--c-terra);
    font-size: 0.62rem;
  }

  /* ── Columns ────────────────────────────── */
  .footer__col-heading {
    color: var(--c-ink-3);
    margin-bottom: var(--s-3);
    padding-bottom: var(--s-2);
    border-bottom: 1px solid var(--c-border);
  }

  .footer__address {
    font-style: normal;
    display: grid;
    gap: var(--s-1);
    font-size: 0.875rem;
    color: var(--c-ink-2);
    line-height: 1.5;
  }

  .footer__contact {
    list-style: none;
    display: grid;
    gap: var(--s-2);
    font-size: 0.875rem;
    color: var(--c-ink-2);
  }
  .footer__contact a {
    text-decoration: none;
    transition: color 0.18s;
  }
  .footer__contact a:hover { color: var(--c-terra); }

  .footer__legal {
    list-style: none;
    display: grid;
    gap: var(--s-1);
    font-family: var(--f-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--s-3);
  }
  .footer__legal a {
    color: var(--c-ink-2);
    text-decoration: none;
    transition: color 0.18s;
  }
  .footer__legal a:hover { color: var(--c-terra); }

  .footer__ethics {
    color: var(--c-ink-3);
    font-size: 0.62rem;
    line-height: 1.5;
  }

  /* ── Bottom bar ─────────────────────────── */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s-3);
    padding-top: var(--s-5);
    border-top: 1px solid var(--c-border);
  }

  .footer__copy {
    color: var(--c-ink-3);
    font-size: 0.62rem;
  }

  .footer__top {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-ink-2);
    text-decoration: none;
    transition: color 0.18s;
  }
  .footer__top svg { width: 12px; height: 12px; }
  .footer__top:hover { color: var(--c-terra); }

  /* ── ≥640px ─────────────────────────────── */
  @media (min-width: 640px) {
    .footer__grid { grid-template-columns: 1fr 1fr; }
  }

  /* ── ≥1024px ────────────────────────────── */
  @media (min-width: 1024px) {
    .footer__grid { grid-template-columns: 1.5fr 1fr 1fr 1fr; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('.footer__top-rule',
      { scaleX: 0 },
      {
        scaleX: 1, duration: 1.2, ease: 'power3.out',
        scrollTrigger: { trigger: '.footer', start: 'top 92%' },
      }
    );

    gsap.fromTo('.footer__grid > *',
      { autoAlpha: 0, y: 18 },
      {
        autoAlpha: 1, y: 0, duration: 0.7, stagger: 0.1,
        scrollTrigger: { trigger: '.footer__grid', start: 'top 90%' },
      }
    );
  });
</script>
