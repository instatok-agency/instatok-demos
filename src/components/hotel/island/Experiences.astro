---
const experiences = [
  {
    title: 'Spa & Ευεξία',
    subtitle: 'Serenity Spa',
    desc: 'Βυθιστείτε σε μια εμπειρία ολιστικής ευεξίας. Ayurvedic θεραπείες, σάουνα, hammam, yoga και meditation — κάθε στιγμή σχεδιασμένη για αναζωογόνηση σώματος και πνεύματος.',
    img: 'https://images.unsplash.com/photo-1540555700478-4be289fbecef?w=1000&q=85&fit=crop',
    alt: 'Spa θεραπείες',
  },
  {
    title: 'Γαστρονομία',
    subtitle: 'The Ionian Table',
    desc: 'Η κουζίνα μας εμπνέεται από τα τοπικά αρώματα και τα φρέσκα υλικά του Ιονίου. Farm-to-table φιλοσοφία, κρασιά από ντόπιους αμπελώνες, θέα στη θάλασσα.',
    img: 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1000&q=85&fit=crop',
    alt: 'Γαστρονομικό εστιατόριο',
  },
  {
    title: 'Island Activities',
    subtitle: 'Explore & Discover',
    desc: 'Ιστιοπλοΐα, καταδύσεις, kayak, πεζοπορία σε μονοπάτια με θέα, εξερεύνηση κρυφών σπηλαίων. Βιώστε το Ιόνιο από μια διαφορετική οπτική.',
    img: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1000&q=85&fit=crop',
    alt: 'Island δραστηριότητες',
  },
];
---

<section class="hi-exp" id="experiences" aria-label="Εμπειρίες">
  <div class="hi-exp__head hi-inner" data-anim="hi-exp-head">
    <p class="hi-eyebrow">Εμπειρίες</p>
    <h2 class="hi-sec-title">Unforgettable Experience</h2>
    <p class="hi-exp__sub">Ένας από τους πιο επιθυμητούς προορισμούς στη Μεσόγειο</p>
  </div>

  <div class="hi-exp__grid" data-anim="hi-exp-grid">
    {experiences.map(e => (
      <article class="hi-exp-card">
        <div class="hi-exp-card__img-wrap">
          <img src={e.img} alt={e.alt} class="hi-exp-card__img" width="1000" height="700" loading="lazy" />
          <div class="hi-exp-card__overlay" aria-hidden="true"></div>
        </div>
        <div class="hi-exp-card__body">
          <div class="hi-exp-card__text">
            <span class="hi-eyebrow hi-eyebrow--gold">{e.subtitle}</span>
            <h3 class="hi-exp-card__title">{e.title}</h3>
            <p class="hi-exp-card__desc">{e.desc}</p>
          </div>
          <a href="#contact" class="hi-exp-card__link">
            Discover More
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .hi-exp { background: var(--hi-white); padding-block: var(--s-9); }

  .hi-exp__head {
    display: grid; gap: var(--s-4); max-width: 48rem;
    margin-bottom: var(--s-7);
  }
  .hi-exp__sub {
    font-family: var(--f-display); font-style: italic;
    font-size: clamp(1rem, 2vw, 1.375rem);
    font-weight: 400; color: var(--hi-muted);
  }

  /* GRID — 3 columns on desktop */
  .hi-exp__grid {
    display: grid; gap: 0;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 24rem), 1fr));
  }

  /* CARD */
  .hi-exp-card {
    position: relative; overflow: hidden;
    height: clamp(400px, 55vw, 680px);
    cursor: default;
  }
  @media (min-width: 900px) { .hi-exp-card { height: clamp(480px, 55vh, 700px); } }

  .hi-exp-card__img-wrap {
    position: absolute; inset: 0;
  }
  .hi-exp-card__img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.7s ease;
  }
  .hi-exp-card:hover .hi-exp-card__img { transform: scale(1.04); }
  .hi-exp-card__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to top,
      rgba(15,32,24,0.92) 0%,
      rgba(15,32,24,0.5) 40%,
      rgba(15,32,24,0.15) 70%,
      transparent 100%
    );
    transition: background 0.4s;
  }
  .hi-exp-card:hover .hi-exp-card__overlay {
    background: linear-gradient(
      to top,
      rgba(15,32,24,0.95) 0%,
      rgba(15,32,24,0.6) 50%,
      rgba(15,32,24,0.2) 75%,
      transparent 100%
    );
  }

  .hi-exp-card__body {
    position: absolute; bottom: 0; left: 0; right: 0; z-index: 2;
    padding: var(--s-7) var(--s-6);
    display: flex; flex-direction: column; gap: var(--s-4);
  }
  .hi-exp-card__text { display: grid; gap: var(--s-3); }
  .hi-exp-card__title {
    font-family: var(--f-display); font-style: italic;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 400; color: var(--hi-white); line-height: 1.1;
  }
  .hi-exp-card__desc {
    font-family: var(--f-body); font-size: 0.875rem;
    font-weight: 300; line-height: 1.8; color: rgba(255,255,255,0.7);
    max-width: 28rem;
    max-height: 0; overflow: hidden;
    transition: max-height 0.4s ease, opacity 0.4s ease;
    opacity: 0;
  }
  .hi-exp-card:hover .hi-exp-card__desc {
    max-height: 8rem; opacity: 1;
  }
  .hi-exp-card__link {
    display: inline-flex; align-items: center; gap: var(--s-2);
    font-family: var(--f-body); font-size: 0.5rem;
    font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--hi-gold);
    border-bottom: 1px solid rgba(200,164,90,0.35);
    padding-bottom: 2px; align-self: flex-start;
    transition: gap 0.2s, border-color 0.2s;
  }
  .hi-exp-card__link:hover { gap: var(--s-3); border-color: var(--hi-gold); }

  [data-anim="hi-exp-head"], [data-anim="hi-exp-grid"] { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    [data-anim="hi-exp-head"], [data-anim="hi-exp-grid"] { opacity: 1 !important; }
    .hi-exp-card__desc { max-height: none; opacity: 1; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.set('[data-anim="hi-exp-head"]', { y: 24 });
    gsap.set('[data-anim="hi-exp-grid"]', { y: 28 });
    gsap.to('[data-anim="hi-exp-head"]', { opacity: 1, y: 0, duration: 0.9, scrollTrigger: { trigger: '.hi-exp__head', start: 'top 85%' } });
    gsap.to('[data-anim="hi-exp-grid"]', { opacity: 1, y: 0, duration: 1.0, scrollTrigger: { trigger: '.hi-exp__grid', start: 'top 82%' } });
  });
</script>
