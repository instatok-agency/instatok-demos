const services = [
  { icon: svgCar,   title: 'Airport Transfer',    desc: 'Μεταφορά από αεροδρόμιο Κεφαλονιάς με ιδιωτικό όχημα' },
  { icon: svgStar,  title: 'Concierge Service',   desc: 'Προσωπικός concierge 24/7 για κάθε ανάγκη σας' },
  { icon: svgWifi,  title: 'WiFi & Internet',      desc: 'Υψηλής ταχύτητας ασύρματο δίκτυο σε όλους τους χώρους' },
  { icon: svgFood,  title: 'Breakfast in Bed',     desc: 'Πρωινό σερβιρισμένο στο δωμάτιό σας κάθε πρωί' },
  { icon: svgWaves, title: 'Private Beach',        desc: 'Αποκλειστική πρόσβαση σε ιδιωτική αμμώδη παραλία' },
