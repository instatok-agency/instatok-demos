---

<section class="hi-amen" id="amenities" aria-label="Υπηρεσίες">
  <div class="hi-amen__inner hi-inner">

    <div class="hi-amen__head" data-anim="hi-amen-head">
      <p class="hi-eyebrow">Υπηρεσίες</p>
      <h2 class="hi-sec-title">Discover the Services<br/>we Offered</h2>
      <p class="hi-amen__sub">Όλα τα απαραίτητα για μια άνετη και αξέχαστη διαμονή.</p>
    </div>

    <div class="hi-amen__grid" data-anim="hi-amen-grid">
      {services.map(s => (
        <div class="hi-amen-card">
          <div class="hi-amen-card__icon" aria-hidden="true" set:html={s.icon}></div>
          <h3 class="hi-amen-card__title">{s.title}</h3>
          <p class="hi-amen-card__desc">{s.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .hi-amen { background: var(--hi-cream); padding-block: var(--s-9); }
  .hi-amen__inner { display: grid; gap: var(--s-8); }

  .hi-amen__head { display: grid; gap: var(--s-4); max-width: 44rem; }
  .hi-amen__sub {
    font-family: var(--f-body); font-size: 0.9375rem;
    font-weight: 300; line-height: 1.8; color: var(--hi-muted);
  }

  /* GRID — 3 columns on desktop, 2 on tablet, 1 on mobile */
  .hi-amen__grid {
    display: grid; gap: var(--s-5);
    grid-template-columns: repeat(3, 1fr);
  }
  @media (max-width: 900px) { .hi-amen__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .hi-amen__grid { grid-template-columns: 1fr; } }

  /* CARD */
  .hi-amen-card {
    background: var(--hi-white);
    border: 1px solid var(--hi-border);
    border-radius: var(--r-lg);
    padding: var(--s-6);
    display: grid; gap: var(--s-4); align-content: start;
    transition: box-shadow 0.25s, transform 0.25s;
  }
  .hi-amen-card:hover {
    box-shadow: 0 8px 32px rgba(30,59,44,0.08);
    transform: translateY(-3px);
  }

  .hi-amen-card__icon {
    display: flex; align-items: center; justify-content: center;
    width: 3.5rem; height: 3.5rem;
    background: rgba(30,59,44,0.06); border-radius: var(--r-md);
    color: var(--hi-forest);
  }

  .hi-amen-card__title {
    font-family: var(--f-display); font-style: italic;
    font-size: 1.25rem; font-weight: 400; color: var(--hi-forest);
    line-height: 1.2;
  }
  .hi-amen-card__desc {
    font-family: var(--f-body); font-size: 0.875rem;
    font-weight: 300; line-height: 1.75; color: var(--hi-muted);
  }

  [data-anim="hi-amen-head"], [data-anim="hi-amen-grid"] { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    [data-anim="hi-amen-head"], [data-anim="hi-amen-grid"] { opacity: 1 !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.set('[data-anim="hi-amen-head"]', { y: 24 });
    gsap.set('[data-anim="hi-amen-grid"]', { y: 28 });
    gsap.to('[data-anim="hi-amen-head"]', { opacity: 1, y: 0, duration: 0.9, scrollTrigger: { trigger: '.hi-amen__head', start: 'top 85%' } });
    gsap.to('[data-anim="hi-amen-grid"]', { opacity: 1, y: 0, duration: 1.0, scrollTrigger: { trigger: '.hi-amen__grid', start: 'top 82%' } });
  });
</script>
