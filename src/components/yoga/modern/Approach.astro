---
const pillars = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    label: 'Προσαρμογή',
    title: 'Κάθε σώμα είναι διαφορετικό',
    body: 'Τα μαθήματά μας προσαρμόζονται στο επίπεδο και τους στόχους κάθε μαθητή — αρχάριοι και έμπειροι μαζί.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    label: 'Πιστοποίηση',
    title: 'Εκπαίδευση που μετράει',
    body: 'RYT-500 πιστοποιημένοι εκπαιδευτές, εξειδικευμένοι στην ανατομία κίνησης και στη θεραπευτική yoga.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    label: 'Αποτέλεσμα',
    title: 'Πρόοδος που βλέπεις',
    body: 'Παρακολουθούμε την εξέλιξη κάθε μαθητή. Ρεαλιστικοί στόχοι, μετρήσιμη βελτίωση κάθε μήνα.',
  },
];
---

<section class="approach" aria-label="Η προσέγγισή μας">
  <hr class="section-rule" aria-hidden="true" />

  <div class="approach__inner modern-section-inner">

    <div class="approach__head">
      <p class="eyebrow eyebrow--mint" data-anim="approach-label">Η προσέγγισή μας</p>
      <h2 class="approach__title" data-anim="approach-title">
        Yoga που λειτουργεί<br/>για εσένα.
      </h2>
    </div>

    <div class="approach__grid">
      {pillars.map((p, i) => (
        <div class="approach__card" data-anim="approach-card" style={`transition-delay: ${i * 0.08}s`}>
          <div class="approach__icon" aria-hidden="true">
            <Fragment set:html={p.icon} />
          </div>
          <span class="eyebrow approach__card-label">{p.label}</span>
          <h3 class="approach__card-title">{p.title}</h3>
          <p class="approach__card-body">{p.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .approach {
    background: var(--c-bg);
    padding-block: var(--s-9);
  }

  .approach__inner { display: grid; gap: var(--s-8); }

  .approach__head { display: grid; gap: var(--s-4); }
  .approach__title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--c-ink);
  }

  .approach__grid {
    display: grid;
    gap: var(--s-5);
  }
  @media (min-width: 768px) {
    .approach__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .approach__card {
    padding: var(--s-6);
    background: var(--c-bg-card);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    display: grid;
    gap: var(--s-3);
    transition: border-color 0.2s;
  }
  .approach__card:hover { border-color: var(--c-mint-border); }

  .approach__icon {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--c-mint-bg);
    border-radius: var(--r-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-mint-dark);
  }
  .approach__icon svg { width: 1.25rem; height: 1.25rem; }

  .approach__card-label { color: var(--c-ink-3); }
  .approach__card-title {
    font-family: var(--f-display);
    font-weight: 600;
    font-size: 1.0625rem;
    color: var(--c-ink);
    line-height: 1.3;
  }
  .approach__card-body {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--c-ink-2);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('[data-anim="approach-label"]',
      { autoAlpha: 0, y: 12 }, {
        autoAlpha: 1, y: 0, duration: 0.55,
        scrollTrigger: { trigger: '[data-anim="approach-label"]', start: 'top 85%' }
      });
    gsap.fromTo('[data-anim="approach-title"]',
      { autoAlpha: 0, y: 18 }, {
        autoAlpha: 1, y: 0, duration: 0.65,
        scrollTrigger: { trigger: '[data-anim="approach-title"]', start: 'top 85%' }
      });
    gsap.fromTo('[data-anim="approach-card"]',
      { autoAlpha: 0, y: 20 }, {
        autoAlpha: 1, y: 0, duration: 0.6, stagger: 0.08,
        scrollTrigger: { trigger: '.approach__grid', start: 'top 80%' }
      });
  });
</script>
