---

<footer class="footer" role="contentinfo">
  <hr class="section-rule" aria-hidden="true" />

  <div class="footer__inner modern-section-inner">

    <div class="footer__grid">

      <div class="footer__brand">
        <p class="footer__name">Studio Kali</p>
        <div class="footer__pills">
          <span class="pill pill--mint">RYT-500</span>
          <span class="pill pill--outline">Κολωνάκι</span>
        </div>
        <p class="footer__tagline">Yoga + Pilates στο κέντρο της Αθήνας.</p>
      </div>

      <nav class="footer__nav" aria-label="Footer navigation">
        <p class="footer__nav-label eyebrow">Προγράμματα</p>
        <ul>
          <li><a href="#classes">Vinyasa Flow</a></li>
          <li><a href="#classes">Pilates Mat</a></li>
          <li><a href="#classes">Yin Yoga</a></li>
          <li><a href="#classes">Ιδιωτικά Μαθήματα</a></li>
        </ul>
      </nav>

      <div class="footer__contact">
        <p class="footer__nav-label eyebrow">Επικοινωνία</p>
        <a href="mailto:hello@studiokali.gr" class="footer__link">hello@studiokali.gr</a>
        <a href="tel:+302101234567" class="footer__link">210 123 4567</a>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer"
           class="footer__link footer__ig">@studiokali →</a>
      </div>

    </div>

    <div class="footer__bottom">
      <p class="eyebrow footer__copy">© {new Date().getFullYear()} Studio Kali</p>
      <p class="eyebrow footer__demo">Demo — Instatok Agency</p>
    </div>

  </div>
</footer>

<style>
  .footer {
    background: var(--c-bg);
    padding-block: 0 var(--s-7);
  }

  .footer__inner { padding-block-start: var(--s-7); }

  .footer__grid {
    display: grid;
    gap: var(--s-7);
    padding-bottom: var(--s-7);
    border-bottom: 1px solid var(--c-border);
  }
  @media (min-width: 768px) {
    .footer__grid { grid-template-columns: 1.4fr 1fr 1fr; }
  }

  .footer__name {
    font-family: var(--f-display);
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--c-ink);
    letter-spacing: -0.02em;
    margin-bottom: var(--s-3);
  }
  .footer__pills {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
    margin-bottom: var(--s-4);
  }
  .footer__tagline {
    font-size: 0.9375rem;
    color: var(--c-ink-3);
    line-height: 1.6;
  }

  .footer__nav-label {
    color: var(--c-ink-3);
    margin-bottom: var(--s-4);
  }
  .footer__nav ul {
    list-style: none;
    display: grid;
    gap: var(--s-3);
  }
  .footer__nav a {
    font-size: 0.9375rem;
    color: var(--c-ink-2);
    transition: color 0.18s;
  }
  .footer__nav a:hover { color: var(--c-mint-dark); }

  .footer__contact {
    display: grid;
    gap: var(--s-3);
    align-content: start;
  }
  .footer__link {
    font-size: 0.9375rem;
    color: var(--c-ink-2);
    transition: color 0.18s;
  }
  .footer__link:hover { color: var(--c-mint-dark); }
  .footer__ig { font-weight: 500; }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s-3);
    padding-top: var(--s-5);
    color: var(--c-ink-3);
  }
</style>
