---
---

<section class="about" id="about" aria-labelledby="about-heading">
  <hr class="section-rule about__rule" aria-hidden="true" />

  <div class="about__inner yoga-section-inner">

    <header class="about__header">
      <p class="eyebrow about__eyebrow" data-anim="reveal">Ποια είμαι</p>
      <h2 class="about__heading" id="about-heading" data-anim="reveal">
        Γιατί διδάσκω<br />yoga εδώ και 12 χρόνια
      </h2>
    </header>

    <div class="about__body">

      <div class="about__text">
        <p class="about__para" data-anim="reveal">
          Ξεκίνησα yoga σε μια δύσκολη περίοδο — δεν έψαχνα ευελιξία ή fitness.
          Έψαχνα έναν τρόπο να ξαναβρώ τον εαυτό μου μέσα από τη μέρα μου.
          Δώδεκα χρόνια μετά, αυτό διδάσκω: όχι ακροβατισμούς, αλλά
          πώς το σώμα μπορεί να γίνει σύμμαχος αντί για πηγή stress.
        </p>
        <p class="about__para" data-anim="reveal">
          Εξειδικεύομαι σε vinyasa flow και restorative yoga — δύο πρακτικές
          που δείχνουν εντελώς διαφορετικές αλλά απαντούν στην ίδια ανάγκη:
          να επιστρέψεις στον εαυτό σου μέσα σε έναν κόσμο που τραβάει προς
          τα έξω.
        </p>

        <ul class="about__approach" data-anim="list" aria-label="Προσέγγισή μου">
          <li>
            <span class="about__approach-label">Δεν διδάσκω «τέλεια» στάση</span>
            <span class="about__approach-sep" aria-hidden="true">→</span>
            <span class="about__approach-value">Διδάσκω αίσθηση</span>
          </li>
          <li>
            <span class="about__approach-label">Δεν ζητώ να ανταγωνιστείς κανέναν</span>
            <span class="about__approach-sep" aria-hidden="true">→</span>
            <span class="about__approach-value">Ζητώ να ακούς</span>
          </li>
          <li>
            <span class="about__approach-label">Δεν υπόσχομαι «transformation»</span>
            <span class="about__approach-sep" aria-hidden="true">→</span>
            <span class="about__approach-value">Υπόσχομαι παρουσία</span>
          </li>
        </ul>

        <ul class="about__creds eyebrow" data-anim="reveal" aria-label="Πιστοποιήσεις">
          <li>RYT-500 · Yoga Alliance</li>
          <li>Restorative Yoga Teacher Training</li>
          <li>Somatic Experiencing® Fundamentals</li>
          <li>12 χρόνια διδακτικής εμπειρίας</li>
        </ul>
      </div>

      <figure class="about__figure" data-anim="photo" aria-label="Έλενα Παπαδάκη">
        <div class="about__frame">
          <img
            src="https://images.unsplash.com/photo-1518611012118-696072aa579a?w=600&q=80&fit=crop&crop=top"
            alt="Έλενα Παπαδάκη, Δασκάλα Yoga"
            class="about__photo"
            loading="lazy"
            width="600"
            height="780"
          />
        </div>
        <figcaption class="about__figcaption eyebrow">
          Έλενα Παπαδάκη<br />
          <em>RYT-500 · Παγκράτι, Αθήνα</em>
        </figcaption>
      </figure>

    </div>
  </div>
</section>

<style>
  .about {
    background: var(--c-bg);
    padding-block: 0 var(--s-9);
  }
  .about__rule { margin-bottom: 0; }
  .about__inner { padding-block-start: var(--s-7); }

  .about__header { margin-bottom: var(--s-7); }
  .about__eyebrow { margin-bottom: var(--s-3); }
  .about__heading {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .about__body { display: grid; gap: var(--s-7); }

  .about__para {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--c-ink-2);
    max-width: 55ch;
  }
  .about__para + .about__para { margin-top: var(--s-4); }

  .about__approach {
    list-style: none;
    margin-top: var(--s-6);
    padding-top: var(--s-5);
    border-top: 1px solid var(--c-border);
    display: grid;
    gap: var(--s-3);
  }
  .about__approach li {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.9375rem;
  }
  .about__approach-label {
    color: var(--c-ink-3);
    font-style: italic;
    font-family: var(--f-display);
  }
  .about__approach-sep {
    color: var(--c-clay);
    font-family: var(--f-mono);
    font-size: 0.75rem;
  }
  .about__approach-value { color: var(--c-ink); font-weight: 500; }

  .about__creds {
    list-style: none;
    margin-top: var(--s-6);
    padding-top: var(--s-4);
    border-top: 1px solid var(--c-border);
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2) var(--s-5);
  }
  .about__creds li { position: relative; }
  .about__creds li + li::before {
    content: "·";
    position: absolute;
    left: calc(var(--s-5) * -1 - 0.3ch);
    color: var(--c-clay);
  }

  .about__figure { display: grid; gap: var(--s-3); }
  .about__frame {
    border: 1px solid var(--c-border);
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }
  .about__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    filter: sepia(8%) contrast(1.03);
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .about__frame:hover .about__photo { transform: scale(1.02); }
  .about__figcaption { color: var(--c-ink-3); line-height: 1.5; }
  .about__figcaption em {
    font-family: var(--f-display);
    font-style: italic;
    font-size: 0.75rem;
    color: var(--c-ink-2);
  }

  @media (min-width: 1024px) {
    .about__body { grid-template-columns: 1fr 320px; align-items: start; }
    .about__frame { aspect-ratio: auto; height: 500px; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('.about__rule',
      { scaleX: 0 },
      { scaleX: 1, duration: 1.2, ease: 'power3.out',
        scrollTrigger: { trigger: '.about', start: 'top 90%' } });

    gsap.utils.toArray<HTMLElement>('.about [data-anim="reveal"]').forEach(el => {
      gsap.fromTo(el,
        { autoAlpha: 0, y: 22 },
        { autoAlpha: 1, y: 0, duration: 0.85,
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
    });

    gsap.utils.toArray<HTMLElement>('.about__approach li').forEach((el, i) => {
      gsap.fromTo(el,
        { autoAlpha: 0, y: 14 },
        { autoAlpha: 1, y: 0, duration: 0.65, delay: i * 0.09,
          scrollTrigger: { trigger: el, start: 'top 90%', toggleActions: 'play none none none' } });
    });

    gsap.fromTo('.about__frame',
      { autoAlpha: 0, scale: 1.04 },
      { autoAlpha: 1, scale: 1, duration: 1.1, ease: 'power2.out',
        scrollTrigger: { trigger: '.about__figure', start: 'top 85%' } });
  });
</script>
