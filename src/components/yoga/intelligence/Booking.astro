---
---

<section class="booking" id="booking" aria-labelledby="booking-heading">
  <hr class="section-rule booking__rule" aria-hidden="true" />

  <div class="booking__inner yoga-section-inner">

    <div class="booking__grid">

      <div class="booking__info">
        <p class="eyebrow booking__eyebrow" data-anim="reveal">Κράτηση</p>
        <h2 class="booking__heading" id="booking-heading" data-anim="reveal">
          Ξεκίνα<br />την εβδομάδα σου
        </h2>
        <p class="booking__lead" data-anim="reveal">
          Μπορείς να κλείσεις θέση online ή να επικοινωνήσεις απευθείας.
          Η πρώτη σου φορά δεν απαιτεί εμπειρία — μόνο ανοιχτό μυαλό.
        </p>

        <address class="booking__contact" data-anim="reveal">
          <a href="tel:+302101234567" class="booking__contact-item">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="16" height="16">
              <path d="M2 5a2 2 0 012-2h2.28a1 1 0 01.95.68l1.1 3.3a1 1 0 01-.23 1.02L6.91 9.23a11 11 0 005.86 5.86l1.24-1.24a1 1 0 011.02-.23l3.3 1.1A1 1 0 0119 15.72V18a2 2 0 01-2 2H15a13 13 0 01-13-13V5z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>+30 210 123 4567</span>
          </a>
          <a href="mailto:elena@yoga-papadaki.gr" class="booking__contact-item">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="16" height="16">
              <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
            </svg>
            <span>elena@yoga-papadaki.gr</span>
          </a>
          <div class="booking__contact-item">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="16" height="16">
              <path d="M10 2C6.686 2 4 4.686 4 8c0 5.25 6 10 6 10s6-4.75 6-10c0-3.314-2.686-6-6-6zm0 8a2 2 0 110-4 2 2 0 010 4z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Υμηττού 42, Παγκράτι · Αθήνα</span>
          </div>
        </address>
      </div>

      <form class="booking__form" action="#" method="post" novalidate data-anim="form">
        <div class="booking__field">
          <label class="booking__label eyebrow" for="name">Ονοματεπώνυμο <span aria-hidden="true">*</span></label>
          <input class="booking__input" type="text" id="name" name="name" required autocomplete="name" placeholder="Π.χ. Μαρία Κωνσταντίνου" />
        </div>

        <div class="booking__field">
          <label class="booking__label eyebrow" for="email">Email <span aria-hidden="true">*</span></label>
          <input class="booking__input" type="email" id="email" name="email" required autocomplete="email" placeholder="maria@email.com" />
        </div>

        <div class="booking__field">
          <label class="booking__label eyebrow" for="class-type">Τύπος μαθήματος</label>
          <select class="booking__input booking__select" id="class-type" name="class-type">
            <option value="">Επέλεξε...</option>
            <option value="vinyasa">Vinyasa Flow</option>
            <option value="restorative">Restorative Yoga</option>
            <option value="private">Ιδιωτικό μάθημα</option>
          </select>
        </div>

        <div class="booking__field">
          <label class="booking__label eyebrow" for="message">Μήνυμα <span class="booking__optional">(προαιρετικό)</span></label>
          <textarea class="booking__input booking__textarea" id="message" name="message" rows="4" placeholder="Πείτε μου κάτι για σένα — επίπεδο εμπειρίας, οτιδήποτε να ξέρω..."></textarea>
        </div>

        <button type="submit" class="booking__submit">
          <span>Αποστολή αίτησης</span>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="16" height="16">
            <path d="M4 10h12M11 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <p class="booking__disclaimer eyebrow">
          Θα επικοινωνήσω εντός 24 ωρών για επιβεβαίωση.
        </p>
      </form>

    </div>
  </div>
</section>

<style>
  .booking {
    background: var(--c-bg);
    padding-block: 0 var(--s-9);
  }
  .booking__rule { margin-bottom: 0; }
  .booking__inner { padding-block-start: var(--s-7); }

  .booking__grid { display: grid; gap: var(--s-8); }

  .booking__eyebrow { margin-bottom: var(--s-3); }
  .booking__heading {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--s-5);
  }
  .booking__lead {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--c-ink-2);
    max-width: 44ch;
    margin-bottom: var(--s-6);
  }

  .booking__contact {
    display: grid;
    gap: var(--s-3);
    font-style: normal;
  }
  .booking__contact-item {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    font-size: 0.9375rem;
    color: var(--c-ink-2);
    transition: color 0.2s;
  }
  .booking__contact-item svg { color: var(--c-clay); flex-shrink: 0; }
  a.booking__contact-item:hover { color: var(--c-ink); }

  .booking__form { display: grid; gap: var(--s-4); }
  .booking__field { display: grid; gap: var(--s-2); }
  .booking__label { color: var(--c-ink-2); }
  .booking__label span[aria-hidden] { color: var(--c-clay); margin-left: 2px; }
  .booking__optional { font-style: normal; color: var(--c-ink-3); }

  .booking__input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--c-border);
    background: var(--c-bg);
    color: var(--c-ink);
    font-family: var(--f-body);
    font-size: 0.9375rem;
    transition: border-color 0.2s;
    -webkit-appearance: none;
    appearance: none;
  }
  .booking__input:focus {
    outline: none;
    border-color: var(--c-clay);
  }
  .booking__input::placeholder { color: var(--c-ink-3); }
  .booking__textarea { resize: vertical; min-height: 7rem; }
  .booking__select { cursor: pointer; }

  .booking__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--s-3);
    padding: 0.875rem 1.75rem;
    background: var(--c-ink);
    color: var(--c-bg);
    border: 1px solid var(--c-ink);
    font-family: var(--f-body);
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .booking__submit:hover {
    background: var(--c-clay);
    border-color: var(--c-clay);
  }

  .booking__disclaimer { margin-top: var(--s-2); }

  @media (min-width: 1024px) {
    .booking__grid { grid-template-columns: 1fr 1fr; align-items: start; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('.booking__rule',
      { scaleX: 0 },
      { scaleX: 1, duration: 1.2, ease: 'power3.out',
        scrollTrigger: { trigger: '.booking', start: 'top 90%' } });

    gsap.utils.toArray<HTMLElement>('.booking [data-anim="reveal"]').forEach(el => {
      gsap.fromTo(el,
        { autoAlpha: 0, y: 18 },
        { autoAlpha: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
    });

    gsap.fromTo('[data-anim="form"]',
      { autoAlpha: 0, y: 28 },
      { autoAlpha: 1, y: 0, duration: 0.9,
        scrollTrigger: { trigger: '[data-anim="form"]', start: 'top 85%', toggleActions: 'play none none none' } });
  });
</script>
