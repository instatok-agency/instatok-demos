---
const classes = [
  {
    num: '01',
    title: 'Vinyasa Flow',
    subtitle: 'Κίνηση που ακολουθεί την ανάσα',
    description: 'Δυναμική πρακτική όπου κάθε κίνηση γεννιέται από την εκπνοή ή την εισπνοή. Χτίζει δύναμη, εστίαση και ρυθμό χωρίς να γίνεται γυμναστήριο.',
    details: ['60 λεπτά', 'Όλα τα επίπεδα', 'Max 10 άτομα'],
    photo: 'https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=700&q=80&fit=crop',
    tag: 'Δημοφιλές',
  },
  {
    num: '02',
    title: 'Restorative Yoga',
    subtitle: 'Αποκατάσταση για το νευρικό σύστημα',
    description: 'Παθητικές στάσεις με props, κρατημένες για 5–10 λεπτά. Το παρασυμπαθητικό νευρικό σύστημα επανέρχεται. Ιδανικό για burnout, stress και αϋπνία.',
    details: ['75 λεπτά', 'Όλα τα επίπεδα', 'Max 8 άτομα'],
    photo: 'https://images.unsplash.com/photo-1599901860904-17e6ed7083a0?w=700&q=80&fit=crop',
    tag: 'Συνιστάται',
  },
  {
    num: '03',
    title: 'Ιδιωτικά Μαθήματα',
    subtitle: 'Εξατομικευμένη πρακτική',
    description: 'Ένα μάθημα σχεδιασμένο αποκλειστικά για σένα. Για συγκεκριμένο τραύμα, περιορισμό ή ανάγκη — ή απλά αν προτιμάς να δουλεύεις μόνος σου.',
    details: ['60–90 λεπτά', 'Όλα τα επίπεδα', '1:1 session'],
    photo: 'https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=700&q=80&fit=crop',
    tag: null,
  },
];
---

<section class="classes" id="classes" aria-labelledby="classes-heading">
  <hr class="section-rule classes__rule" aria-hidden="true" />

  <div class="classes__inner yoga-section-inner">

    <header class="classes__header">
      <p class="eyebrow" data-anim="reveal">Τάξεις</p>
      <h2 class="classes__heading" id="classes-heading" data-anim="reveal">
        Τρεις τρόποι<br />να εξασκείσαι
      </h2>
    </header>

    <div class="classes__grid" role="list">
      {classes.map(cls => (
        <article class="class-card" role="listitem" data-anim="card">
          <div class="class-card__image">
            <img
              src={cls.photo}
              alt=""
              loading="lazy"
              width="700"
              height="420"
            />
            {cls.tag && <span class="class-card__tag">{cls.tag}</span>}
          </div>
          <div class="class-card__body">
            <div class="class-card__header">
              <span class="class-card__num eyebrow">{cls.num}</span>
              <div>
                <h3 class="class-card__title">{cls.title}</h3>
                <p class="class-card__subtitle eyebrow">{cls.subtitle}</p>
              </div>
            </div>
            <p class="class-card__desc">{cls.description}</p>
            <ul class="class-card__details" aria-label="Λεπτομέρειες μαθήματος">
              {cls.details.map(d => (
                <li class="class-card__detail eyebrow">{d}</li>
              ))}
            </ul>
            <a href="#booking" class="class-card__cta">
              Κράτηση θέσης →
            </a>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .classes {
    background: var(--c-bg-2);
    padding-block: 0 var(--s-9);
  }
  .classes__rule { margin-bottom: 0; }
  .classes__inner { padding-block-start: var(--s-7); }

  .classes__header { margin-bottom: var(--s-7); }
  .classes__header .eyebrow { margin-bottom: var(--s-3); }
  .classes__heading {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .classes__grid {
    display: grid;
    gap: 1px;
    background: var(--c-border);
    border: 1px solid var(--c-border);
  }

  .class-card { background: var(--c-bg); display: grid; }
  .class-card__image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .class-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(10%) contrast(1.03);
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .class-card:hover .class-card__image img { transform: scale(1.03); }
  .class-card__tag {
    position: absolute;
    top: var(--s-4);
    left: var(--s-4);
    font-family: var(--f-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-bg);
    background: var(--c-clay);
    padding: 0.25rem 0.6rem;
  }

  .class-card__body {
    padding: var(--s-5) var(--s-5) var(--s-6);
    display: grid;
    gap: var(--s-4);
  }
  .class-card__header {
    display: flex;
    align-items: flex-start;
    gap: var(--s-4);
  }
  .class-card__num { color: var(--c-clay); flex-shrink: 0; padding-top: 0.25rem; }
  .class-card__title {
    font-family: var(--f-display);
    font-weight: 500;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }
  .class-card__subtitle { color: var(--c-clay); }
  .class-card__desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--c-ink-2);
  }

  .class-card__details {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2) var(--s-4);
    padding-top: var(--s-3);
    border-top: 1px solid var(--c-border);
  }
  .class-card__detail { color: var(--c-ink-2); }
  .class-card__detail + .class-card__detail { position: relative; padding-left: var(--s-4); }
  .class-card__detail + .class-card__detail::before {
    content: "·";
    position: absolute;
    left: calc(var(--s-4) / 2 - 0.3ch);
    color: var(--c-clay);
  }

  .class-card__cta {
    display: inline-flex;
    font-family: var(--f-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-clay);
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.125rem;
    width: fit-content;
    transition: color 0.2s;
  }
  .class-card__cta:hover { color: var(--c-clay-deep); }

  @media (min-width: 768px) {
    .classes__grid { grid-template-columns: repeat(3, 1fr); }
    .class-card { grid-template-rows: auto 1fr; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('.classes__rule',
      { scaleX: 0 },
      { scaleX: 1, duration: 1.2, ease: 'power3.out',
        scrollTrigger: { trigger: '.classes', start: 'top 90%' } });

    gsap.utils.toArray<HTMLElement>('.classes [data-anim="reveal"]').forEach(el => {
      gsap.fromTo(el,
        { autoAlpha: 0, y: 20 },
        { autoAlpha: 1, y: 0, duration: 0.85,
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
    });

    gsap.utils.toArray<HTMLElement>('.class-card').forEach((el, i) => {
      gsap.fromTo(el,
        { autoAlpha: 0, y: 28 },
        { autoAlpha: 1, y: 0, duration: 0.8, delay: i * 0.1,
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
    });
  });
</script>
