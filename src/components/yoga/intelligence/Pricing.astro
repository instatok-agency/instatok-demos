---
const plans = [
  {
    title: 'Μεμονωμένο',
    price: '€15',
    period: 'ανά μάθημα',
    desc: 'Ιδανικό αν θέλεις να δοκιμάσεις ή να έρθεις όταν μπορείς.',
    includes: ['Ένα μάθημα επιλογής σου', 'Χωρίς δέσμευση', 'Κράτηση online ή τηλεφωνικά'],
    cta: 'Κλείσε μάθημα',
    highlight: false,
  },
  {
    title: 'Μηνιαία Κάρτα',
    price: '€120',
    period: 'ανά μήνα',
    desc: 'Αδιόριστες θέσεις στο μηνιαίο πρόγραμμα — η πιο αποδοτική επιλογή.',
    includes: ['Αδιόριστα ομαδικά μαθήματα', 'Προτεραιότητα στο πρόγραμμα', 'Pause έναν μήνα αν απουσιάσεις'],
    cta: 'Ξεκίνα σήμερα',
    highlight: true,
  },
  {
    title: 'Ιδιωτικό',
    price: 'Επικοινωνία',
    period: 'κατόπιν συνεννόησης',
    desc: 'Εξατομικευμένη πρακτική — τιμή ανάλογα με συχνότητα και διάρκεια.',
    includes: ['1:1 session στο studio ή online', 'Πρόγραμμα σχεδιασμένο για σένα', 'Ευελιξία ωραρίου'],
    cta: 'Επικοινωνία',
    highlight: false,
  },
];
---

<section class="pricing" id="pricing" aria-labelledby="pricing-heading">
  <hr class="section-rule pricing__rule" aria-hidden="true" />

  <div class="pricing__inner yoga-section-inner">

    <header class="pricing__header">
      <p class="eyebrow" data-anim="reveal">Τιμές</p>
      <h2 class="pricing__heading" id="pricing-heading" data-anim="reveal">
        Απλά, διαφανή
      </h2>
    </header>

    <div class="pricing__grid" role="list">
      {plans.map(plan => (
        <article class={`pricing-card ${plan.highlight ? 'pricing-card--highlight' : ''}`} role="listitem" data-anim="card">
          <div class="pricing-card__top">
            <h3 class="pricing-card__title">{plan.title}</h3>
            <div class="pricing-card__price-row">
              <span class="pricing-card__price">{plan.price}</span>
              <span class="pricing-card__period eyebrow">{plan.period}</span>
            </div>
            <p class="pricing-card__desc">{plan.desc}</p>
          </div>
          <ul class="pricing-card__includes" aria-label="Περιλαμβάνει">
            {plan.includes.map(item => (
              <li>
                <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" width="12" height="12">
                  <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="#booking" class={`pricing-card__cta ${plan.highlight ? 'pricing-card__cta--fill' : ''}`}>
            {plan.cta}
          </a>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .pricing {
    background: var(--c-bg-2);
    padding-block: 0 var(--s-9);
  }
  .pricing__rule { margin-bottom: 0; }
  .pricing__inner { padding-block-start: var(--s-7); }

  .pricing__header { margin-bottom: var(--s-7); }
  .pricing__header .eyebrow { margin-bottom: var(--s-3); }
  .pricing__heading {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .pricing__grid {
    display: grid;
    gap: 1px;
    background: var(--c-border);
    border: 1px solid var(--c-border);
  }

  .pricing-card {
    background: var(--c-bg);
    padding: var(--s-6);
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
  }
  .pricing-card--highlight {
    background: var(--c-ink);
    color: var(--c-bg);
  }

  .pricing-card__top { display: grid; gap: var(--s-3); }
  .pricing-card__title {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 1.1rem;
    letter-spacing: -0.01em;
  }
  .pricing-card__price-row { display: flex; align-items: baseline; gap: var(--s-2); }
  .pricing-card__price {
    font-family: var(--f-display);
    font-size: 2.5rem;
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .pricing-card__period {
    color: var(--c-ink-3);
  }
  .pricing-card--highlight .pricing-card__period {
    color: rgba(247, 244, 240, 0.5);
  }
  .pricing-card__desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--c-ink-2);
  }
  .pricing-card--highlight .pricing-card__desc { color: rgba(247, 244, 240, 0.7); }

  .pricing-card__includes {
    list-style: none;
    display: grid;
    gap: var(--s-2);
    padding-top: var(--s-4);
    border-top: 1px solid var(--c-rule);
    flex: 1;
  }
  .pricing-card--highlight .pricing-card__includes {
    border-top-color: rgba(247, 244, 240, 0.15);
  }
  .pricing-card__includes li {
    display: flex;
    align-items: flex-start;
    gap: var(--s-3);
    font-size: 0.9rem;
    color: var(--c-ink-2);
  }
  .pricing-card--highlight .pricing-card__includes li { color: rgba(247, 244, 240, 0.8); }
  .pricing-card__includes li svg {
    flex-shrink: 0;
    margin-top: 0.2rem;
    color: var(--c-clay);
  }
  .pricing-card--highlight .pricing-card__includes li svg { color: var(--c-clay); }

  .pricing-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    border: 1px solid var(--c-border);
    background: transparent;
    color: var(--c-ink);
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    text-align: center;
  }
  .pricing-card__cta:hover { border-color: var(--c-ink); }
  .pricing-card__cta--fill {
    background: var(--c-clay);
    border-color: var(--c-clay);
    color: #fff;
  }
  .pricing-card__cta--fill:hover {
    background: var(--c-clay-deep);
    border-color: var(--c-clay-deep);
  }

  @media (min-width: 768px) {
    .pricing__grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('.pricing__rule',
      { scaleX: 0 },
      { scaleX: 1, duration: 1.2, ease: 'power3.out',
        scrollTrigger: { trigger: '.pricing', start: 'top 90%' } });

    gsap.utils.toArray<HTMLElement>('.pricing [data-anim="reveal"]').forEach(el => {
      gsap.fromTo(el,
        { autoAlpha: 0, y: 18 },
        { autoAlpha: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
    });

    gsap.utils.toArray<HTMLElement>('.pricing-card').forEach((el, i) => {
      gsap.fromTo(el,
        { autoAlpha: 0, y: 28 },
        { autoAlpha: 1, y: 0, duration: 0.75, delay: i * 0.1,
          scrollTrigger: { trigger: '.pricing__grid', start: 'top 85%', toggleActions: 'play none none none' } });
    });
  });
</script>
