---
---

<footer class="footer" role="contentinfo">
  <hr class="section-rule section-rule--deep" aria-hidden="true" />

  <div class="footer__inner retreat-section-inner">

    <div class="footer__grid">

      <div class="footer__brand">
        <p class="footer__name">Έλενα Παπαδάκη</p>
        <p class="footer__cred eyebrow-dark">Yoga Teacher · RYT-500</p>
        <p class="footer__location eyebrow-dark">Παγκράτι · Αθήνα · Online</p>
      </div>

      <nav class="footer__nav" aria-label="Footer navigation">
        <ul>
          <li><a href="#programs">Προγράμματα</a></li>
          <li><a href="#schedule">Πρόγραμμα</a></li>
          <li><a href="#pricing">Τιμές</a></li>
          <li><a href="#booking">Επικοινωνία</a></li>
        </ul>
      </nav>

      <div class="footer__contact">
        <p class="eyebrow-dark footer__contact-label">Επικοινωνία</p>
        <a href="mailto:elena@papadaki.yoga" class="footer__link">elena@papadaki.yoga</a>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer"
           class="footer__link footer__insta eyebrow-dark">Instagram →</a>
      </div>

    </div>

    <div class="footer__bottom">
      <p class="eyebrow-dark footer__copy">© {new Date().getFullYear()} Έλενα Παπαδάκη · Yoga Teacher</p>
      <p class="eyebrow-dark footer__demo">Demo — Instatok Agency</p>
    </div>

  </div>
</footer>

<style>
  .footer { background: var(--c-deep); padding-block: 0 var(--s-6); }
  .footer > .section-rule--deep { background: var(--c-deep-border); margin-bottom: 0; }
  .footer__inner { padding-block-start: var(--s-7); }

  .footer__grid {
    display: grid;
    gap: var(--s-7);
    padding-bottom: var(--s-7);
    border-bottom: 1px solid var(--c-deep-border);
  }
  @media (min-width: 768px) { .footer__grid { grid-template-columns: 1fr 1fr 1fr; } }

  .footer__name {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    color: var(--c-on-deep);
    margin-bottom: var(--s-2);
  }
  .footer__cred { color: var(--c-gold); margin-bottom: var(--s-1); }
  .footer__location { color: var(--c-on-deep-3); }

  .footer__nav ul { list-style: none; display: grid; gap: var(--s-2); }
  .footer__nav a {
    font-family: var(--f-body);
    font-size: 0.9375rem;
    color: var(--c-on-deep-2);
    transition: color 0.18s;
  }
  .footer__nav a:hover { color: var(--c-gold); }

  .footer__contact { display: grid; gap: var(--s-2); }
  .footer__contact-label { margin-bottom: var(--s-1); }
  .footer__link {
    font-size: 0.9375rem;
    color: var(--c-on-deep-2);
    transition: color 0.18s;
  }
  .footer__link:hover { color: var(--c-gold); }
  .footer__insta { margin-top: var(--s-2); }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s-3);
    padding-top: var(--s-5);
    color: var(--c-on-deep-3);
  }
</style>
