---
const before = [
  'Ξυπνάς χωρίς κίνητρο',
  'Δεν ξέρεις τι θέλεις',
  'Δουλεύεις πολύ αλλά νιώθεις στάσιμος',
  'Συγκρίνεις τον εαυτό σου συνέχεια με άλλους',
  'Κάθεσαι και "περιμένεις να δεις"',
];
const after = [
  'Ξυπνάς με σαφήνεια για την ημέρα',
  'Ξέρεις ακριβώς που πας',
  'Παίρνεις αποφάσεις χωρίς κολλήματα',
  'Ενεργείς από αυτοπεποίθηση',
  'Δημιουργείς αλλαγή αντί να την αναμένεις',
];
---

<section class="transform" aria-label="Η μετάβαση">
  <hr class="section-rule" aria-hidden="true" />
  <div class="transform__inner cm-inner">

    <div class="transform__head" data-anim="tf-head">
      <p class="eyebrow eyebrow--orange">Η διαδρομή</p>
      <h2 class="transform__title">Από πού σε πού.</h2>
    </div>

    <div class="transform__grid" data-anim="tf-grid">
      <!-- Before -->
      <div class="transform__col transform__col--before">
        <p class="transform__col-label eyebrow">Πριν</p>
        <ul class="transform__list">
          {before.map(b => (
            <li class="transform__item transform__item--before">
              <span class="transform__dot" aria-hidden="true"></span>
              {b}
            </li>
          ))}
        </ul>
      </div>

      <!-- Divider -->
      <div class="transform__divider" aria-hidden="true">
        <div class="transform__arrow">→</div>
      </div>

      <!-- After -->
      <div class="transform__col transform__col--after">
        <p class="transform__col-label eyebrow eyebrow--orange">Μετά</p>
        <ul class="transform__list">
          {after.map(a => (
            <li class="transform__item transform__item--after">
              <span class="transform__check" aria-hidden="true">✓</span>
              {a}
            </li>
          ))}
        </ul>
      </div>
    </div>

  </div>
</section>

<style>
  .transform { background: var(--c-bg-2); padding-block: var(--s-9); }
  .transform__inner { display: grid; gap: var(--s-8); }
  .transform__head { display: grid; gap: var(--s-4); }
  .transform__title {
    font-family: var(--f-display); font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.5rem);
    letter-spacing: -0.02em; color: var(--c-ink); line-height: 1.05;
  }

  .transform__grid {
    display: grid; gap: var(--s-5); align-items: center;
  }
  @media (min-width: 768px) {
    .transform__grid { grid-template-columns: 1fr auto 1fr; gap: var(--s-7); }
  }

  .transform__col { display: grid; gap: var(--s-5); }
  .transform__col-label { margin-bottom: calc(var(--s-2) * -1); }

  .transform__list { list-style: none; display: grid; gap: var(--s-3); }
  .transform__item {
    display: flex; align-items: flex-start; gap: var(--s-3);
    font-size: 0.9375rem; line-height: 1.6;
    padding: var(--s-3) var(--s-4);
    border-radius: var(--r-sm);
  }
  .transform__item--before {
    color: var(--c-ink-3);
    background: rgba(28, 23, 16, 0.04);
    text-decoration: line-through;
    text-decoration-color: var(--c-border);
  }
  .transform__item--after {
    color: var(--c-ink);
    background: var(--c-orange-bg);
    border: 1px solid var(--c-orange-border);
  }
  .transform__dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--c-ink-3); flex-shrink: 0; margin-top: 0.45rem;
  }
  .transform__check {
    color: var(--c-orange); font-size: 0.875rem;
    flex-shrink: 0; font-weight: 600; line-height: 1.6;
  }

  .transform__divider {
    display: flex; align-items: center; justify-content: center;
  }
  .transform__arrow {
    font-family: var(--f-display); font-size: 2.5rem; font-weight: 700;
    color: var(--c-orange); line-height: 1;
  }
  @media (max-width: 767px) { .transform__divider { display: none; } }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('[data-anim="tf-head"]', { autoAlpha: 0, y: 20 }, {
      autoAlpha: 1, y: 0, duration: 0.65,
      scrollTrigger: { trigger: '[data-anim="tf-head"]', start: 'top 85%' }
    });
    gsap.fromTo('[data-anim="tf-grid"]', { autoAlpha: 0, y: 28 }, {
      autoAlpha: 1, y: 0, duration: 0.75,
      scrollTrigger: { trigger: '[data-anim="tf-grid"]', start: 'top 80%' }
    });
  });
</script>
