---
const packages = [
  {
    duration: '3 Months',
    name: 'Strategic Coaching',
    price: '€1.200',
    priceNote: 'ή €420/μήνα',
    target: 'Για professionals που έχουν ήδη μια κατεύθυνση και θέλουν δομή και accountability για να την υλοποιήσουν.',
    sessions: '6 sessions × 60΄',
    includes: [
      '6 bi-weekly sessions (60 λεπτά)',
      'Discovery session (δωρεάν)',
      'Async support μεταξύ sessions',
      'Action plan per session',
    ],
    highlight: false,
  },
  {
    duration: '6 Months',
    name: 'Transition Support',
    price: '€2.800',
    priceNote: 'ή €475/μήνα',
    target: 'Για ανθρώπους σε ενεργή μετάβαση — αλλαγή ρόλου, κλάδου ή μοντέλου εργασίας. Αρκετός χρόνος για βαθύτερη δουλειά.',
    sessions: '12 sessions × 60΄',
    includes: [
      '12 bi-weekly sessions (60 λεπτά)',
      'Discovery session (δωρεάν)',
      'Async support μεταξύ sessions',
      'Career transition roadmap',
      'Mid-point review session',
    ],
    highlight: true,
  },
  {
    duration: '12 Months',
    name: 'Complete Career Transition',
    price: '€4.500',
    priceNote: 'ή €390/μήνα',
    target: 'Για όσους θέλουν πλήρη συνοδεία σε μια βαθιά μετάβαση — από εταιρικό σε ανεξάρτητο, από industry σε industry, ή από execution σε leadership.',
    sessions: '24 sessions × 60΄',
    includes: [
      '24 bi-weekly sessions (60 λεπτά)',
      'Discovery session (δωρεάν)',
      'Async support καθ\' όλη τη διάρκεια',
      'Full career transition roadmap',
      'Quarterly reviews',
      'Επιπλέον 2 emergency sessions',
    ],
    highlight: false,
  },
];
---

<section class="packages" id="packages" aria-labelledby="packages-heading">
  <hr class="section-rule" aria-hidden="true" />

  <div class="packages__inner coach-section-inner">

    <header class="packages__header">
      <p class="eyebrow">Πακέτα</p>
      <h2 class="packages__heading" id="packages-heading">
        Διαφανείς τιμές.<br />Χωρίς εκπλήξεις.
      </h2>
      <p class="packages__note">
        Όλα τα πακέτα ξεκινούν με δωρεάν discovery call — 30 λεπτά για να
        δούμε αν έχει νόημα να δουλέψουμε μαζί.
      </p>
    </header>

    <div class="packages__grid" role="list">
      {packages.map(pkg => (
        <article class={`pkg-card ${pkg.highlight ? 'pkg-card--highlight' : ''}`} role="listitem">
          <div class="pkg-card__top">
            <div class="pkg-card__duration-row">
              <span class="pkg-card__duration eyebrow">{pkg.duration}</span>
              {pkg.highlight && <span class="pkg-card__badge eyebrow">Δημοφιλές</span>}
            </div>
            <h3 class="pkg-card__name">{pkg.name}</h3>
            <div class="pkg-card__price-row">
              <span class="pkg-card__price">{pkg.price}</span>
              <span class="pkg-card__price-note eyebrow">{pkg.priceNote}</span>
            </div>
            <p class="pkg-card__sessions eyebrow">{pkg.sessions}</p>
            <p class="pkg-card__target">{pkg.target}</p>
          </div>

          <ul class="pkg-card__includes" aria-label="Περιλαμβάνει">
            {pkg.includes.map(item => (
              <li>
                <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" width="11" height="11">
                  <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <a href="#contact" class={`pkg-card__cta ${pkg.highlight ? 'pkg-card__cta--fill' : ''}`}>
            Ξεκίνα με discovery call
          </a>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .packages {
    background: var(--c-bg);
    padding-block: 0 var(--s-9);
  }
  .packages__inner { padding-block-start: var(--s-7); }

  .packages__header { margin-bottom: var(--s-7); }
  .packages__header .eyebrow { margin-bottom: var(--s-3); }
  .packages__heading {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--s-4);
  }
  .packages__note {
    font-size: 0.9375rem;
    color: var(--c-ink-2);
    line-height: 1.65;
    max-width: 52ch;
  }

  .packages__grid {
    display: grid;
    gap: 1px;
    background: var(--c-border);
    border: 1px solid var(--c-border);
  }

  .pkg-card {
    background: var(--c-bg);
    padding: var(--s-6);
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
  }
  .pkg-card--highlight {
    background: var(--c-ink);
    color: var(--c-bg);
  }

  .pkg-card__duration-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-3);
    margin-bottom: var(--s-2);
  }
  .pkg-card__duration { color: var(--c-ink-3); }
  .pkg-card--highlight .pkg-card__duration { color: rgba(250,250,249,0.5); }
  .pkg-card__badge {
    background: var(--c-amber);
    color: #fff;
    padding: 0.15rem 0.55rem;
    font-size: 0.58rem;
  }

  .pkg-card__name {
    font-family: var(--f-display);
    font-weight: 500;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    margin-bottom: var(--s-3);
  }
  .pkg-card__price-row { display: flex; align-items: baseline; gap: var(--s-2); margin-bottom: var(--s-1); }
  .pkg-card__price {
    font-family: var(--f-display);
    font-size: 2.25rem;
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .pkg-card__price-note { color: var(--c-ink-3); }
  .pkg-card--highlight .pkg-card__price-note { color: rgba(250,250,249,0.45); }
  .pkg-card__sessions { color: var(--c-amber); margin-bottom: var(--s-3); }
  .pkg-card--highlight .pkg-card__sessions { color: color-mix(in srgb, var(--c-amber) 80%, white); }
  .pkg-card__target {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--c-ink-2);
  }
  .pkg-card--highlight .pkg-card__target { color: rgba(250,250,249,0.65); }

  .pkg-card__includes {
    list-style: none;
    display: grid;
    gap: var(--s-2);
    padding-top: var(--s-4);
    border-top: 1px solid var(--c-rule);
    flex: 1;
  }
  .pkg-card--highlight .pkg-card__includes { border-top-color: rgba(250,250,249,0.12); }
  .pkg-card__includes li {
    display: flex;
    align-items: flex-start;
    gap: var(--s-3);
    font-size: 0.875rem;
    color: var(--c-ink-2);
    line-height: 1.5;
  }
  .pkg-card--highlight .pkg-card__includes li { color: rgba(250,250,249,0.75); }
  .pkg-card__includes svg { flex-shrink: 0; margin-top: 0.25rem; color: var(--c-amber); }

  .pkg-card__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    text-align: center;
    border: 1px solid var(--c-border);
    color: var(--c-ink);
    background: transparent;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .pkg-card__cta:hover { border-color: var(--c-ink); }
  .pkg-card--highlight .pkg-card__cta {
    border-color: rgba(250,250,249,0.3);
    color: var(--c-bg);
  }
  .pkg-card--highlight .pkg-card__cta:hover { border-color: var(--c-bg); }
  .pkg-card__cta--fill {
    background: var(--c-amber);
    border-color: var(--c-amber);
    color: #fff;
  }
  .pkg-card__cta--fill:hover { background: var(--c-amber-deep); border-color: var(--c-amber-deep); }

  @media (min-width: 768px) { .packages__grid { grid-template-columns: repeat(3, 1fr); } }
</style>
