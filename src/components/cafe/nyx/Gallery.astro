---
const photos = [
  { src: 'photo-1559925393-8be0ec4767c8', alt: 'Bar atmosphere', w: 800, h: 1000 },
  { src: 'photo-1470337458703-46ad1756a187', alt: 'Cocktail preparation', w: 800, h: 600 },
  { src: 'photo-1543007630-9710e4a00a20', alt: 'Coffee brewing', w: 800, h: 1000 },
  { src: 'photo-1541014741259-de529411b96a', alt: 'Drinks on the bar', w: 800, h: 600 },
  { src: 'photo-1536935338788-846bb9981813', alt: 'Bar interior', w: 800, h: 1000 },
  { src: 'photo-1517701550927-30cf4ba1dba5', alt: 'Late night', w: 800, h: 600 },
];
---

<section class="gallery" aria-label="Φωτογραφίες">
  <hr class="section-rule" style="border-color: var(--c-border);" aria-hidden="true" />

  <div class="gallery__inner nyx-inner">
    <p class="eyebrow eyebrow--coral gallery__label" data-anim="gallery-label">Ατμόσφαιρα</p>
    <h2 class="gallery__title" data-anim="gallery-title">Δες τον χώρο.</h2>

    <div class="gallery__grid">
      {photos.map((p, i) => (
        <div class="gallery__item" data-anim="gallery-item">
          <img
            src={`https://images.unsplash.com/${p.src}?w=${p.w}&q=80&fit=crop`}
            alt={p.alt}
            class="gallery__photo"
            loading="lazy"
            width={p.w}
            height={p.h}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    background: var(--c-bg);
    padding-block: var(--s-9);
  }

  .gallery__inner { display: grid; gap: var(--s-7); }

  .gallery__label { margin-bottom: calc(var(--s-3) * -1); }
  .gallery__title {
    font-family: var(--f-display);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.9;
    letter-spacing: 0.01em;
    color: var(--c-cream);
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-3);
  }
  @media (min-width: 768px) {
    .gallery__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .gallery__item {
    overflow: hidden;
    border-radius: var(--r-sm);
    /* clip-path set by GSAP */
  }
  .gallery__photo {
    width: 100%;
    height: clamp(200px, 28vw, 380px);
    object-fit: cover;
    filter: brightness(0.82) saturate(0.85);
    transition: transform 0.6s ease, filter 0.4s;
    display: block;
  }
  .gallery__item:hover .gallery__photo {
    transform: scale(1.05);
    filter: brightness(0.95) saturate(1.0);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {

    gsap.fromTo('[data-anim="gallery-label"]',
      { autoAlpha: 0, y: 12 }, {
        autoAlpha: 1, y: 0, duration: 0.5,
        scrollTrigger: { trigger: '[data-anim="gallery-label"]', start: 'top 85%' }
      });

    gsap.fromTo('[data-anim="gallery-title"]',
      { autoAlpha: 0, y: 20 }, {
        autoAlpha: 1, y: 0, duration: 0.7,
        scrollTrigger: { trigger: '[data-anim="gallery-title"]', start: 'top 85%' }
      });

    // Each photo wipes in from bottom with stagger
    gsap.fromTo('[data-anim="gallery-item"]',
      { clipPath: 'inset(0 0 100% 0)', autoAlpha: 1 }, {
        clipPath: 'inset(0 0 0% 0)',
        duration: 0.85,
        stagger: 0.1,
        ease: 'power3.out',
        scrollTrigger: { trigger: '.gallery__grid', start: 'top 78%' }
      });
  });
</script>
