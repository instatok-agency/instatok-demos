---
const drinks = [
  {
    photo: 'https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=600&q=80&fit=crop&crop=center',
    type: 'Signature',
    name: 'Nyx Negroni',
    notes: 'Mezcal · Campari · Vermouth Rosso · Orange Bitters',
    price: '€13',
  },
  {
    photo: 'https://images.unsplash.com/photo-1470337458703-46ad1756a187?w=600&q=80&fit=crop&crop=center',
    type: 'Cocktail',
    name: 'Espresso Martini',
    notes: 'Cold Brew · Vodka · Kahlúa · Vanilla',
    price: '€12',
  },
  {
    photo: 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=600&q=80&fit=crop&crop=top',
    type: 'Coffee',
    name: 'Single Origin Filter',
    notes: 'Εβδομαδιαία επιλογή origin · Aeropress ή V60',
    price: '€5',
  },
  {
    photo: 'https://images.unsplash.com/photo-1566150905458-1bf1fc113f0d?w=600&q=80&fit=crop&crop=center',
    type: 'Wine',
    name: 'Φυσικό Ροζέ',
    notes: 'Αμπελώνας Κτήμα Σκλάβου · Σαντορίνη · 2023',
    price: '€9',
  },
  {
    photo: 'https://images.unsplash.com/photo-1536935338788-846bb9981813?w=600&q=80&fit=crop&crop=center',
    type: 'Cocktail',
    name: 'Αthens Sour',
    notes: 'Mastiha Liqueur · Lemon · Egg White · Aromatic Bitters',
    price: '€11',
  },
];
---

<section class="menu" id="menu" aria-label="Drinks & Coffee menu">

  <!-- Header above the pin zone -->
  <div class="menu__header nyx-inner" data-anim="menu-header">
    <div class="menu__head-row">
      <div>
        <p class="eyebrow eyebrow--coral">Drinks &amp; Coffee</p>
        <h2 class="menu__title">Τι πίνουμε.</h2>
      </div>
      <p class="menu__hint eyebrow" aria-hidden="true">
        <span class="menu__hint-arrow">→</span> scroll
      </p>
    </div>
    <!-- Progress bar -->
    <div class="menu__progress" aria-hidden="true">
      <div class="menu__progress-fill" id="menuProgressFill"></div>
    </div>
  </div>

  <!-- Pinned horizontal stage -->
  <div class="menu__stage" id="menuStage">
    <div class="menu__track" id="menuTrack">
      {drinks.map((d, i) => (
        <article class="menu__card" data-index={i}>
          <div class="menu__card-photo-wrap">
            <img
              src={d.photo}
              alt={d.name}
              class="menu__card-photo"
              loading="lazy"
              width="600"
              height="750"
            />
          </div>
          <div class="menu__card-body">
            <span class="pill pill--coral">{d.type}</span>
            <h3 class="menu__card-name">{d.name}</h3>
            <p class="menu__card-notes">{d.notes}</p>
            <p class="menu__card-price">{d.price}</p>
          </div>
        </article>
      ))}
      <!-- End padding card -->
      <div class="menu__end-pad" aria-hidden="true"></div>
    </div>
  </div>

</section>

<style>
  .menu {
    background: var(--c-bg-2);
    padding-top: var(--s-9);
  }

  .menu__header { padding-bottom: var(--s-5); }

  .menu__head-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--s-4);
    margin-bottom: var(--s-5);
  }
  .menu__title {
    font-family: var(--f-display);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.9;
    letter-spacing: 0.01em;
    color: var(--c-cream);
    margin-top: var(--s-2);
  }
  .menu__hint {
    color: var(--c-cream-3);
    display: flex;
    align-items: center;
    gap: var(--s-2);
    padding-bottom: 0.5rem;
  }
  .menu__hint-arrow { color: var(--c-coral); font-size: 1rem; }

  /* Progress bar */
  .menu__progress {
    height: 2px;
    background: var(--c-border);
    border-radius: 1px;
    overflow: hidden;
  }
  .menu__progress-fill {
    height: 100%;
    background: var(--c-coral);
    transform-origin: left center;
    transform: scaleX(0);
    will-change: transform;
  }

  /* Stage + Track */
  .menu__stage {
    overflow: hidden;
    padding-block: var(--s-6) var(--s-9);
  }
  .menu__track {
    display: flex;
    gap: var(--s-5);
    padding-inline: 1.5rem;
    will-change: transform;
  }
  @media (min-width: 640px) { .menu__track { padding-inline: 2.5rem; } }
  @media (min-width: 1024px) { .menu__track { padding-inline: 4rem; } }

  /* Cards */
  .menu__card {
    flex-shrink: 0;
    width: clamp(260px, 30vw, 360px);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s;
  }
  .menu__card:hover { border-color: var(--c-coral-border); }

  .menu__card-photo-wrap {
    height: 300px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .menu__card-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.88) saturate(0.9);
    transition: transform 0.5s ease;
  }
  .menu__card:hover .menu__card-photo { transform: scale(1.04); }

  .menu__card-body {
    padding: var(--s-5);
    display: grid;
    gap: var(--s-3);
    flex: 1;
  }
  .menu__card-name {
    font-family: var(--f-display);
    font-size: 2rem;
    line-height: 1;
    color: var(--c-cream);
    letter-spacing: 0.02em;
  }
  .menu__card-notes {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--c-cream-2);
    flex: 1;
  }
  .menu__card-price {
    font-family: var(--f-display);
    font-size: 1.5rem;
    color: var(--c-coral);
    letter-spacing: 0.04em;
    padding-top: var(--s-3);
    border-top: 1px solid var(--c-border);
    margin-top: auto;
  }

  .menu__end-pad {
    flex-shrink: 0;
    width: 1px;
  }

  /* Mobile: native scroll-snap */
  @media (max-width: 767px) {
    .menu__stage {
      overflow-x: scroll;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .menu__stage::-webkit-scrollbar { display: none; }
    .menu__card { scroll-snap-align: start; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const mm = gsap.matchMedia();

  // Header reveal — all breakpoints
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('[data-anim="menu-header"]',
      { autoAlpha: 0, y: 24 }, {
        autoAlpha: 1, y: 0, duration: 0.8,
        scrollTrigger: { trigger: '[data-anim="menu-header"]', start: 'top 80%' }
      });
  });

  // Horizontal scroll — desktop only
  mm.add('(min-width: 768px) and (prefers-reduced-motion: no-preference)', () => {
    const track = document.getElementById('menuTrack') as HTMLElement;
    const stage = document.getElementById('menuStage') as HTMLElement;
    const fill  = document.getElementById('menuProgressFill') as HTMLElement;
    if (!track || !stage || !fill) return;

    const getDistance = () => track.scrollWidth - window.innerWidth;

    ScrollTrigger.create({
      trigger: stage,
      start: 'top top',
      end: () => `+=${getDistance()}`,
      pin: true,
      scrub: 1,
      invalidateOnRefresh: true,
      onUpdate(self) {
        gsap.set(track, { x: -getDistance() * self.progress });
        gsap.set(fill,  { scaleX: self.progress });
      },
    });
  });
</script>
