---
const espresso = [
  { name: 'Espresso', spec: '18g in · 36g out · 27s', price: '3.50' },
  { name: 'Lungo', spec: '18g in · 54g out · 35s', price: '3.80' },
  { name: 'Cappuccino', spec: '6oz · 20% microfoam', price: '4.50' },
  { name: 'Flat White', spec: '5oz · velvet texture', price: '4.50' },
  { name: 'Cortado', spec: '1:1 ratio', price: '4.00' },
  { name: 'Cold Brew', spec: '16h cold steep · 1:8', price: '5.00' },
];

const filter = [
  { name: 'V60', spec: 'Single origin · 15g · 250ml', price: '5.50' },
  { name: 'Aeropress', spec: 'Inverted · 15g · 220ml', price: '5.00' },
  { name: 'Chemex', spec: '6-cup · 42g · 700ml', price: '12.00', note: '2 ποτήρια' },
  { name: 'Filter (batch)', spec: 'Rotating origin · fresh', price: '4.00' },
  { name: 'Cascara', spec: 'Coffee cherry tea · 10g', price: '5.00' },
];
---

<section class="menu" id="menu" aria-labelledby="menu-title">
  <hr class="section-rule" aria-hidden="true" />

  <div class="menu__inner darkbar-section-inner">

    <p class="eyebrow" id="menu-title" data-anim="eyebrow">Μενού</p>

    <div class="menu__cols" data-anim="cols">

      <div class="menu__col">
        <h2 class="menu__col-title">Espresso Bar</h2>
        <ul class="menu__list" aria-label="Espresso">
          {espresso.map(item => (
            <li class="menu__item">
              <div class="menu__item-main">
                <span class="menu__item-name">{item.name}</span>
                <span class="menu__item-spec eyebrow">{item.spec}</span>
              </div>
              <span class="menu__item-price">€{item.price}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="menu__col">
        <h2 class="menu__col-title">Filter & Pour-Over</h2>
        <ul class="menu__list" aria-label="Filter">
          {filter.map(item => (
            <li class="menu__item">
              <div class="menu__item-main">
                <span class="menu__item-name">
                  {item.name}
                  {item.note && <span class="menu__item-note eyebrow">({item.note})</span>}
                </span>
                <span class="menu__item-spec eyebrow">{item.spec}</span>
              </div>
              <span class="menu__item-price">€{item.price}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="menu__retail" data-anim="retail">
      <p class="eyebrow">Ωμός καφές — retail</p>
      <div class="menu__retail-prices">
        <div class="menu__retail-item">
          <span class="menu__retail-qty">250g</span>
          <span class="menu__retail-price">€12</span>
        </div>
        <div class="menu__retail-sep" aria-hidden="true"></div>
        <div class="menu__retail-item">
          <span class="menu__retail-qty">500g</span>
          <span class="menu__retail-price">€22</span>
        </div>
        <div class="menu__retail-sep" aria-hidden="true"></div>
        <div class="menu__retail-item">
          <span class="menu__retail-qty">1kg</span>
          <span class="menu__retail-price">€40</span>
        </div>
        <div class="menu__retail-sep" aria-hidden="true"></div>
        <div class="menu__retail-item menu__retail-item--note">
          <span class="menu__retail-qty">Wholesale</span>
          <span class="menu__retail-price menu__retail-price--link">
            <a href="#visit" class="menu__retail-link">Επικοινωνία →</a>
          </span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .menu { background: var(--c-bg-2); }
  .menu__inner { padding-block: var(--s-9); display: grid; gap: var(--s-7); }

  .menu__cols {
    display: grid;
    gap: var(--s-7);
  }
  @media (min-width: 768px) {
    .menu__cols { grid-template-columns: 1fr 1fr; }
  }

  .menu__col { display: grid; gap: var(--s-4); }
  .menu__col-title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1.125rem;
    letter-spacing: 0.01em;
    color: var(--c-cream);
    padding-bottom: var(--s-3);
    border-bottom: 1px solid var(--c-border);
  }

  .menu__list { list-style: none; display: grid; gap: 0; }
  .menu__item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-3);
    padding-block: var(--s-3);
    border-bottom: 1px solid var(--c-border);
    transition: background 0.15s;
  }
  .menu__item:hover { background: rgba(240, 235, 227, 0.03); }

  .menu__item-main {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }
  .menu__item-name {
    font-family: var(--f-display);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--c-cream);
    display: flex;
    align-items: baseline;
    gap: var(--s-2);
    flex-wrap: wrap;
  }
  .menu__item-note { color: var(--c-cream-3); }
  .menu__item-spec { color: var(--c-cream-3); }
  .menu__item-price {
    font-family: var(--f-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--c-amber);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Retail strip */
  .menu__retail {
    border: 1px solid var(--c-border);
    padding: var(--s-5);
    display: grid;
    gap: var(--s-4);
  }
  .menu__retail-prices {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    flex-wrap: wrap;
  }
  .menu__retail-item {
    display: flex;
    align-items: baseline;
    gap: var(--s-2);
  }
  .menu__retail-qty {
    font-family: var(--f-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--c-cream-3);
    text-transform: uppercase;
  }
  .menu__retail-price {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--c-cream);
  }
  .menu__retail-link {
    font-family: var(--f-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-amber);
    transition: opacity 0.2s;
  }
  .menu__retail-link:hover { opacity: 0.7; }
  .menu__retail-sep {
    width: 1px;
    height: 1.75rem;
    background: var(--c-border);
    flex-shrink: 0;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const mm = gsap.matchMedia();
  mm.add(
    { isMotion: '(prefers-reduced-motion: no-preference)', isReduced: '(prefers-reduced-motion: reduce)' },
    (ctx) => {
      const { isReduced } = ctx.conditions ?? {};
      const els = [
        document.querySelector('[data-anim="eyebrow"]'),
        document.querySelector('[data-anim="cols"]'),
        document.querySelector('[data-anim="retail"]'),
      ].filter(Boolean);
      gsap.set(els, { autoAlpha: 0 });
      if (isReduced) { gsap.set(els, { autoAlpha: 1 }); return; }

      ScrollTrigger.batch(els, {
        start: 'top 85%',
        onEnter: batch => gsap.to(batch, { autoAlpha: 1, stagger: 0.12, duration: 0.8 }),
      });
    }
  );
</script>
