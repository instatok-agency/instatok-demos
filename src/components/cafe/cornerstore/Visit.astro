---
const hours = [
  { days: 'Δευτέρα – Παρασκευή', time: '07:30 – 21:00' },
  { days: 'Σάββατο',             time: '08:00 – 21:30' },
  { days: 'Κυριακή',             time: '09:00 – 20:00' },
];
---

<section class="visit" id="visit" aria-labelledby="visit-heading">
  <hr class="section-rule visit__rule" aria-hidden="true" />

  <div class="visit__inner cafe-section-inner">

    <div class="visit__grid">

      <div class="visit__info">
        <p class="eyebrow" data-anim="reveal">Έλα να μας δεις</p>
        <h2 class="visit__heading" id="visit-heading" data-anim="reveal">
          Βρες μας<br />στο Παγκράτι
        </h2>

        <address class="visit__address" data-anim="reveal">
          <p class="visit__street">Υμηττού 87</p>
          <p class="eyebrow visit__city">116 35 Παγκράτι · Αθήνα</p>
        </address>

        <dl class="visit__hours" data-anim="reveal" aria-label="Ώρες λειτουργίας">
          <div class="visit__hours-header">
            <dt class="eyebrow">Ώρες λειτουργίας</dt>
          </div>
          {hours.map(h => (
            <div class="visit__hour-row">
              <dt class="visit__hour-days">{h.days}</dt>
              <dd class="visit__hour-time">{h.time}</dd>
            </div>
          ))}
        </dl>

        <div class="visit__transport" data-anim="reveal">
          <p class="eyebrow visit__transport-label">Πώς να φτάσεις</p>
          <ul class="visit__transport-list">
            <li>
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="14" height="14">
                <circle cx="10" cy="10" r="8"/><path d="M10 6v4l2.5 2.5"/>
              </svg>
              5΄ περπάτημα από Μετρό Ευαγγελισμός (Γραμμή 3)
            </li>
            <li>
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="14" height="14">
                <circle cx="10" cy="10" r="8"/><path d="M10 6v4l2.5 2.5"/>
              </svg>
              Λεωφορείο 203, 732 — στάση «Υμηττού»
            </li>
            <li>
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="14" height="14">
                <circle cx="10" cy="10" r="8"/><path d="M10 6v4l2.5 2.5"/>
              </svg>
              Parking στην Ευφρονίου (3΄ πεζή)
            </li>
          </ul>
        </div>

        <div class="visit__actions" data-anim="reveal">
          <a href="https://maps.google.com" target="_blank" rel="noopener noreferrer" class="visit__map-btn">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" width="15" height="15">
              <path d="M10 2C6.686 2 4 4.686 4 8c0 5.25 6 10 6 10s6-4.75 6-10c0-3.314-2.686-6-6-6zm0 8a2 2 0 110-4 2 2 0 010 4z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Οδηγίες Google Maps
          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="visit__insta">
            @aletricoffee
          </a>
        </div>
      </div>

      <figure class="visit__figure" data-anim="photo" aria-hidden="true">
        <div class="visit__frame">
          <img
            src="https://images.unsplash.com/photo-1447933601403-0c6688de566e?w=800&q=80&fit=crop"
            alt="Coffee beans at Aletri"
            class="visit__photo"
            loading="lazy"
            width="800"
            height="600"
          />
        </div>
      </figure>

    </div>
  </div>
</section>

<style>
  .visit {
    background: var(--c-bg-2);
    padding-block: 0 var(--s-9);
  }
  .visit__rule { margin-bottom: 0; }
  .visit__inner { padding-block-start: var(--s-7); }

  .visit__grid { display: grid; gap: var(--s-7); }

  .visit__info .eyebrow { margin-bottom: var(--s-3); }
  .visit__heading {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--s-6);
  }

  .visit__address {
    font-style: normal;
    margin-bottom: var(--s-6);
  }
  .visit__street {
    font-family: var(--f-display);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--c-ink);
    margin-bottom: var(--s-1);
  }
  .visit__city { color: var(--c-terra); }

  .visit__hours {
    border: 1px solid var(--c-border);
    margin-bottom: var(--s-6);
  }
  .visit__hours-header {
    padding: var(--s-3) var(--s-4);
    border-bottom: 1px solid var(--c-border);
    background: var(--c-bg);
  }
  .visit__hour-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-4);
    padding: var(--s-3) var(--s-4);
    border-bottom: 1px solid var(--c-rule);
  }
  .visit__hour-row:last-child { border-bottom: none; }
  .visit__hour-days { font-size: 0.9rem; color: var(--c-ink-2); }
  .visit__hour-time { font-family: var(--f-mono); font-size: 0.82rem; color: var(--c-ink); }

  .visit__transport { margin-bottom: var(--s-6); }
  .visit__transport-label { margin-bottom: var(--s-3); }
  .visit__transport-list { list-style: none; display: grid; gap: var(--s-2); }
  .visit__transport-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--s-3);
    font-size: 0.9rem;
    color: var(--c-ink-2);
    line-height: 1.5;
  }
  .visit__transport-list svg { flex-shrink: 0; margin-top: 0.15rem; color: var(--c-terra); }

  .visit__actions { display: flex; align-items: center; gap: var(--s-5); flex-wrap: wrap; }
  .visit__map-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--c-ink);
    background: transparent;
    color: var(--c-ink);
    font-size: 0.9rem;
    font-weight: 500;
    transition: background 0.2s, color 0.2s;
  }
  .visit__map-btn:hover { background: var(--c-ink); color: var(--c-bg); }
  .visit__insta {
    font-family: var(--f-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--c-terra);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: color 0.2s;
  }
  .visit__insta:hover { color: var(--c-terra-deep); }

  .visit__figure { display: grid; }
  .visit__frame {
    border: 1px solid var(--c-border);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }
  .visit__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(12%) contrast(1.04) saturate(0.9);
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .visit__frame:hover .visit__photo { transform: scale(1.02); }

  @media (min-width: 1024px) {
    .visit__grid { grid-template-columns: 1fr 1fr; align-items: start; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('.visit__rule',
      { scaleX: 0 },
      { scaleX: 1, duration: 1.2, ease: 'power3.out',
        scrollTrigger: { trigger: '.visit', start: 'top 90%' } });

    gsap.utils.toArray<HTMLElement>('.visit [data-anim="reveal"]').forEach(el => {
      gsap.fromTo(el,
        { autoAlpha: 0, y: 18 },
        { autoAlpha: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
    });

    gsap.fromTo('[data-anim="photo"]',
      { autoAlpha: 0, scale: 1.04 },
      { autoAlpha: 1, scale: 1, duration: 1.1, ease: 'power2.out',
        scrollTrigger: { trigger: '[data-anim="photo"]', start: 'top 85%' } });
  });
</script>
