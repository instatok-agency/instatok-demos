---
---

<footer class="footer" role="contentinfo">
  <hr class="section-rule" aria-hidden="true" />

  <div class="footer__inner cafe-section-inner">

    <div class="footer__grid">

      <div class="footer__brand">
        <p class="footer__name">Aletri Coffee</p>
        <p class="footer__tagline eyebrow">Specialty Roastery · Παγκράτι</p>
        <p class="footer__since eyebrow">est. 2019 · Αθήνα</p>
      </div>

      <nav class="footer__nav" aria-label="Footer navigation">
        <ul>
          <li><a href="#story">Η ιστορία μας</a></li>
          <li><a href="#menu">Menu</a></li>
          <li><a href="#beans">Roastery</a></li>
          <li><a href="#visit">Πώς να μας βρεις</a></li>
        </ul>
      </nav>

      <div class="footer__contact">
        <p class="eyebrow footer__contact-label">Επικοινωνία</p>
        <a href="tel:+302101234567" class="footer__link">+30 210 123 4567</a>
        <a href="mailto:hello@aletricoffee.gr" class="footer__link">hello@aletricoffee.gr</a>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="footer__link footer__insta">@aletricoffee</a>
        <p class="footer__address eyebrow">Υμηττού 87, Παγκράτι · Αθήνα</p>
      </div>

      <div class="footer__order">
        <p class="eyebrow footer__order-label">Online Παραγγελία</p>
        <p class="footer__order-note">Beans delivery σε όλη την Ελλάδα — σύντομα.</p>
        <a href="#" class="footer__order-btn" aria-disabled="true">
          Notify me when live →
        </a>
      </div>

    </div>

    <div class="footer__bottom">
      <p class="eyebrow footer__copy">© {new Date().getFullYear()} Aletri Coffee · Specialty Roastery Παγκράτι</p>
      <p class="eyebrow footer__demo">Demo — Instatok Agency</p>
    </div>

  </div>
</footer>

<style>
  .footer {
    background: var(--c-bg);
    padding-block: 0 var(--s-6);
  }
  .footer > .section-rule { margin-bottom: 0; }
  .footer__inner { padding-block-start: var(--s-7); }

  .footer__grid {
    display: grid;
    gap: var(--s-7);
    padding-bottom: var(--s-7);
    border-bottom: 1px solid var(--c-border);
  }

  .footer__name {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    margin-bottom: var(--s-2);
  }
  .footer__tagline { margin-bottom: var(--s-1); }
  .footer__since { color: var(--c-terra); }

  .footer__nav ul { list-style: none; display: grid; gap: var(--s-2); }
  .footer__nav a { font-size: 0.9375rem; color: var(--c-ink-2); transition: color 0.18s; }
  .footer__nav a:hover { color: var(--c-terra); }

  .footer__contact { display: grid; gap: var(--s-2); }
  .footer__contact-label { margin-bottom: var(--s-1); }
  .footer__link { font-size: 0.9375rem; color: var(--c-ink-2); transition: color 0.18s; }
  .footer__link:hover { color: var(--c-terra); }
  .footer__insta { font-family: var(--f-mono); font-size: 0.78rem; }
  .footer__address { margin-top: var(--s-2); }

  .footer__order-label { margin-bottom: var(--s-2); }
  .footer__order-note { font-size: 0.875rem; color: var(--c-ink-2); margin-bottom: var(--s-3); line-height: 1.5; }
  .footer__order-btn {
    display: inline-block;
    font-family: var(--f-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    color: var(--c-ink-3);
    border-bottom: 1px solid var(--c-border);
    padding-bottom: 1px;
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s-3);
    padding-top: var(--s-5);
    color: var(--c-ink-3);
  }

  @media (min-width: 768px) {
    .footer__grid { grid-template-columns: 1fr 1fr 1fr 1fr; }
  }
</style>
