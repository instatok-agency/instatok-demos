---
const coffeeItems = [
  { name: 'Espresso', desc: 'Single origin · Εφήμερο — αλλάζει κάθε εβδομάδα', price: '2.50' },
  { name: 'Batch Brew', desc: 'Filter του ψησίματος της εβδομάδας', price: '3.00' },
  { name: 'Cortado', desc: '1:1 espresso με ατμισμένο γάλα', price: '3.50' },
  { name: 'Flat White', desc: 'Double ristretto · Microfoam texture', price: '4.00' },
  { name: 'Pour Over', desc: 'Στο χέρι, V60 ή Chemex — κατόπιν επιλογής origin', price: '5.00' },
  { name: 'Cold Brew', desc: '18ωρη ψυχρή εκχύλιση · Καλοκαιρινά', price: '4.50' },
  { name: 'Cappuccino', desc: 'Κλασικό, με προσοχή στην υφή', price: '3.80' },
  { name: 'Oat Flat White', desc: 'Oatly barista edition', price: '4.50' },
];

const brunchItems = [
  { name: 'Avocado Toast', desc: 'Sourdough · Αβοκάντο · Αυγό ποσέ · Dukkah', price: '9.50' },
  { name: 'Granola Bowl', desc: 'Σπιτικό granola · Greek yogurt · Seasonal fruits', price: '8.00' },
  { name: 'Shakshuka', desc: 'Αυγά ποσέ σε σάλτσα ντομάτας · Φέτα · Ψωμί', price: '10.50' },
  { name: 'Banana Bread', desc: 'Σπιτικό · Βούτυρο καρύδας · Μέλι', price: '5.50' },
  { name: 'Smashed Eggs', desc: 'Scrambled · Sourdough · Μαϊντανός', price: '8.50' },
  { name: 'Açaí Bowl', desc: 'Açaí · Granola · Φράουλα · Βατόμουρο · Coconut flakes', price: '9.00' },
];
---

<section class="menu" id="menu" aria-labelledby="menu-heading">
  <hr class="section-rule menu__rule" aria-hidden="true" />

  <div class="menu__inner cafe-section-inner">

    <header class="menu__header">
      <p class="eyebrow" data-anim="reveal">Menu</p>
      <h2 class="menu__heading" id="menu-heading" data-anim="reveal">
        Specialty coffee<br />&amp; weekend brunch
      </h2>
      <p class="menu__note" data-anim="reveal">
        Το menu καφέ αλλάζει εποχιακά ανάλογα με τα origins που ψήνουμε.
        Τα brunch items διαθέσιμα Σαββ–Κυρ 09:00–14:30.
      </p>
    </header>

    <div class="menu__sections">

      <div class="menu__section" data-anim="section">
        <h3 class="menu__section-title eyebrow">
          <span>Specialty Coffee</span>
        </h3>
        <ul class="menu__list">
          {coffeeItems.map(item => (
            <li class="menu__item">
              <div class="menu__item-text">
                <span class="menu__item-name">{item.name}</span>
                <span class="menu__item-desc">{item.desc}</span>
              </div>
              <span class="menu__item-price">{item.price}€</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="menu__section" data-anim="section">
        <h3 class="menu__section-title eyebrow">
          <span>Weekend Brunch</span>
          <span class="menu__section-note eyebrow">Σαββ–Κυρ · 09:00–14:30</span>
        </h3>
        <ul class="menu__list">
          {brunchItems.map(item => (
            <li class="menu__item">
              <div class="menu__item-text">
                <span class="menu__item-name">{item.name}</span>
                <span class="menu__item-desc">{item.desc}</span>
              </div>
              <span class="menu__item-price">{item.price}€</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div class="menu__photo-strip" data-anim="strip" aria-hidden="true">
      <div class="menu__strip-item">
        <img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=500&q=80&fit=crop" alt="" loading="lazy" width="500" height="400" />
      </div>
      <div class="menu__strip-item">
        <img src="https://images.unsplash.com/photo-1484723091739-30a097e8f929?w=500&q=80&fit=crop" alt="" loading="lazy" width="500" height="400" />
      </div>
      <div class="menu__strip-item">
        <img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=500&q=80&fit=crop" alt="" loading="lazy" width="500" height="400" />
      </div>
    </div>

  </div>
</section>

<style>
  .menu {
    background: var(--c-bg-2);
    padding-block: 0 var(--s-9);
  }
  .menu__rule { margin-bottom: 0; }
  .menu__inner { padding-block-start: var(--s-7); }

  .menu__header { margin-bottom: var(--s-7); }
  .menu__header .eyebrow { margin-bottom: var(--s-3); }
  .menu__heading {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--s-4);
  }
  .menu__note {
    font-size: 0.9rem;
    color: var(--c-ink-2);
    max-width: 50ch;
  }

  .menu__sections { display: grid; gap: var(--s-7); margin-bottom: var(--s-8); }

  .menu__section-title {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s-3);
    padding-bottom: var(--s-3);
    border-bottom: 1px solid var(--c-border);
    margin-bottom: var(--s-4);
    color: var(--c-ink-2);
  }
  .menu__section-note { color: var(--c-terra); }

  .menu__list { list-style: none; display: grid; gap: 0; }
  .menu__item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-4);
    padding-block: var(--s-3);
    border-bottom: 1px solid var(--c-rule);
  }
  .menu__item:last-child { border-bottom: none; }
  .menu__item-text { display: flex; flex-direction: column; gap: var(--s-1); flex: 1; }
  .menu__item-name {
    font-size: 1rem;
    font-weight: 500;
    color: var(--c-ink);
  }
  .menu__item-desc {
    font-size: 0.8125rem;
    color: var(--c-ink-3);
    line-height: 1.4;
  }
  .menu__item-price {
    font-family: var(--f-mono);
    font-size: 0.875rem;
    color: var(--c-ink-2);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .menu__photo-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--c-border);
    border: 1px solid var(--c-border);
  }
  .menu__strip-item {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }
  .menu__strip-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(10%) contrast(1.04) saturate(0.9);
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .menu__strip-item:hover img { transform: scale(1.04); }

  @media (min-width: 1024px) {
    .menu__sections { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('.menu__rule',
      { scaleX: 0 },
      { scaleX: 1, duration: 1.2, ease: 'power3.out',
        scrollTrigger: { trigger: '.menu', start: 'top 90%' } });

    gsap.utils.toArray<HTMLElement>('.menu [data-anim="reveal"]').forEach(el => {
      gsap.fromTo(el,
        { autoAlpha: 0, y: 18 },
        { autoAlpha: 1, y: 0, duration: 0.8,
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' } });
    });

    gsap.utils.toArray<HTMLElement>('.menu [data-anim="section"]').forEach((el, i) => {
      gsap.fromTo(el,
        { autoAlpha: 0, y: 24 },
        { autoAlpha: 1, y: 0, duration: 0.8, delay: i * 0.12,
          scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' } });
    });

    gsap.utils.toArray<HTMLElement>('.menu__item').forEach((el, i) => {
      gsap.fromTo(el,
        { autoAlpha: 0, x: -10 },
        { autoAlpha: 1, x: 0, duration: 0.45, delay: i * 0.04,
          scrollTrigger: { trigger: el, start: 'top 92%', toggleActions: 'play none none none' } });
    });

    gsap.fromTo('[data-anim="strip"]',
      { autoAlpha: 0, y: 30 },
      { autoAlpha: 1, y: 0, duration: 0.9,
        scrollTrigger: { trigger: '[data-anim="strip"]', start: 'top 85%' } });
  });
</script>
