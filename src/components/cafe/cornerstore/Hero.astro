---
---

<section class="hero" aria-labelledby="hero-headline">

  <!-- Full-bleed background photo -->
  <div class="hero__bg" aria-hidden="true">
    <img
      src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1600&q=80&fit=crop"
      alt=""
      class="hero__photo"
      loading="eager"
      width="1600"
      height="1067"
      data-anim="photo"
    />
    <div class="hero__overlay"></div>
  </div>

  <!-- Content anchored at bottom -->
  <div class="hero__content">
    <div class="hero__inner">

      <p class="hero__stamp eyebrow" data-anim="stamp">
        Παγκράτι · Αθήνα · 2019
      </p>

      <h1 class="hero__headline" id="hero-headline">
        <span class="hero__hline" data-anim="hline">Πήγαμε στη</span>
        <span class="hero__hline hero__hline--em" data-anim="hline">Μελβούρνη.</span>
        <span class="hero__hline" data-anim="hline">Γυρίσαμε</span>
        <span class="hero__hline" data-anim="hline">με καφέ.</span>
      </h1>

      <p class="hero__lead" data-anim="lead">
        Το <strong>Aletri</strong> είναι ένα specialty coffee shop και micro-roastery στο
        Παγκράτι. Ψήνουμε μόνοι μας, επιλέγουμε origins με προσοχή, και πιστεύουμε
        ότι ένα καλό φλιτζάνι δεν χρειάζεται εξήγηση.
      </p>

      <div class="hero__actions" data-anim="actions">
        <a href="#menu" class="hero__cta hero__cta--primary">
          <span>Δες το menu</span>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M4 10h12M11 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#story" class="hero__cta hero__cta--ghost">Η ιστορία μας</a>
      </div>

      <div class="hero__meta" data-anim="meta">
        <div class="hero__meta-item">
          <span class="hero__meta-label eyebrow">Specialty Coffee</span>
          <span class="hero__meta-val">Single origins + blends</span>
        </div>
        <div class="hero__meta-item">
          <span class="hero__meta-label eyebrow">Roastery</span>
          <span class="hero__meta-val">Ψήνουμε στον χώρο</span>
        </div>
        <div class="hero__meta-item">
          <span class="hero__meta-label eyebrow">Ώρες</span>
          <span class="hero__meta-val">07:30 – 21:00 καθημερινά</span>
        </div>
      </div>

    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    background: var(--c-bg);
  }

  /* Full-bleed photo layer */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: sepia(14%) contrast(1.05) saturate(0.88);
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(253,248,242, 0)    0%,
      rgba(253,248,242, 0)    20%,
      rgba(253,248,242, 0.5)  48%,
      rgba(253,248,242, 0.95) 65%,
      var(--c-bg)             77%
    );
  }

  /* Content layer */
  .hero__content {
    position: relative;
    z-index: 2;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5rem 1.5rem 3.5rem;
  }
  .hero__inner {
    width: min(100%, 46rem);
    display: grid;
    gap: var(--s-5);
  }

  .hero__stamp {
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }
  .hero__stamp::before {
    content: "";
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--c-terra);
    flex-shrink: 0;
  }

  .hero__headline {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2.6rem, 8.5vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .hero__hline {
    display: block;
    overflow: hidden;
    padding-bottom: 0.05em;
  }
  .hero__hline--em {
    color: var(--c-terra);
    font-style: italic;
  }

  .hero__lead {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--c-ink-2);
    max-width: 44ch;
  }
  .hero__lead strong { color: var(--c-ink); font-weight: 500; }

  .hero__actions { display: flex; flex-wrap: nowrap; gap: var(--s-3); }
  .hero__cta {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 1.35rem;
    font-family: var(--f-body);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    cursor: pointer;
  }
  .hero__cta svg { width: 16px; height: 16px; flex-shrink: 0; }
  .hero__cta--primary {
    background: var(--c-ink);
    color: var(--c-bg);
    border: 1px solid var(--c-ink);
  }
  .hero__cta--primary:hover { background: var(--c-terra); border-color: var(--c-terra); }
  .hero__cta--ghost {
    background: transparent;
    color: var(--c-ink);
    border: 1px solid var(--c-border);
  }
  .hero__cta--ghost:hover { border-color: var(--c-ink); }

  .hero__meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-1);
    padding-top: var(--s-4);
    border-top: 1px solid var(--c-border);
  }
  .hero__meta-item { display: flex; flex-direction: column; gap: var(--s-1); }
  .hero__meta-label { color: var(--c-terra); }
  .hero__meta-val { font-size: 0.85rem; color: var(--c-ink-2); line-height: 1.4; }

  @media (min-width: 640px) {
    .hero__content { padding-inline: 2.5rem; }
  }
  @media (min-width: 1024px) {
    .hero__content { padding-inline: 4rem; padding-bottom: 4.5rem; }
    .hero__inner { width: min(100%, 54rem); }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initGSAP } from '../../../scripts/gsap-cafe-cornerstore';

  initGSAP();
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();
  mm.add(
    { isMotion: '(prefers-reduced-motion: no-preference)', isReduced: '(prefers-reduced-motion: reduce)' },
    (ctx) => {
      const { isReduced } = ctx.conditions ?? {};
      const els = ['[data-anim="photo"]', '[data-anim="stamp"]', '[data-anim="hline"]',
                   '[data-anim="lead"]', '[data-anim="actions"]', '[data-anim="meta"]'];
      gsap.set(els, { autoAlpha: 0 });
      if (isReduced) { gsap.set(els, { autoAlpha: 1 }); return; }

      const tl = gsap.timeline();
      tl.fromTo('[data-anim="photo"]',
          { autoAlpha: 0, scale: 1.06 },
          { autoAlpha: 1, scale: 1, duration: 2, ease: 'power2.out' }, 0)
        .fromTo('[data-anim="stamp"]',
          { autoAlpha: 0, y: -10 }, { autoAlpha: 1, y: 0, duration: 0.7 }, 0.5)
        .fromTo('[data-anim="hline"]',
          { autoAlpha: 0, yPercent: 110 },
          { autoAlpha: 1, yPercent: 0, duration: 1.05, stagger: 0.09, ease: 'power4.out' }, 0.65)
        .fromTo('[data-anim="lead"]',
          { autoAlpha: 0, y: 16 }, { autoAlpha: 1, y: 0, duration: 0.8 }, '-=0.5')
        .fromTo('[data-anim="actions"]',
          { autoAlpha: 0, y: 12 }, { autoAlpha: 1, y: 0, duration: 0.65 }, '-=0.4')
        .fromTo('[data-anim="meta"]',
          { autoAlpha: 0, y: 10 }, { autoAlpha: 1, y: 0, duration: 0.65 }, '-=0.35');
    }
  );
</script>
