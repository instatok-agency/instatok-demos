---
---

<section class="hero" aria-labelledby="hero-headline">

  <!-- Left: story text -->
  <div class="hero__text">
    <div class="hero__text-inner">

      <p class="hero__stamp eyebrow" data-anim="stamp">
        Παγκράτι · Αθήνα · 2019
      </p>

      <h1 class="hero__headline" id="hero-headline">
        <span class="hero__hline" data-anim="hline">Πήγαμε στη</span>
        <span class="hero__hline hero__hline--em" data-anim="hline">Μελβούρνη.</span>
        <span class="hero__hline" data-anim="hline">Γυρίσαμε</span>
        <span class="hero__hline" data-anim="hline">με καφέ.</span>
      </h1>

      <!-- Mobile photo -->
      <div class="hero__mobile-photo" aria-hidden="true" data-anim="mobile-photo">
        <img
          src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=800&q=80&fit=crop"
          alt=""
          loading="eager"
          width="800"
          height="450"
        />
      </div>

      <p class="hero__lead" data-anim="lead">
        Το <strong>Aletri</strong> είναι ένα specialty coffee shop και micro-roastery στο
        Παγκράτι. Ψήνουμε μόνοι μας, επιλέγουμε origins με προσοχή, και πιστεύουμε
        ότι ένα καλό φλιτζάνι δεν χρειάζεται εξήγηση.
      </p>

      <div class="hero__actions" data-anim="actions">
        <a href="#menu" class="hero__cta hero__cta--primary">
          <span>Δες το menu</span>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M4 10h12M11 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#story" class="hero__cta hero__cta--ghost">Η ιστορία μας</a>
      </div>

      <div class="hero__meta" data-anim="meta">
        <div class="hero__meta-item">
          <span class="hero__meta-label eyebrow">Specialty Coffee</span>
          <span class="hero__meta-val">Single origins + blends</span>
        </div>
        <div class="hero__meta-item">
          <span class="hero__meta-label eyebrow">Roastery</span>
          <span class="hero__meta-val">Ψήνουμε στον χώρο</span>
        </div>
        <div class="hero__meta-item">
          <span class="hero__meta-label eyebrow">Ώρες</span>
          <span class="hero__meta-val">07:30 – 21:00 καθημερινά</span>
        </div>
      </div>

    </div>
  </div>

  <!-- Right: photo -->
  <div class="hero__visual" aria-hidden="true" data-anim="photo">
    <img
      src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=900&q=80&fit=crop"
      alt=""
      class="hero__photo"
      loading="eager"
      width="900"
      height="1200"
    />
    <div class="hero__photo-overlay"></div>
    <p class="hero__caption">
      <span>Παγκράτι</span>
      <span>Αθήνα</span>
    </p>
  </div>

</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 100svh;
    background: var(--c-bg);
  }

  .hero__text {
    padding: var(--s-8) 1.5rem var(--s-7);
    padding-top: calc(var(--s-8) + 2rem);
    display: flex;
    align-items: center;
  }
  .hero__text-inner {
    width: min(100%, 38rem);
    margin-inline: auto;
    display: grid;
    gap: var(--s-5);
  }

  .hero__stamp {
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }
  .hero__stamp::before {
    content: "";
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--c-terra);
    flex-shrink: 0;
  }

  .hero__headline {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: clamp(2.6rem, 8.5vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .hero__hline {
    display: block;
    overflow: hidden;
    padding-bottom: 0.05em;
  }
  .hero__hline--em {
    color: var(--c-terra);
    font-style: italic;
  }

  .hero__mobile-photo {
    overflow: hidden;
    border: 1px solid var(--c-border);
    aspect-ratio: 16 / 9;
  }
  .hero__mobile-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: sepia(12%) contrast(1.04) saturate(0.95);
  }

  .hero__lead {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--c-ink-2);
    max-width: 44ch;
  }
  .hero__lead strong { color: var(--c-ink); font-weight: 500; }

  .hero__actions { display: flex; flex-wrap: nowrap; gap: var(--s-3); }
  .hero__cta {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 1.35rem;
    font-family: var(--f-body);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    cursor: pointer;
  }
  .hero__cta svg { width: 16px; height: 16px; flex-shrink: 0; }
  .hero__cta--primary {
    background: var(--c-ink);
    color: var(--c-bg);
    border: 1px solid var(--c-ink);
  }
  .hero__cta--primary:hover { background: var(--c-terra); border-color: var(--c-terra); }
  .hero__cta--ghost {
    background: transparent;
    color: var(--c-ink);
    border: 1px solid var(--c-border);
  }
  .hero__cta--ghost:hover { border-color: var(--c-ink); }

  .hero__meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-1);
    padding-top: var(--s-4);
    border-top: 1px solid var(--c-border);
  }
  .hero__meta-item { display: flex; flex-direction: column; gap: var(--s-1); }
  .hero__meta-label { color: var(--c-terra); }
  .hero__meta-val { font-size: 0.85rem; color: var(--c-ink-2); line-height: 1.4; }

  .hero__visual {
    display: none;
    position: relative;
    overflow: hidden;
  }
  .hero__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(12%) contrast(1.04) saturate(0.9);
  }
  .hero__photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(253,248,242,0.15) 0%, transparent 40%);
    z-index: 1;
  }
  .hero__caption {
    position: absolute;
    bottom: var(--s-5);
    right: var(--s-5);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    font-family: var(--f-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(253, 248, 242, 0.65);
  }

  @media (min-width: 640px) { .hero__text { padding-inline: 2.5rem; } }
  @media (min-width: 1024px) {
    .hero { grid-template-columns: 55% 45%; }
    .hero__text { padding: var(--s-8) 4rem; border-right: 1px solid var(--c-border); }
    .hero__text-inner { margin-inline: 0; }
    .hero__visual { display: block; }
    .hero__mobile-photo { display: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initGSAP } from '../../../scripts/gsap-cafe-cornerstore';

  initGSAP();
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();
  mm.add(
    { isMotion: '(prefers-reduced-motion: no-preference)', isReduced: '(prefers-reduced-motion: reduce)' },
    (ctx) => {
      const { isReduced } = ctx.conditions ?? {};
      const els = ['[data-anim="stamp"]', '[data-anim="hline"]', '[data-anim="mobile-photo"]',
                   '[data-anim="lead"]', '[data-anim="actions"]', '[data-anim="meta"]', '[data-anim="photo"]'];
      gsap.set(els, { autoAlpha: 0 });
      if (isReduced) { gsap.set(els, { autoAlpha: 1 }); return; }

      const tl = gsap.timeline();
      tl.fromTo('[data-anim="stamp"]',
          { autoAlpha: 0, y: -10 }, { autoAlpha: 1, y: 0, duration: 0.7 }, 0.1)
        .fromTo('[data-anim="hline"]',
          { autoAlpha: 0, yPercent: 110 },
          { autoAlpha: 1, yPercent: 0, duration: 1.05, stagger: 0.09, ease: 'power4.out' }, 0.2)
        .fromTo('[data-anim="mobile-photo"]',
          { autoAlpha: 0, scale: 1.03 }, { autoAlpha: 1, scale: 1, duration: 0.9, ease: 'power2.out' }, '-=0.4')
        .fromTo('[data-anim="lead"]',
          { autoAlpha: 0, y: 16 }, { autoAlpha: 1, y: 0, duration: 0.8 }, '-=0.5')
        .fromTo('[data-anim="actions"]',
          { autoAlpha: 0, y: 12 }, { autoAlpha: 1, y: 0, duration: 0.65 }, '-=0.4')
        .fromTo('[data-anim="meta"]',
          { autoAlpha: 0, y: 10 }, { autoAlpha: 1, y: 0, duration: 0.65 }, '-=0.35')
        .fromTo('[data-anim="photo"]',
          { autoAlpha: 0, scale: 1.04 }, { autoAlpha: 1, scale: 1, duration: 1.4, ease: 'power2.out' }, 0.15);
    }
  );
</script>
