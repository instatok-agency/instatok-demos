---
const iconHome = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`;
const iconUtensils = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>`;
const iconCpu = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2M15 20v2M2 15h2M2 9h2M20 15h2M20 9h2M9 2v2M9 20v2"/></svg>`;

const groups = [
  {
    icon: iconHome,
    title: 'Διαμονή',
    items: [
      '3 υπνοδωμάτια (6 άτομα)',
      'King & queen κρεβάτια',
      'Πολυτελή λινά premium',
      'Ιδιωτική αυλή 30 m²',
      'Θέα Αιγαίου παντού',
      'Παραδοσιακοί πέτρινοι τοίχοι',
    ],
  },
  {
    icon: iconUtensils,
    title: 'Κουζίνα',
    items: [
      'Πλήρης εξοπλισμός',
      'Espresso machine Nespresso',
      'Πλυντήριο πιάτων',
      'Πλυντήριο ρούχων',
      'Ψυγείο & καταψύκτης',
      'Τοπικά προϊόντα Σύρου',
    ],
  },
  {
    icon: iconCpu,
    title: 'Τεχνολογία',
    items: [
      'WiFi Fiber 400Mbps',
      'Smart TV 4K (2 δωμ.)',
      'Κλιματισμός Daikin',
      'Έξυπνες κλειδαριές',
      'Blackout κουρτίνες',
      'Εξωτερική BBQ εστία',
    ],
  },
];
---

<section class="rv-amen" id="amenities" aria-label="Παροχές">
  <div class="rv-amen__inner rv-inner">

    <div class="rv-amen__head" data-anim="rv-amen-head">
      <p class="rv-eyebrow">Παροχές</p>
      <h2 class="rv-sec-title">Τι περιλαμβάνεται.</h2>
      <p class="rv-amen__sub">
        Όλα όσα χρειάζεστε για μια αυτόνομη, άνετη διαμονή. Τίποτα λιγότερο.
      </p>
    </div>

    <div class="rv-amen__grid" data-anim="rv-amen-grid">
      {groups.map((g, i) => (
        <div class="rv-amen-group">
          <div class="rv-amen-group__head">
            <span class="rv-amen-group__icon" aria-hidden="true" set:html={g.icon}></span>
            <div>
              <span class="rv-eyebrow rv-eyebrow--gold">0{i + 1}</span>
              <h3 class="rv-amen-group__title">{g.title}</h3>
            </div>
          </div>
          <ul class="rv-amen-group__list">
            {g.items.map(item => (
              <li class="rv-amen-group__item">
                <span class="rv-amen-group__check" aria-hidden="true">—</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="rv-amen__note" data-anim="rv-amen-note">
      <span class="rv-eyebrow rv-eyebrow--gold">+</span>
      <span class="rv-eyebrow">Καλωσόρισμα με τοπικά προϊόντα · Τελικός καθαρισμός · Check-in ευέλικτο</span>
    </p>

  </div>
</section>

<style>
  .rv-amen { background: var(--rv-cream); padding-block: var(--s-9); }
  .rv-amen__inner { display: grid; gap: var(--s-8); }

  .rv-amen__head { display: grid; gap: var(--s-4); max-width: 44rem; }
  .rv-amen__sub {
    font-family: var(--f-body); font-size: 0.9375rem;
    font-weight: 300; line-height: 1.8; color: var(--rv-warm);
  }

  .rv-amen__grid {
    display: grid; gap: 0;
    border-top: 2px solid var(--rv-gold);
  }
  @media (min-width: 768px) {
    .rv-amen__grid { grid-template-columns: repeat(3, 1fr); }
    .rv-amen-group:not(:last-child) { border-right: 1px solid var(--rv-border-2); }
  }

  .rv-amen-group {
    padding: var(--s-6) var(--s-5) var(--s-6) 0;
    display: grid; gap: var(--s-5); align-content: start;
  }
  @media (min-width: 768px) {
    .rv-amen-group:not(:first-child) { padding-left: var(--s-6); }
  }
  @media (max-width: 767px) {
    .rv-amen-group { border-bottom: 1px solid var(--rv-border); padding-bottom: var(--s-6); }
  }

  .rv-amen-group__head {
    display: flex; align-items: flex-start; gap: var(--s-4);
  }
  .rv-amen-group__icon {
    display: flex; align-items: center; justify-content: center;
    width: 2.25rem; height: 2.25rem; flex-shrink: 0;
    background: var(--rv-gold-bg); border-radius: var(--r-sm);
    color: var(--rv-gold);
  }
  .rv-amen-group__icon svg { width: 18px; height: 18px; }
  .rv-amen-group__title {
    font-family: var(--f-display); font-style: italic;
    font-size: 1.375rem; font-weight: 500; color: var(--rv-black);
    margin-top: 2px;
  }

  .rv-amen-group__list { list-style: none; display: grid; gap: var(--s-3); }
  .rv-amen-group__item {
    display: flex; align-items: baseline; gap: var(--s-3);
    font-family: var(--f-body); font-size: 0.875rem;
    font-weight: 300; color: var(--rv-warm);
    line-height: 1.5;
  }
  .rv-amen-group__check { color: var(--rv-gold); font-size: 0.75rem; flex-shrink: 0; }

  .rv-amen__note {
    display: flex; align-items: center; gap: var(--s-3); flex-wrap: wrap;
    padding-top: var(--s-6); border-top: 1px solid var(--rv-border-2);
  }

  [data-anim="rv-amen-head"], [data-anim="rv-amen-grid"], [data-anim="rv-amen-note"] { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    [data-anim="rv-amen-head"], [data-anim="rv-amen-grid"], [data-anim="rv-amen-note"] { opacity: 1 !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.set('[data-anim="rv-amen-head"]', { y: 20 });
    gsap.set('[data-anim="rv-amen-grid"]', { y: 24 });
    gsap.to('[data-anim="rv-amen-head"]', { opacity: 1, y: 0, duration: 0.85, scrollTrigger: { trigger: '.rv-amen__head', start: 'top 85%' } });
    gsap.to('[data-anim="rv-amen-grid"]', { opacity: 1, y: 0, duration: 0.9,  scrollTrigger: { trigger: '.rv-amen__grid', start: 'top 82%' } });
    gsap.to('[data-anim="rv-amen-note"]', { opacity: 1, duration: 0.6, scrollTrigger: { trigger: '[data-anim="rv-amen-note"]', start: 'top 88%' } });
  });
</script>
