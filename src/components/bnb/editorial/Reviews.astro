---
const reviews = [
  {
    quote: 'Το πιο ωραίο διαμέρισμα που έχουμε νοικιάσει ποτέ. Νιώσαμε σαν να ζούμε εκεί μόνιμα. Η Μαρία είναι εξαιρετική οικοδέσποινα.',
    name: 'Σοφία & Νίκος',
    from: 'Θεσσαλονίκη',
    stays: '5 διανυκτερεύσεις',
    stars: 5,
  },
  {
    quote: 'Ήρθα για δουλειά και έμεινα 10 μέρες. Το γραφείο ήταν τέλειο, το WiFi γρήγορο, και η γειτονιά ήταν ό,τι χρειαζόμουν.',
    name: 'Δημήτρης Κ.',
    from: 'Λονδίνο',
    stays: '10 διανυκτερεύσεις',
    stars: 5,
  },
  {
    quote: 'Τα χρώματα, τα έπιπλα, η ατμόσφαιρα — όλα δείχνουν ότι κάποιος το σκέφτηκε με αγάπη. Σπάνιο σε ενοικιαζόμενα.',
    name: 'Ελένη Μ.',
    from: 'Γαλλία',
    stays: '7 διανυκτερεύσεις',
    stars: 5,
  },
];
---

<section class="reviews" aria-label="Κριτικές">
  <div class="reviews__inner ed-inner">

    <div class="reviews__head" data-anim="rev-head">
      <p class="eyebrow">Τι λένε</p>
      <h2 class="reviews__title">Κριτικές.</h2>
      <div class="reviews__score">
        <span class="reviews__score-n">4.98</span>
        <div class="reviews__score-r">
          <span class="reviews__stars">★★★★★</span>
          <span class="eyebrow">126 κριτικές</span>
        </div>
      </div>
    </div>

    <div class="reviews__grid">
      {reviews.map((r, i) => (
        <blockquote class="rev-card" data-anim="rev-card">
          <p class="rev-card__quote">"{r.quote}"</p>
          <footer class="rev-card__foot">
            <div>
              <p class="rev-card__name">{r.name}</p>
              <p class="rev-card__from eyebrow">{r.from} · {r.stays}</p>
            </div>
            <span class="rev-card__stars">{'★'.repeat(r.stars)}</span>
          </footer>
        </blockquote>
      ))}
    </div>

  </div>
</section>

<style>
  .reviews { background: var(--c-bg); padding-block: var(--s-9); }
  .reviews__inner { display: grid; gap: var(--s-8); }

  .reviews__head { display: grid; gap: var(--s-4); }
  .reviews__title {
    font-family: var(--f-display); font-weight: 400;
    font-size: clamp(2.5rem, 6vw, 5rem);
    letter-spacing: -0.025em; color: var(--c-ink); line-height: 1.0;
  }
  .reviews__score { display: flex; align-items: center; gap: var(--s-4); }
  .reviews__score-n {
    font-family: var(--f-display); font-size: 3rem;
    font-weight: 300; font-style: italic; color: var(--c-ink);
  }
  .reviews__score-r { display: grid; gap: 2px; }
  .reviews__stars { color: var(--c-sand); font-size: 0.875rem; letter-spacing: 0.12em; }

  .reviews__grid {
    display: grid; gap: var(--s-5);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 22rem), 1fr));
  }

  .rev-card {
    background: var(--c-bg-2); border: 1px solid var(--c-border);
    border-radius: var(--r-lg); padding: var(--s-6);
    display: flex; flex-direction: column; gap: var(--s-5);
    transition: border-color 0.2s;
  }
  .rev-card:hover { border-color: var(--c-sand); }
  .rev-card__quote {
    font-family: var(--f-display); font-style: italic;
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.65; color: var(--c-ink); flex: 1;
  }
  .rev-card__foot {
    display: flex; align-items: flex-end;
    justify-content: space-between; gap: var(--s-3);
    padding-top: var(--s-4); border-top: 1px solid var(--c-border);
  }
  .rev-card__name { font-size: 0.9375rem; font-weight: 500; color: var(--c-ink); }
  .rev-card__from { color: var(--c-ink-3); margin-top: 2px; }
  .rev-card__stars { color: var(--c-sand); font-size: 0.75rem; letter-spacing: 0.1em; flex-shrink: 0; }

  [data-anim="rev-head"] { opacity: 0; }
  [data-anim="rev-card"] { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    [data-anim="rev-head"], [data-anim="rev-card"] { opacity: 1 !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.set('[data-anim="rev-head"]', { y: 20 });
    gsap.set('[data-anim="rev-card"]', { y: 28 });
    gsap.to('[data-anim="rev-head"]', { opacity: 1, y: 0, duration: 0.8, scrollTrigger: { trigger: '.reviews__head', start: 'top 85%' } });
    gsap.to('[data-anim="rev-card"]', { opacity: 1, y: 0, duration: 0.75, stagger: 0.12, scrollTrigger: { trigger: '.reviews__grid', start: 'top 82%' } });
  });
</script>
