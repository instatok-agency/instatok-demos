---
---
<header class="hero" aria-label="Hero">

  <div class="hero__bg-wrap">
    <div class="hero__bg-clip" data-anim="hero-photo">
      <img
        src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=1600&q=85&fit=crop"
        alt="Theodoraki Apartment"
        class="hero__bg-img"
        width="1600" height="900"
        loading="eager"
      />
    </div>
    <div class="hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="hero__content">
    <div class="hero__inner ed-inner">

      <nav class="hero__nav" data-anim="hero-nav">
        <p class="eyebrow" style="color:rgba(246,241,232,0.6);">Theodoraki Stays</p>
        <a href="#booking" class="hero__book-btn">Κράτηση</a>
      </nav>

      <div class="hero__copy">
        <p class="eyebrow hero__location" data-anim="hero-eyebrow" style="color:rgba(246,241,232,0.55);">
          Κολωνάκι · Αθήνα · 2 Υπνοδωμάτια
        </p>
        <h1 class="hero__hl">
          <span class="line-wrap"><span data-anim="hl">Ένα διαμέρισμα</span></span>
          <span class="line-wrap"><span data-anim="hl">που <em>νιώθεις</em></span></span>
          <span class="line-wrap"><span data-anim="hl">δικό σου.</span></span>
        </h1>
        <div class="hero__meta" data-anim="hero-meta">
          <span class="hero__stat"><span class="hero__stat-n">85</span>m²</span>
          <span class="hero__divider" aria-hidden="true">·</span>
          <span class="hero__stat"><span class="hero__stat-n">2</span> υπνοδ.</span>
          <span class="hero__divider" aria-hidden="true">·</span>
          <span class="hero__stat">έως <span class="hero__stat-n">4</span> άτομα</span>
        </div>
      </div>

    </div>
  </div>

</header>

<style>
  .hero {
    position: relative; height: 100svh; min-height: 560px;
    display: flex; flex-direction: column;
  }

  .hero__bg-wrap { position: absolute; inset: 0; z-index: 0; }
  .hero__bg-clip { height: 100%; }
  .hero__bg-img { width: 100%; height: 100%; object-fit: cover; }
  .hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(20,16,12,0.25) 0%,
      rgba(20,16,12,0.05) 40%,
      rgba(20,16,12,0.55) 75%,
      rgba(20,16,12,0.80) 100%
    );
  }

  .hero__content {
    position: relative; z-index: 2;
    flex: 1; display: flex; flex-direction: column;
  }
  .hero__inner {
    flex: 1; display: flex; flex-direction: column;
    justify-content: space-between;
    padding-block: clamp(1.5rem, 4vw, 2.5rem);
  }

  .hero__nav {
    display: flex; align-items: center;
    justify-content: space-between;
  }
  .hero__book-btn {
    font-family: var(--f-body); font-size: 0.75rem; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(246,241,232,0.9);
    padding: 0.6rem 1.25rem;
    border: 1px solid rgba(246,241,232,0.35);
    border-radius: var(--r-sm);
    transition: background 0.2s, border-color 0.2s;
  }
  .hero__book-btn:hover {
    background: rgba(246,241,232,0.12);
    border-color: rgba(246,241,232,0.6);
  }

  .hero__copy { display: grid; gap: var(--s-5); }
  .hero__location { margin-bottom: var(--s-1); }

  .hero__hl {
    font-family: var(--f-display); font-weight: 400;
    font-size: clamp(3rem, 8vw, 7.5rem);
    line-height: 1.0; letter-spacing: -0.025em;
    color: #F6F1E8;
  }
  .hero__hl [data-anim="hl"] { display: block; }
  .hero__hl em { font-style: italic; color: var(--c-sand-2); }

  .hero__meta {
    display: flex; align-items: center; gap: var(--s-4); flex-wrap: wrap;
    font-family: var(--f-display); font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 300; color: rgba(246,241,232,0.65);
  }
  .hero__stat-n { font-weight: 500; color: rgba(246,241,232,0.9); }
  .hero__divider { color: rgba(246,241,232,0.3); }

  /* Pre-hide */
  .hero__bg-clip       { clip-path: inset(0 0 100% 0); }
  [data-anim="hero-nav"],
  [data-anim="hero-eyebrow"],
  [data-anim="hero-meta"] { opacity: 0; }
  [data-anim="hl"]      { display: block; }

  @media (prefers-reduced-motion: reduce) {
    .hero__bg-clip { clip-path: inset(0 0 0% 0) !important; }
    [data-anim="hero-nav"],
    [data-anim="hero-eyebrow"],
    [data-anim="hero-meta"] { opacity: 1 !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { initGSAP } from '../../../scripts/gsap-bnb-editorial';
  initGSAP();

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.set('[data-anim="hl"]', { yPercent: 110 });

    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl
      .to('.hero__bg-clip',          { clipPath: 'inset(0 0 0% 0)', duration: 1.6, ease: 'power4.inOut' }, 0)
      .to('[data-anim="hero-nav"]',  { opacity: 1, duration: 0.7 }, 0.6)
      .to('[data-anim="hero-eyebrow"]', { opacity: 1, duration: 0.6 }, 0.8)
      .to('[data-anim="hl"]',        { yPercent: 0, stagger: 0.12, duration: 1.05 }, 0.9)
      .to('[data-anim="hero-meta"]', { opacity: 1, duration: 0.7 }, 1.4);
  });
</script>
