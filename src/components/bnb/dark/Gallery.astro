---
---
<section class="dk-gallery" id="gallery" aria-label="Φωτογραφίες">

  <div class="dk-gallery__head dk-inner" data-anim="dk-gal-head">
    <p class="eyebrow">Χώρος</p>
    <h2 class="dk-section-title">Κάθε λεπτομέρεια<br>μετράει.</h2>
  </div>

  <div class="dk-gallery__grid dk-inner" data-anim="dk-gal-grid">
    <div class="dk-gal-main">
      <img src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=1200&q=80"
        alt="Κεντρικός χώρος με minimal design" class="dk-gal-img" width="1200" height="800" loading="lazy" />
    </div>
    <div class="dk-gal-side">
      <div class="dk-gal-item">
        <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=80"
          alt="Κουζίνα" class="dk-gal-img" width="800" height="600" loading="lazy" />
      </div>
      <div class="dk-gal-item">
        <img src="https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?w=800&q=80"
          alt="Υπνοδωμάτιο" class="dk-gal-img" width="800" height="600" loading="lazy" />
      </div>
    </div>
    <div class="dk-gal-wide">
      <img src="https://images.unsplash.com/photo-1567767292278-a4f21aa2d36e?w=1400&q=80"
        alt="Ιδιωτική ταράτσα με θέα" class="dk-gal-img" width="1400" height="600" loading="lazy" />
      <div class="dk-gal-wide__caption">
        <span class="eyebrow">Ιδιωτική ταράτσα · 20m²</span>
      </div>
    </div>
    <div class="dk-gal-pair">
      <div class="dk-gal-item">
        <img src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?w=800&q=80"
          alt="Μπάνιο" class="dk-gal-img" width="800" height="700" loading="lazy" />
      </div>
      <div class="dk-gal-item">
        <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=80"
          alt="Γραφείο εργασίας" class="dk-gal-img" width="800" height="700" loading="lazy" />
      </div>
    </div>
  </div>

</section>

<style>
  .dk-gallery { background: var(--c-bg); padding-block: var(--s-9); }

  .dk-gallery__head { display: grid; gap: var(--s-4); margin-bottom: var(--s-7); }

  .dk-section-title {
    font-family: var(--f-display);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700; letter-spacing: -0.02em;
    color: var(--c-cream); line-height: 1.1;
  }

  .dk-gallery__grid { display: grid; gap: var(--s-3); }

  .dk-gal-main, .dk-gal-item, .dk-gal-wide { overflow: hidden; border-radius: var(--r-md); }
  .dk-gal-main { height: clamp(220px, 40vw, 480px); }

  .dk-gal-side {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-3);
  }
  .dk-gal-side .dk-gal-item { height: clamp(140px, 22vw, 260px); }

  .dk-gal-wide {
    position: relative;
    height: clamp(180px, 28vw, 340px);
  }
  .dk-gal-wide__caption {
    position: absolute; bottom: var(--s-4); left: var(--s-5);
    background: rgba(12,11,9,0.7); backdrop-filter: blur(6px);
    padding: 0.375rem 0.875rem; border-radius: var(--r-sm);
    border: 1px solid var(--c-border);
  }

  .dk-gal-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-3);
  }
  .dk-gal-pair .dk-gal-item { height: clamp(140px, 20vw, 240px); }

  .dk-gal-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .dk-gal-main:hover .dk-gal-img,
  .dk-gal-item:hover .dk-gal-img,
  .dk-gal-wide:hover .dk-gal-img { transform: scale(1.03); }

  @media (min-width: 860px) {
    .dk-gallery__grid {
      grid-template-columns: 7fr 5fr;
      grid-template-rows: auto auto auto;
    }
    .dk-gal-main { height: clamp(320px, 40vw, 500px); }
    .dk-gal-side { grid-template-columns: 1fr; grid-column: 2; }
    .dk-gal-side .dk-gal-item { height: 50%; }
    .dk-gal-wide { grid-column: 1 / -1; }
    .dk-gal-pair { grid-column: 1 / -1; grid-template-columns: 1fr 1fr; }
    .dk-gal-pair .dk-gal-item { height: clamp(180px, 22vw, 280px); }
  }

  [data-anim="dk-gal-head"], [data-anim="dk-gal-grid"] { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    [data-anim="dk-gal-head"], [data-anim="dk-gal-grid"] { opacity: 1 !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.to('[data-anim="dk-gal-head"]', { opacity: 1, duration: 0.7, scrollTrigger: { trigger: '.dk-gallery__head', start: 'top 85%' } });
    gsap.to('[data-anim="dk-gal-grid"]', { opacity: 1, duration: 0.8, scrollTrigger: { trigger: '.dk-gallery__grid', start: 'top 82%' } });
  });
</script>
