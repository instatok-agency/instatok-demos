---
---
<header class="dk-hero">
  <nav class="dk-nav dk-inner">
    <span class="eyebrow" data-anim="dk-nav">ROOM 12</span>
    <a href="#booking" class="dk-nav__cta" data-anim="dk-nav">Κλείσε τώρα</a>
  </nav>

  <div class="dk-hero__body dk-inner">
    <p class="eyebrow dk-hero__eyebrow" data-anim="dk-eyebrow">ΚΕΡΑΜΕΙΚΟΣ · ΑΘΗΝΑ · 40m²</p>

    <h1 class="dk-hero__title" aria-label="Ένα δωμάτιο. Η πόλη. Όλα.">
      <span class="line-wrap"><span class="dk-hl" data-anim="dk-hl">Ένα δωμάτιο.</span></span>
      <span class="line-wrap"><span class="dk-hl" data-anim="dk-hl">Η πόλη.</span></span>
      <span class="line-wrap"><span class="dk-hl" data-anim="dk-hl"><span class="dk-amber">Όλα.</span></span></span>
    </h1>

    <p class="dk-hero__sub" data-anim="dk-sub">
      Boutique studio με ιδιωτική ταράτσα. Design σε κάθε λεπτομέρεια. Κεντρική Αθήνα.
    </p>

    <div class="dk-hero__ctas" data-anim="dk-ctas">
      <a href="#booking" class="dk-btn dk-btn--fill">Κλείσε τώρα</a>
      <a href="#gallery" class="dk-btn dk-btn--ghost">Δες φωτογραφίες</a>
    </div>
  </div>

  <div class="dk-hero__photo-wrap" data-anim="dk-photo">
    <img
      src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=1600&q=80"
      alt="ROOM 12 interior — minimal dark studio"
      class="dk-hero__photo"
      width="1600" height="900"
      loading="eager"
    />
    <div class="dk-hero__photo-vignette" aria-hidden="true"></div>
  </div>

  <div class="dk-hero__meta dk-inner" data-anim="dk-meta">
    <span class="dk-meta-item">40 m²</span>
    <span class="dk-meta-sep" aria-hidden="true">·</span>
    <span class="dk-meta-item">Ιδιωτική ταράτσα</span>
    <span class="dk-meta-sep" aria-hidden="true">·</span>
    <span class="dk-meta-item">Check-in 24/7</span>
    <span class="dk-meta-sep" aria-hidden="true">·</span>
    <span class="dk-meta-item">Pet-friendly</span>
  </div>
</header>

<style>
  .dk-hero { background: var(--c-bg); position: relative; overflow: hidden; }

  .dk-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 1.25rem; padding-bottom: 1.25rem;
    background: linear-gradient(to bottom, rgba(12,11,9,0.95) 0%, rgba(12,11,9,0) 100%);
  }
  .dk-nav__cta {
    font-family: var(--f-sans); font-size: 0.5625rem;
    font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--c-amber); border: 1px solid rgba(59,130,246,0.35);
    padding: 0.4rem 1.1rem; border-radius: var(--r-sm);
    transition: background 0.2s, border-color 0.2s;
  }
  .dk-nav__cta:hover { background: rgba(59,130,246,0.12); border-color: var(--c-amber); }

  [data-anim="dk-nav"] { opacity: 0; }

  .dk-hero__body {
    position: relative; z-index: 2;
    padding-top: clamp(7rem, 14vh, 11rem);
    padding-bottom: var(--s-8);
    display: grid; gap: var(--s-5);
  }

  .dk-hero__eyebrow { opacity: 0; }

  .dk-hero__title {
    font-family: var(--f-display);
    font-size: clamp(3.5rem, 8vw, 8rem);
    font-weight: 700; letter-spacing: -0.02em;
    color: var(--c-cream); line-height: 1.0;
  }
  .dk-hl { display: block; opacity: 0; }
  .dk-amber { color: var(--c-amber); }

  .dk-hero__sub {
    font-family: var(--f-body); font-size: 1rem;
    font-weight: 400; line-height: 1.7;
    color: var(--c-cream-2); max-width: 34rem;
    opacity: 0;
  }

  .dk-hero__ctas {
    display: flex; gap: var(--s-3); flex-wrap: wrap;
    padding-top: var(--s-2);
    opacity: 0;
  }

  .dk-btn {
    font-family: var(--f-sans); font-size: 0.625rem;
    font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    padding: 0.875rem 2rem; border-radius: var(--r-sm);
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .dk-btn--fill {
    background: var(--c-amber); color: #fff;
    border: 1px solid var(--c-amber);
  }
  .dk-btn--fill:hover { background: var(--c-amber-2); border-color: var(--c-amber-2); }
  .dk-btn--ghost {
    background: transparent; color: var(--c-cream-2);
    border: 1px solid var(--c-border-2);
  }
  .dk-btn--ghost:hover { border-color: var(--c-cream-2); color: var(--c-cream); }

  .dk-hero__photo-wrap {
    position: relative; width: 100%; height: clamp(280px, 55vh, 640px);
    overflow: hidden;
    clip-path: inset(0 0 100% 0);
  }
  .dk-hero__photo {
    width: 100%; height: 100%; object-fit: cover;
    object-position: center;
  }
  .dk-hero__photo-vignette {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(12,11,9,0.3) 0%, rgba(12,11,9,0) 60%, rgba(12,11,9,0.55) 100%);
  }

  .dk-hero__meta {
    display: flex; align-items: center; gap: var(--s-4); flex-wrap: wrap;
    padding-block: var(--s-5);
    border-top: 1px solid var(--c-border);
    opacity: 0;
  }
  .dk-meta-item {
    font-family: var(--f-sans); font-size: 0.5625rem;
    font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--c-cream-3);
  }
  .dk-meta-sep { color: var(--c-border-2); }

  @media (prefers-reduced-motion: reduce) {
    [data-anim="dk-nav"],
    .dk-hero__eyebrow,
    .dk-hl,
    .dk-hero__sub,
    .dk-hero__ctas,
    .dk-hero__meta { opacity: 1 !important; }
    .dk-hero__photo-wrap { clip-path: none !important; }
  }
</style>

<script>
  import { initGSAP } from '../../../scripts/gsap-bnb-dark';
  import { gsap } from 'gsap';
  initGSAP();

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    const tl = gsap.timeline({ defaults: { ease: 'expo.out' } });

    tl.to('.dk-hero__photo-wrap', { clipPath: 'inset(0 0 0% 0)', duration: 1.4, ease: 'power4.inOut' }, 0)
      .to('[data-anim="dk-nav"]', { opacity: 1, duration: 0.6, stagger: 0.08 }, 0.3)
      .to('.dk-hero__eyebrow', { opacity: 1, duration: 0.5 }, 0.5)
      .to('.dk-hl', { opacity: 1, duration: 0.55, stagger: 0.08 }, 0.65)
      .to('.dk-hero__sub', { opacity: 1, duration: 0.5 }, 1.0)
      .to('.dk-hero__ctas', { opacity: 1, duration: 0.5 }, 1.1)
      .to('.dk-hero__meta', { opacity: 1, duration: 0.5 }, 1.25);
  });
</script>
