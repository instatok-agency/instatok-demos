---
const reviews = [
  {
    quote: 'Η ταράτσα την αξίζει μόνη της. Πίναμε καφέ κάθε πρωί με θέα στην Ακρόπολη. Θα ξαναρθούμε σίγουρα.',
    name: 'Αλέξης & Μαρία',
    from: 'Θεσσαλονίκη',
    stays: '5 διανυκτερεύσεις',
    stars: 5,
  },
  {
    quote: 'Remote worker για 3 εβδομάδες. Το γραφείο ήταν τέλειο, το WiFi γρήγορο, και ο Κεραμεικός ήταν ακριβώς αυτό που ήθελα.',
    name: 'Κατερίνα Π.',
    from: 'Βερολίνο',
    stays: '21 διανυκτερεύσεις',
    stars: 5,
  },
  {
    quote: 'Ο καλύτερος χώρος που έχω νοικιάσει σε ταξίδια μου. Design, λεπτομέρεια, και host που ανταποκρίνεται αμέσως.',
    name: 'Στέφαν Μ.',
    from: 'Παρίσι',
    stays: '7 διανυκτερεύσεις',
    stars: 5,
  },
];
---

<section class="dk-rev" aria-label="Κριτικές">
  <div class="dk-rev__inner dk-inner">

    <div class="dk-rev__head" data-anim="dk-rev-head">
      <p class="eyebrow">Κριτικές</p>
      <h2 class="dk-section-title">Τι λένε.</h2>
      <div class="dk-rev__score">
        <span class="dk-rev__score-n">4.97</span>
        <div class="dk-rev__score-r">
          <span class="dk-rev__stars">★★★★★</span>
          <span class="eyebrow">89 κριτικές</span>
        </div>
      </div>
    </div>

    <div class="dk-rev__grid">
      {reviews.map((r) => (
        <blockquote class="dk-rev-card" data-anim="dk-rev-card">
          <p class="dk-rev-card__quote">"{r.quote}"</p>
          <footer class="dk-rev-card__foot">
            <div>
              <p class="dk-rev-card__name">{r.name}</p>
              <p class="eyebrow" style="color:var(--c-cream-3); margin-top:2px;">{r.from} · {r.stays}</p>
            </div>
            <span class="dk-rev-card__stars">{'★'.repeat(r.stars)}</span>
          </footer>
        </blockquote>
      ))}
    </div>

  </div>
</section>

<style>
  .dk-rev { background: var(--c-bg); padding-block: var(--s-9); }
  .dk-rev__inner { display: grid; gap: var(--s-8); }

  .dk-rev__head { display: grid; gap: var(--s-4); }

  .dk-section-title {
    font-family: var(--f-display);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700; letter-spacing: -0.02em;
    color: var(--c-cream); line-height: 1.1;
  }

  .dk-rev__score { display: flex; align-items: center; gap: var(--s-4); }
  .dk-rev__score-n {
    font-family: var(--f-display); font-size: 3rem;
    font-weight: 700; color: var(--c-amber);
  }
  .dk-rev__score-r { display: grid; gap: 2px; }
  .dk-rev__stars { color: var(--c-amber); font-size: 0.875rem; letter-spacing: 0.1em; }

  .dk-rev__grid {
    display: grid; gap: var(--s-4);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 22rem), 1fr));
  }

  .dk-rev-card {
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-radius: var(--r-lg); padding: var(--s-6);
    display: flex; flex-direction: column; gap: var(--s-5);
    transition: border-color 0.25s;
  }
  .dk-rev-card:hover { border-color: rgba(212,168,67,0.3); }

  .dk-rev-card__quote {
    font-family: var(--f-body); font-style: italic;
    font-size: 0.9375rem; line-height: 1.75;
    color: var(--c-cream-2); flex: 1;
  }

  .dk-rev-card__foot {
    display: flex; align-items: flex-end;
    justify-content: space-between; gap: var(--s-3);
    padding-top: var(--s-4); border-top: 1px solid var(--c-border);
  }
  .dk-rev-card__name {
    font-family: var(--f-display); font-size: 0.9375rem;
    font-weight: 600; color: var(--c-cream);
  }
  .dk-rev-card__stars { color: var(--c-amber); font-size: 0.6875rem; letter-spacing: 0.08em; flex-shrink: 0; }

  [data-anim="dk-rev-head"] { opacity: 0; }
  [data-anim="dk-rev-card"] { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    [data-anim="dk-rev-head"], [data-anim="dk-rev-card"] { opacity: 1 !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.to('[data-anim="dk-rev-head"]', { opacity: 1, duration: 0.7, scrollTrigger: { trigger: '.dk-rev__head', start: 'top 85%' } });
    gsap.to('[data-anim="dk-rev-card"]', { opacity: 1, duration: 0.7, stagger: 0.1, scrollTrigger: { trigger: '.dk-rev__grid', start: 'top 82%' } });
  });
</script>
