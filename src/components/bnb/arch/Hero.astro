---
---
<header class="ar-hero">

  <nav class="ar-nav ar-inner" data-anim="ar-nav">
    <span class="eyebrow eyebrow--white">Αρχόντισσα</span>
    <a href="#booking" class="ar-nav__cta">Κράτηση</a>
  </nav>

  <div class="ar-hero__body ar-inner">
    <p class="eyebrow eyebrow--white ar-hero__eyebrow" data-anim="ar-eyebrow">
      ΑΝΩ ΣΥΡΟΣ · ΚΥΚΛΑΔΕΣ · 1847
    </p>

    <h1 class="ar-hero__title">
      <span class="line-wrap"><span class="ar-hl" data-anim="ar-hl">Αρχόντισσα.</span></span>
    </h1>

    <p class="ar-hero__sub" data-anim="ar-sub">
      Κυκλαδική αρχοντική κατοικία του 19ου αιώνα. Τρία υπνοδωμάτια, θέα στο Αιγαίο, ιδιωτική αυλή.
    </p>

    <div class="ar-hero__ctas" data-anim="ar-ctas">
      <a href="#booking" class="ar-btn ar-btn--white">Ζητήστε κράτηση</a>
      <a href="#gallery" class="ar-btn ar-btn--ghost">Δείτε φωτογραφίες</a>
    </div>
  </div>

  <div class="ar-hero__photo-band" data-anim="ar-photo">
    <img
      src="https://images.unsplash.com/photo-1555990793-da11153b4077?w=1800&q=85&fit=crop"
      alt="Θέα Αιγαίου από Άνω Σύρο"
      class="ar-hero__photo"
      width="1800" height="800"
      loading="eager"
    />
    <div class="ar-hero__photo-overlay" aria-hidden="true"></div>
  </div>

  <div class="ar-hero__meta ar-inner" data-anim="ar-meta">
    <div class="ar-meta-spec">
      <span class="ar-meta-n">3</span>
      <span class="eyebrow">υπνοδωμ.</span>
    </div>
    <span class="ar-meta-rule" aria-hidden="true"></span>
    <div class="ar-meta-spec">
      <span class="ar-meta-n">160</span>
      <span class="eyebrow">τ.μ.</span>
    </div>
    <span class="ar-meta-rule" aria-hidden="true"></span>
    <div class="ar-meta-spec">
      <span class="ar-meta-n">6</span>
      <span class="eyebrow">άτομα</span>
    </div>
    <span class="ar-meta-rule" aria-hidden="true"></span>
    <div class="ar-meta-spec">
      <span class="ar-meta-n">1847</span>
      <span class="eyebrow">έτος</span>
    </div>
  </div>

</header>

<style>
  .ar-hero { background: var(--c-sea); }

  .ar-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 1.25rem; padding-bottom: 1.25rem;
    background: linear-gradient(to bottom, rgba(27,64,128,0.9) 0%, rgba(27,64,128,0) 100%);
  }
  [data-anim="ar-nav"] { opacity: 0; }

  .ar-nav__cta {
    font-family: var(--f-body); font-size: 0.5625rem;
    font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase;
    color: #fff; border: 1px solid rgba(255,255,255,0.35);
    padding: 0.4rem 1.1rem; border-radius: var(--r-sm);
    transition: background 0.2s, border-color 0.2s;
  }
  .ar-nav__cta:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.7); }

  .ar-hero__body {
    position: relative; z-index: 2;
    padding-top: clamp(8rem, 16vh, 13rem);
    padding-bottom: var(--s-8);
    display: grid; gap: var(--s-5);
    max-width: 56rem;
  }

  .ar-hero__eyebrow { opacity: 0; }

  .ar-hero__title {
    font-family: var(--f-display); font-style: italic;
    font-size: clamp(4rem, 9vw, 9rem);
    font-weight: 500; letter-spacing: -0.02em;
    color: #fff; line-height: 1.0;
  }
  .ar-hl { display: block; opacity: 0; }

  .ar-hero__sub {
    font-family: var(--f-body); font-size: 1.0625rem;
    font-weight: 300; line-height: 1.75;
    color: var(--c-on-sea); max-width: 38rem;
    opacity: 0;
  }

  .ar-hero__ctas {
    display: flex; gap: var(--s-3); flex-wrap: wrap;
    padding-top: var(--s-2); opacity: 0;
  }

  .ar-btn {
    font-family: var(--f-body); font-size: 0.5625rem;
    font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase;
    padding: 0.875rem 2rem; border-radius: var(--r-sm);
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .ar-btn--white {
    background: #fff; color: var(--c-sea);
    border: 1px solid #fff;
  }
  .ar-btn--white:hover { background: var(--c-on-sea); border-color: var(--c-on-sea); }
  .ar-btn--ghost {
    background: transparent; color: rgba(255,255,255,0.75);
    border: 1px solid rgba(255,255,255,0.3);
  }
  .ar-btn--ghost:hover { border-color: rgba(255,255,255,0.7); color: #fff; }

  .ar-hero__photo-band {
    position: relative; overflow: hidden;
    height: clamp(260px, 42vh, 560px);
    clip-path: inset(0 0 100% 0);
  }
  .ar-hero__photo { width: 100%; height: 100%; object-fit: cover; object-position: center 40%; }
  .ar-hero__photo-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(27,64,128,0.25) 0%, rgba(27,64,128,0) 50%);
  }

  .ar-hero__meta {
    display: flex; align-items: center; gap: var(--s-6); flex-wrap: wrap;
    padding-block: var(--s-6);
    background: var(--c-bg);
    opacity: 0;
  }
  .ar-meta-spec { display: flex; align-items: baseline; gap: var(--s-2); }
  .ar-meta-n {
    font-family: var(--f-display); font-style: italic;
    font-size: 1.5rem; font-weight: 400; color: var(--c-sea); line-height: 1;
  }
  .ar-meta-rule {
    width: 1px; height: 1.25rem; background: var(--c-border-2); flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-anim="ar-nav"],
    .ar-hero__eyebrow,
    .ar-hl,
    .ar-hero__sub,
    .ar-hero__ctas,
    .ar-hero__meta { opacity: 1 !important; }
    .ar-hero__photo-band { clip-path: none !important; }
  }
</style>

<script>
  import { initGSAP } from '../../../scripts/gsap-bnb-arch';
  import { gsap } from 'gsap';
  initGSAP();

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    tl.to('.ar-hero__photo-band', { clipPath: 'inset(0 0 0% 0)', duration: 1.5, ease: 'power4.inOut' }, 0)
      .to('[data-anim="ar-nav"]',    { opacity: 1, duration: 0.6 }, 0.3)
      .to('.ar-hero__eyebrow',       { opacity: 1, duration: 0.5 }, 0.5)
      .to('.ar-hl',                  { opacity: 1, y: 0, duration: 1.0 }, 0.65)
      .to('.ar-hero__sub',           { opacity: 1, duration: 0.6 }, 1.0)
      .to('.ar-hero__ctas',          { opacity: 1, duration: 0.5 }, 1.1)
      .to('.ar-hero__meta',          { opacity: 1, duration: 0.6 }, 1.3);
  });
</script>
