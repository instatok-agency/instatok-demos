---
---
<section class="ar-gallery" id="gallery" aria-label="Φωτογραφίες">
  <div class="ar-gallery__head ar-inner" data-anim="ar-gal-head">
    <p class="eyebrow">Φωτογραφίες</p>
    <h2 class="ar-section-title">Ο χώρος.</h2>
  </div>

  <div class="ar-gallery__grid ar-inner" data-anim="ar-gal-grid">

    <div class="ar-gal-hero">
      <img src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1400&q=80"
        alt="Κεντρικό σαλόνι με θέα Αιγαίο" class="ar-gal-img" width="1400" height="900" loading="lazy" />
      <div class="ar-gal-hero__label">
        <span class="eyebrow">Σαλόνι · Θέα Αιγαίου</span>
      </div>
    </div>

    <div class="ar-gal-trio">
      <div class="ar-gal-item">
        <img src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?w=800&q=80"
          alt="Κυρίως υπνοδωμάτιο" class="ar-gal-img" width="800" height="600" loading="lazy" />
        <span class="ar-gal-caption eyebrow">Κυρίως υπνοδωμάτιο</span>
      </div>
      <div class="ar-gal-item">
        <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=80"
          alt="Κουζίνα" class="ar-gal-img" width="800" height="600" loading="lazy" />
        <span class="ar-gal-caption eyebrow">Κουζίνα</span>
      </div>
      <div class="ar-gal-item">
        <img src="https://images.unsplash.com/photo-1600566753086-00f18fb6b3ea?w=800&q=80"
          alt="Εξωτερικός χώρος" class="ar-gal-img" width="800" height="600" loading="lazy" />
        <span class="ar-gal-caption eyebrow">Ιδιωτική αυλή</span>
      </div>
    </div>

    <div class="ar-gal-wide">
      <img src="https://images.unsplash.com/photo-1524230572899-a752b3835840?w=1600&q=80"
        alt="Εξωτερική αρχιτεκτονική" class="ar-gal-img" width="1600" height="700" loading="lazy" />
      <div class="ar-gal-wide__label">
        <span class="eyebrow">Κυκλαδική αρχιτεκτονική · 1847</span>
      </div>
    </div>

  </div>
</section>

<style>
  .ar-gallery { background: var(--c-bg-2); padding-block: var(--s-9); }

  .ar-gallery__head { display: grid; gap: var(--s-4); margin-bottom: var(--s-7); }

  .ar-section-title {
    font-family: var(--f-display);
    font-size: clamp(2rem, 5vw, 4.5rem);
    font-weight: 400; font-style: italic;
    letter-spacing: -0.02em;
    color: var(--c-ink); line-height: 1.0;
  }

  .ar-gallery__grid { display: grid; gap: var(--s-3); }

  .ar-gal-hero {
    position: relative; border-radius: var(--r-lg); overflow: hidden;
    height: clamp(240px, 40vw, 520px);
  }
  .ar-gal-hero__label {
    position: absolute; bottom: var(--s-4); left: var(--s-5);
    background: rgba(249,248,245,0.9); backdrop-filter: blur(4px);
    padding: 0.375rem 0.875rem; border-radius: var(--r-sm);
  }

  .ar-gal-trio {
    display: grid; gap: var(--s-3);
    grid-template-columns: 1fr 1fr 1fr;
  }

  .ar-gal-item { display: grid; gap: var(--s-2); }
  .ar-gal-item > div, .ar-gal-trio .ar-gal-item { overflow: hidden; border-radius: var(--r-md); }
  .ar-gal-trio .ar-gal-item { display: grid; gap: var(--s-2); }
  .ar-gal-trio .ar-gal-item > .ar-gal-img {
    border-radius: var(--r-md); height: clamp(120px, 18vw, 220px); width: 100%; object-fit: cover;
    transition: transform 0.5s ease;
  }
  .ar-gal-trio .ar-gal-item:hover > .ar-gal-img { transform: scale(1.03); }

  .ar-gal-caption { margin-top: var(--s-1); color: var(--c-ink-3); }

  .ar-gal-wide {
    position: relative; border-radius: var(--r-lg); overflow: hidden;
    height: clamp(180px, 28vw, 360px);
  }
  .ar-gal-wide__label {
    position: absolute; bottom: var(--s-4); right: var(--s-5);
    background: rgba(249,248,245,0.9); backdrop-filter: blur(4px);
    padding: 0.375rem 0.875rem; border-radius: var(--r-sm);
  }

  .ar-gal-hero .ar-gal-img,
  .ar-gal-wide .ar-gal-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s ease;
  }
  .ar-gal-hero:hover .ar-gal-img,
  .ar-gal-wide:hover .ar-gal-img { transform: scale(1.02); }

  @media (max-width: 640px) {
    .ar-gal-trio { grid-template-columns: 1fr 1fr; }
    .ar-gal-trio .ar-gal-item:last-child { display: none; }
  }

  [data-anim="ar-gal-head"] { opacity: 0; filter: blur(4px); }
  [data-anim="ar-gal-grid"] { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    [data-anim="ar-gal-head"], [data-anim="ar-gal-grid"] { opacity: 1 !important; filter: none !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.to('[data-anim="ar-gal-head"]', { opacity: 1, filter: 'blur(0px)', duration: 0.8, scrollTrigger: { trigger: '.ar-gallery__head', start: 'top 85%' } });
    gsap.to('[data-anim="ar-gal-grid"]', { opacity: 1, duration: 0.85, scrollTrigger: { trigger: '.ar-gallery__grid', start: 'top 82%' } });
  });
</script>
