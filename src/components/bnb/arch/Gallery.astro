---
---
<section class="ar-gallery" id="gallery" aria-label="Φωτογραφίες">
  <div class="ar-gallery__head ar-inner" data-anim="ar-gal-head">
    <p class="eyebrow">Φωτογραφίες</p>
    <h2 class="ar-sec-title">Ο χώρος.</h2>
  </div>

  <div class="ar-gallery__grid ar-inner" data-anim="ar-gal-grid">

    <div class="ar-gal-hero">
      <img src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=1400&q=85"
        alt="Κύριος χώρος με θέα Αιγαίο" class="ar-gal-img" width="1400" height="800" loading="lazy" />
      <div class="ar-gal-label"><span class="eyebrow">Σαλόνι · Θέα Αιγαίου</span></div>
    </div>

    <div class="ar-gal-side">
      <div class="ar-gal-item">
        <img src="https://images.unsplash.com/photo-1524231757912-21f4fe3a7200?w=900&q=80"
          alt="Κυκλαδικό εξωτερικό" class="ar-gal-img" width="900" height="700" loading="lazy" />
        <span class="eyebrow ar-gal-cap">Εξωτερικό</span>
      </div>
      <div class="ar-gal-item">
        <img src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?w=900&q=80"
          alt="Κυρίως υπνοδωμάτιο" class="ar-gal-img" width="900" height="700" loading="lazy" />
        <span class="eyebrow ar-gal-cap">Κυρίως υπνοδωμάτιο</span>
      </div>
    </div>

    <div class="ar-gal-pair">
      <div class="ar-gal-item">
        <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=900&q=80"
          alt="Αυλή" class="ar-gal-img" width="900" height="700" loading="lazy" />
        <span class="eyebrow ar-gal-cap">Ιδιωτική αυλή</span>
      </div>
      <div class="ar-gal-item">
        <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=900&q=80"
          alt="Κουζίνα" class="ar-gal-img" width="900" height="700" loading="lazy" />
        <span class="eyebrow ar-gal-cap">Κουζίνα</span>
      </div>
    </div>

    <div class="ar-gal-wide">
      <img src="https://images.unsplash.com/photo-1510798831971-661eb04b3739?w=1600&q=85"
        alt="Θέα Συρόπολη" class="ar-gal-img" width="1600" height="600" loading="lazy" />
      <div class="ar-gal-label ar-gal-label--right"><span class="eyebrow">Θέα Ερμούπολης · Άνω Σύρος</span></div>
    </div>

  </div>
</section>

<style>
  .ar-gallery { background: var(--c-bg); padding-block: var(--s-9); }

  .ar-gallery__head { display: grid; gap: var(--s-4); margin-bottom: var(--s-7); }

  .ar-sec-title {
    font-family: var(--f-display); font-style: italic;
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    font-weight: 400; letter-spacing: -0.02em;
    color: var(--c-sea); line-height: 1.0;
  }

  .ar-gallery__grid { display: grid; gap: var(--s-3); }

  .ar-gal-hero {
    position: relative; border-radius: var(--r-lg); overflow: hidden;
    height: clamp(240px, 42vw, 520px);
  }
  .ar-gal-label {
    position: absolute; bottom: var(--s-4); left: var(--s-5);
    background: rgba(255,255,255,0.92); backdrop-filter: blur(4px);
    padding: 0.375rem 0.875rem; border-radius: var(--r-sm);
    border: 1px solid var(--c-border);
  }
  .ar-gal-label--right { left: auto; right: var(--s-5); }

  .ar-gal-side {
    display: grid; gap: var(--s-3);
    grid-template-columns: 1fr 1fr;
  }

  .ar-gal-pair {
    display: grid; gap: var(--s-3);
    grid-template-columns: 1fr 1fr;
  }

  .ar-gal-wide {
    position: relative; border-radius: var(--r-lg); overflow: hidden;
    height: clamp(180px, 28vw, 380px);
  }

  .ar-gal-item { display: grid; gap: var(--s-2); }
  .ar-gal-side .ar-gal-item > .ar-gal-img,
  .ar-gal-pair .ar-gal-item > .ar-gal-img {
    border-radius: var(--r-md);
    height: clamp(140px, 20vw, 260px);
    width: 100%; object-fit: cover;
    transition: transform 0.55s ease;
  }
  .ar-gal-side .ar-gal-item:hover > .ar-gal-img,
  .ar-gal-pair .ar-gal-item:hover > .ar-gal-img { transform: scale(1.03); }

  .ar-gal-cap { color: var(--c-ink-3); }

  .ar-gal-hero .ar-gal-img,
  .ar-gal-wide .ar-gal-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s ease;
  }
  .ar-gal-hero:hover .ar-gal-img,
  .ar-gal-wide:hover .ar-gal-img { transform: scale(1.025); }

  @media (min-width: 860px) {
    .ar-gallery__grid {
      grid-template-columns: 7fr 5fr;
    }
    .ar-gal-hero { grid-row: 1; }
    .ar-gal-side { grid-column: 2; grid-row: 1; grid-template-columns: 1fr; }
    .ar-gal-side .ar-gal-item > .ar-gal-img { height: clamp(180px, 22vw, 280px); }
    .ar-gal-pair { grid-column: 1 / -1; grid-template-columns: 1fr 1fr; }
    .ar-gal-pair .ar-gal-item > .ar-gal-img { height: clamp(180px, 22vw, 280px); }
    .ar-gal-wide { grid-column: 1 / -1; }
  }

  [data-anim="ar-gal-head"] { opacity: 0; }
  [data-anim="ar-gal-grid"] { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    [data-anim="ar-gal-head"], [data-anim="ar-gal-grid"] { opacity: 1 !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.set('[data-anim="ar-gal-head"]', { y: 20 });
    gsap.set('[data-anim="ar-gal-grid"]', { y: 24 });
    gsap.to('[data-anim="ar-gal-head"]', { opacity: 1, y: 0, duration: 0.8, scrollTrigger: { trigger: '.ar-gallery__head', start: 'top 85%' } });
    gsap.to('[data-anim="ar-gal-grid"]', { opacity: 1, y: 0, duration: 0.85, scrollTrigger: { trigger: '.ar-gallery__grid', start: 'top 82%' } });
  });
</script>
