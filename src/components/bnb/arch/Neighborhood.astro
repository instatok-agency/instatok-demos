---
const places = [
  { name: 'Άνω Σύρος',      type: 'Μεσαιωνική πόλη · Καθολική',  dist: '2 λεπτά' },
  { name: 'Ερμούπολη',      type: 'Πρωτεύουσα · Λιμάνι · Εμπόριο', dist: '15 λεπτά' },
  { name: 'Γαλησσάς',       type: 'Παραλία · Θαλάσσια σπορ',      dist: '20 λεπτά' },
  { name: 'Κινί',           type: 'Ταβέρνες · Ψάρεμα',            dist: '18 λεπτά' },
  { name: 'Βαρί',           type: 'Ήσυχη παραλία',                dist: '25 λεπτά' },
  { name: 'Μύκονος',        type: 'Γειτονικό νησί (ferry)',        dist: '30 λεπτά' },
];
---

<section class="ar-nbhd" aria-label="Περιοχή">
  <div class="ar-nbhd__sea">
    <div class="ar-nbhd__sea-inner ar-inner">

      <div class="ar-nbhd__head" data-anim="ar-nbhd-head">
        <p class="eyebrow eyebrow--white">Γύρω μας</p>
        <h2 class="ar-nbhd__title">Σύρος.</h2>
        <p class="ar-nbhd__sub">
          Το κέντρο του Αιγαίου — κυριολεκτικά. Η πρωτεύουσα των Κυκλάδων, με ιστορία 4000 χρόνων, νεοκλασική αρχιτεκτονική και τα καλύτερα λουκούμια.
        </p>
      </div>

      <div class="ar-nbhd__grid" data-anim="ar-nbhd-grid">
        {places.map(p => (
          <div class="ar-nbhd__card">
            <div class="ar-nbhd__card-top">
              <p class="ar-nbhd__card-name">{p.name}</p>
              <span class="eyebrow eyebrow--sea">{p.dist}</span>
            </div>
            <p class="eyebrow eyebrow--white" style="opacity:0.5;">{p.type}</p>
          </div>
        ))}
      </div>

    </div>
  </div>

  <div class="ar-nbhd__map ar-inner" data-anim="ar-nbhd-map">
    <a href="https://maps.google.com" target="_blank" rel="noopener noreferrer" class="ar-nbhd__map-btn">
      Χάρτης →
    </a>
    <p class="eyebrow" style="color:var(--c-ink-3);">Πλατεία Μητρόπολης 5, Άνω Σύρος · Κυκλάδες 841 00</p>
  </div>
</section>

<style>
  .ar-nbhd__sea {
    background: var(--c-sea);
    padding-block: var(--s-9);
  }
  .ar-nbhd__sea-inner { display: grid; gap: var(--s-8); }

  .ar-nbhd__head { display: grid; gap: var(--s-4); }

  .ar-nbhd__title {
    font-family: var(--f-display); font-style: italic;
    font-size: clamp(3rem, 7vw, 7rem);
    font-weight: 400; letter-spacing: -0.02em;
    color: #fff; line-height: 1.0;
  }

  .ar-nbhd__sub {
    font-family: var(--f-body); font-size: 1rem;
    font-weight: 300; line-height: 1.8;
    color: var(--c-on-sea); max-width: 40rem;
  }

  .ar-nbhd__grid {
    display: grid; gap: 0;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    border-top: 1px solid rgba(255,255,255,0.15);
  }
  .ar-nbhd__card {
    padding: var(--s-5) var(--s-4);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    display: grid; gap: var(--s-2);
    transition: background 0.2s;
    cursor: default;
  }
  .ar-nbhd__card:hover { background: rgba(255,255,255,0.05); }
  .ar-nbhd__card-top {
    display: flex; align-items: baseline;
    justify-content: space-between; gap: var(--s-3);
  }
  .ar-nbhd__card-name {
    font-family: var(--f-display); font-style: italic;
    font-size: 1.125rem; font-weight: 400; color: #fff;
  }

  .ar-nbhd__map {
    display: flex; align-items: center; gap: var(--s-6); flex-wrap: wrap;
    padding-block: var(--s-6); border-bottom: 1px solid var(--c-border-2);
    background: var(--c-bg);
  }
  .ar-nbhd__map-btn {
    font-family: var(--f-body); font-size: 0.5625rem;
    font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--c-sea); border-bottom: 1px solid rgba(27,64,128,0.3);
    padding-bottom: 2px; transition: border-color 0.2s;
  }
  .ar-nbhd__map-btn:hover { border-color: var(--c-sea); }

  [data-anim="ar-nbhd-head"] { opacity: 0; }
  [data-anim="ar-nbhd-grid"] { opacity: 0; }
  [data-anim="ar-nbhd-map"]  { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    [data-anim="ar-nbhd-head"], [data-anim="ar-nbhd-grid"], [data-anim="ar-nbhd-map"] { opacity: 1 !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.set('[data-anim="ar-nbhd-head"]', { y: 20 });
    gsap.set('[data-anim="ar-nbhd-grid"]', { y: 20 });
    gsap.to('[data-anim="ar-nbhd-head"]', { opacity: 1, y: 0, duration: 0.8, scrollTrigger: { trigger: '.ar-nbhd__head', start: 'top 85%' } });
    gsap.to('[data-anim="ar-nbhd-grid"]', { opacity: 1, y: 0, duration: 0.85, scrollTrigger: { trigger: '.ar-nbhd__grid', start: 'top 82%' } });
    gsap.to('[data-anim="ar-nbhd-map"]',  { opacity: 1, duration: 0.6, scrollTrigger: { trigger: '[data-anim="ar-nbhd-map"]', start: 'top 88%' } });
  });
</script>
