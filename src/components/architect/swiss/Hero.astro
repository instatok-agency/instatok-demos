---
---
<header
  style="background-color:#0A0A0A; color:#FAFAFA; min-height:100dvh; display:flex; flex-direction:column; overflow:hidden;"
>
  <!-- Nav -->
  <nav
    style="display:flex; align-items:center; justify-content:space-between; padding:1.75rem 2.5rem; border-bottom:1px solid rgba(250,250,250,0.1); flex-shrink:0;"
  >
    <span
      style="font-size:0.6875rem; font-weight:600; letter-spacing:0.18em; color:#FAFAFA;"
    >VAS.</span>

    <div
      style="display:flex; gap:2rem; flex-wrap:wrap; justify-content:flex-end;"
    >
      {[
        ['Works', '#works'],
        ['Approach', '#approach'],
        ['Services', '#services'],
        ['Process', '#process'],
        ['Studio', '#studio'],
        ['Press', '#press'],
        ['Recognition', '#recognition'],
        ['Journal', '#journal'],
        ['Contact', '#contact'],
      ].map(([label, href]) => (
        <a
          href={href}
          style="font-size:0.625rem; font-weight:400; letter-spacing:0.14em; text-transform:uppercase; color:rgba(250,250,250,0.5); text-decoration:none; transition:color 0.2s;"
          onmouseover="this.style.color='#FAFAFA'"
          onmouseout="this.style.color='rgba(250,250,250,0.5)'"
        >{label}</a>
      ))}
    </div>
  </nav>

  <!-- Hero body -->
  <div
    style="flex:1; display:flex; flex-direction:column; justify-content:flex-end; padding:2.5rem 2.5rem 3rem;"
    class="hero-body"
  >
    <!-- Overline -->
    <p
      style="font-size:0.625rem; font-weight:400; letter-spacing:0.2em; text-transform:uppercase; color:rgba(250,250,250,0.4); margin-bottom:1.5rem;"
    >Αρχιτεκτονική Στούντιο</p>

    <!-- Wordmark -->
    <h1
      style="font-size:clamp(4.5rem, 14vw, 13rem); font-weight:200; letter-spacing:-0.03em; line-height:0.92; color:#FAFAFA; overflow:hidden;"
      class="hero-wordmark"
    >
      VASILIOU
    </h1>

    <!-- Hairline rule -->
    <div style="width:100%; height:1px; background:rgba(250,250,250,0.12); margin:2.5rem 0;"></div>

    <!-- Tagline + metadata row -->
    <div
      style="display:flex; flex-wrap:wrap; align-items:flex-end; justify-content:space-between; gap:1.5rem;"
    >
      <p
        style="font-size:clamp(1rem, 2.2vw, 1.375rem); font-weight:300; font-style:italic; color:rgba(250,250,250,0.75); max-width:36rem; line-height:1.45;"
      >
        Μορφή από υλικό.<br />Φως από διάνοια.
      </p>

      <div style="display:flex; flex-direction:column; gap:0.375rem; text-align:right;">
        {[
          'Ίδρυση 2013 · 12 χρόνια πρακτικής',
          '40+ ολοκληρωμένα έργα',
          'Μυκόνος · Πάρος · Σαντορίνη · Αθήνα · Καβάλα',
        ].map(line => (
          <p style="font-size:0.625rem; font-weight:400; letter-spacing:0.1em; color:rgba(250,250,250,0.35);">{line}</p>
        ))}
      </div>
    </div>
  </div>
</header>

<style>
  .hero-body {
    animation: hero-rise 1.1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-wordmark {
    clip-path: inset(0 0 0 0);
    animation: wordmark-reveal 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(1.5rem); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes wordmark-reveal {
    from { clip-path: inset(0 100% 0 0); }
    to   { clip-path: inset(0 0% 0 0); }
  }

  @media (max-width: 640px) {
    nav { padding: 1.25rem 1.25rem; gap: 1rem; }
    .hero-body { padding: 1.25rem 1.25rem 2rem; }
  }
</style>
