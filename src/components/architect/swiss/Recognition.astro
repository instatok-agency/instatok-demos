---
const awards = [
  { title: 'Βραβείο Ελληνικής Αρχιτεκτονικής',      org: 'ΤΕΕ',                   year: '2024' },
  { title: 'Best Residential Design',                  org: 'Dezeen Awards',          year: '2023' },
  { title: 'House of the Year — Shortlist',            org: 'Wallpaper*',             year: '2023' },
  { title: 'Mediterranean Architecture Prize',         org: 'Frame Magazine',         year: '2022' },
  { title: 'Best Greek Interior',                      org: 'ELLE Decoration GR',     year: '2022' },
  { title: 'Αρχιτεκτονική Αριστεία',                  org: 'Architectural Digest GR', year: '2021' },
  { title: 'Private House — Shortlist',                org: 'Architectural Review',   year: '2021' },
  { title: 'Honorable Mention, Residential',           org: 'Architectural Review',   year: '2020' },
  { title: 'Βραβείο Τοπίου',                          org: 'Topio Magazine',          year: '2020' },
  { title: 'Emerging Practice Award',                  org: 'ΣΑΑ',                   year: '2019' },
  { title: 'Cyclades Residential Award',               org: 'ΣΑΔΑΣ',                 year: '2019' },
  { title: 'Νέος Αρχιτέκτονας',                       org: 'ΤΕΕ',                   year: '2016' },
];
---

<section id="recognition" style="padding:6rem 0;">
  <div style="max-width:72rem; margin:0 auto; padding:0 2.5rem;">
    <!-- Section header -->
    <div style="display:flex; align-items:baseline; gap:1.5rem; margin-bottom:4rem; padding-bottom:1.5rem; border-bottom:1px solid #DCDCDC;">
      <span style="font-family:ui-monospace,'JetBrains Mono','Courier New',monospace; font-size:0.625rem; color:#ABABAB;">008</span>
      <h2 style="font-size:0.6875rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:#0A0A0A;">Αναγνώριση</h2>
    </div>

    <!-- Column labels -->
    <div style="display:grid; grid-template-columns:1fr auto auto; gap:1rem 2rem; padding:0 0 0.75rem; border-bottom:1px solid #DCDCDC; margin-bottom:0;">
      <span style="font-size:0.5rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:#ABABAB;">Βραβείο / Αναγνώριση</span>
      <span style="font-size:0.5rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:#ABABAB;">Φορέας</span>
      <span style="font-size:0.5rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:#ABABAB;">Έτος</span>
    </div>

    <!-- Awards table -->
    {awards.map((award, i) => (
      <div
        style={`display:grid; grid-template-columns:1fr auto auto; gap:1rem 2rem; padding:1rem 0; border-bottom:1px solid #DCDCDC; align-items:baseline;`}
        class="award-row"
      >
        <h3 style="font-size:0.875rem; font-weight:400; color:#0A0A0A; line-height:1.4;">{award.title}</h3>
        <p style="font-size:0.6875rem; font-weight:400; color:#6B6B6B; white-space:nowrap;">{award.org}</p>
        <p style="font-family:ui-monospace,'JetBrains Mono','Courier New',monospace; font-size:0.6875rem; color:#ABABAB; white-space:nowrap;">{award.year}</p>
      </div>
    ))}
  </div>
</section>
