---
const publications = [
  {
    name: 'Architectural Digest GR',
    issue: 'Τεύχος 42 · Ιούνιος 2024',
    coverage: '"Villa Kalokairinos: Νέος ορισμός της κυκλαδικής κατοικίας"',
  },
  {
    name: 'Wallpaper*',
    issue: 'Issue 284 · March 2024',
    coverage: '"Greek minimalism\'s quiet revolution"',
  },
  {
    name: 'Dezeen',
    issue: 'Architecture · February 2024',
    coverage: '"Boutique Retreat redefines Santorini hospitality architecture"',
  },
  {
    name: 'Domus',
    issue: 'No. 1078 · November 2023',
    coverage: '"Radicalità discreta nel Mar Egeo"',
  },
  {
    name: 'Frame Magazine',
    issue: 'Issue 156 · September 2023',
    coverage: '"Material restraint in Mediterranean architecture"',
  },
  {
    name: 'AD Italia',
    issue: 'No. 289 · July 2023',
    coverage: '"Il silenzio del cemento greco"',
  },
  {
    name: 'Elle Decoration GR',
    issue: 'Τεύχος 89 · Μάιος 2023',
    coverage: '"Η ασκητική αρχιτεκτονική του Νικόλα Βασιλείου"',
  },
  {
    name: 'Vogue Living',
    issue: 'Autumn/Winter 2022',
    coverage: '"Stone, light, and the Aegean: inside a Greek architect\'s vision"',
  },
  {
    name: 'ΑρχιτέκτονεΣ',
    issue: 'Τεύχος 116 · 2022 (ΤΕΕ)',
    coverage: '"Η αρχιτεκτονική του τόπου: Μελέτη πεδίου στο Αιγαίο"',
  },
  {
    name: 'Archisearch',
    issue: 'Ετήσια Έκδοση 2023',
    coverage: '"40 architects shaping contemporary Greek architecture"',
  },
];
---

<section id="press" style="padding:6rem 0; background:#0A0A0A; color:#FAFAFA;">
  <div style="max-width:72rem; margin:0 auto; padding:0 2.5rem;">
    <!-- Section header -->
    <div style="display:flex; align-items:baseline; gap:1.5rem; margin-bottom:4rem; padding-bottom:1.5rem; border-bottom:1px solid rgba(250,250,250,0.1);">
      <span style="font-family:ui-monospace,'JetBrains Mono','Courier New',monospace; font-size:0.625rem; color:rgba(250,250,250,0.3);">007</span>
      <h2 style="font-size:0.6875rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:rgba(250,250,250,0.9);">Δημοσιεύσεις</h2>
    </div>

    <!-- Publications grid -->
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(min(100%, 18rem), 1fr)); gap:1.5rem;">
      {publications.map(pub => (
        <div style="display:flex; flex-direction:column; gap:1rem; border:1px solid rgba(250,250,250,0.08); padding:1.5rem;">
          <!-- Magazine cover placeholder -->
          <div style="aspect-ratio:3/4; background:#1A1A1A; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.5rem; border:1px solid rgba(250,250,250,0.06);">
            <p style="font-size:0.6875rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:rgba(250,250,250,0.5); text-align:center; padding:0 1rem;">{pub.name}</p>
            <div style="width:1.5rem; height:1px; background:rgba(250,250,250,0.2);"></div>
          </div>
          <!-- Metadata -->
          <div style="display:flex; flex-direction:column; gap:0.375rem;">
            <p style="font-size:0.5625rem; font-weight:400; letter-spacing:0.1em; text-transform:uppercase; color:rgba(250,250,250,0.35);">{pub.issue}</p>
            <p style="font-size:0.75rem; font-weight:300; font-style:italic; line-height:1.55; color:rgba(250,250,250,0.7);">{pub.coverage}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
