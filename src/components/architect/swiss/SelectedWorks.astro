---

<section id="works" style="padding:6rem 0; position:relative;">
  <!-- Hidden filter radios — must be direct children of section for sibling CSS to work -->
  <input type="radio" id="f-all"         name="wf" class="filter-input" checked />
  <input type="radio" id="f-residential" name="wf" class="filter-input" />
  <input type="radio" id="f-hospitality" name="wf" class="filter-input" />
  <input type="radio" id="f-commercial"  name="wf" class="filter-input" />
  <input type="radio" id="f-renovation"  name="wf" class="filter-input" />
  <input type="radio" id="f-consulting"  name="wf" class="filter-input" />

  <div style="max-width:72rem; margin:0 auto; padding:0 2.5rem;">
    <!-- Section header -->
    <div style="display:flex; flex-wrap:wrap; align-items:baseline; justify-content:space-between; gap:1.5rem; margin-bottom:3rem; padding-bottom:1.5rem; border-bottom:1px solid #DCDCDC;">
      <div style="display:flex; align-items:baseline; gap:1.5rem;">
        <span style="font-family:ui-monospace,'JetBrains Mono','Courier New',monospace; font-size:0.625rem; color:#ABABAB;">002</span>
        <h2 style="font-size:0.6875rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:#0A0A0A;">Επιλεγμένα Έργα</h2>
      </div>
      <p style="font-size:0.6875rem; color:#6B6B6B;">{projects.length} έργα · 2014–2024</p>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar" style="display:flex; flex-wrap:wrap; gap:0; margin-bottom:3.5rem; border-bottom:1px solid #DCDCDC;">
      {[
        ['f-all', 'Όλα'],
        ['f-residential', 'Κατοικία'],
        ['f-hospitality', 'Φιλοξενία'],
        ['f-commercial', 'Εμπορικά'],
        ['f-renovation', 'Ανακαίνιση'],
        ['f-consulting', 'Consulting'],
      ].map(([id, label]) => (
        <label
          for={id}
          style="font-size:0.625rem; font-weight:400; letter-spacing:0.12em; text-transform:uppercase; color:#ABABAB; padding:0.75rem 1.25rem 0.75rem 0; margin-right:1.5rem; border-bottom:1px solid transparent; cursor:pointer; transition:color 0.15s, border-color 0.15s; margin-bottom:-1px;"
        >{label}</label>
      ))}
    </div>

    <!-- Projects grid -->
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(min(100%, 22rem), 1fr)); gap:3rem 2.5rem;">
      {projects.map(p => (
        <article class="project-card" data-type={p.type} style="display:flex; flex-direction:column; gap:1rem;">
          <!-- Image block with hover overlay -->
          <div style="position:relative; overflow:hidden; aspect-ratio:4/3; background:#1A1A1A;" class="img-wrap">
            <img
              src={p.image}
              alt={p.title}
              style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;"
              loading="lazy"
            />
            <!-- Hover narrative overlay -->
            <div class="hover-overlay" style="position:absolute; inset:0; background:rgba(10,10,10,0.88); display:flex; align-items:flex-end; padding:1.25rem; opacity:0; transition:opacity 0.25s;">
              <p style="font-size:0.75rem; font-weight:300; line-height:1.6; color:rgba(250,250,250,0.85);">{p.narrative}</p>
            </div>
          </div>

          <!-- Metadata -->
          <div style="display:flex; flex-direction:column; gap:0.375rem;">
            <div style="display:flex; align-items:baseline; justify-content:space-between; gap:1rem;">
              <span style="font-family:ui-monospace,'JetBrains Mono','Courier New',monospace; font-size:0.5625rem; color:#ABABAB;">{p.index}</span>
              <span style="font-size:0.5625rem; font-weight:400; letter-spacing:0.12em; text-transform:uppercase; color:#ABABAB; border:1px solid #DCDCDC; padding:0.1875rem 0.5rem;">{p.typeLabel}</span>
            </div>
            <h3 style="font-size:0.9375rem; font-weight:400; color:#0A0A0A; line-height:1.3;">{p.title}</h3>
            <div style="display:flex; gap:0.75rem; align-items:center;">
              <p style="font-size:0.6875rem; color:#6B6B6B;">{p.location}</p>
              <span style="color:#DCDCDC;">·</span>
              <p style="font-size:0.6875rem; color:#6B6B6B;">{p.year}</p>
              {p.area !== '—' && (
                <>
                  <span style="color:#DCDCDC;">·</span>
                  <p style="font-size:0.6875rem; color:#ABABAB;">{p.area}</p>
                </>
              )}
            </div>
            <p style="font-size:0.75rem; font-weight:300; font-style:italic; color:#6B6B6B; margin-top:0.125rem; line-height:1.5;">"{p.tagline}"</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .img-wrap:hover .hover-overlay {
    opacity: 1;
  }
</style>
