---
const stats = [
  { value: 15,  suffix: '+',   label: 'χρόνια',      sub: 'εμπειρίας στην ελληνική αγορά' },
  { value: 40,  suffix: '+',   label: 'εταιρείες',   sub: 'σε 8 διαφορετικούς κλάδους' },
  { value: 280, suffix: 'M€+', label: 'αξία',        sub: 'projects υπό διαχείριση' },
  { value: 92,  suffix: '%',   label: 'επαναλ.',     sub: 'πελάτες — η καλύτερη αξιολόγηση' },
];

const sectors = ['FMCG', 'Real Estate', 'Tech & SaaS', 'Φαρμακευτικά', 'Οικογενειακές Επιχειρήσεις', 'Retail', 'Logistics', 'Hospitality', 'FMCG', 'Real Estate', 'Tech & SaaS', 'Φαρμακευτικά', 'Οικογενειακές Επιχειρήσεις', 'Retail', 'Logistics', 'Hospitality'];
---

<section class="track" aria-label="Track record">
  <div class="track__inner con-inner">

    <div class="track__head" data-anim="track-head">
      <p class="eyebrow">Track Record</p>
      <h2 class="track__title">Αριθμοί.</h2>
    </div>

    <div class="track__stats" data-anim="track-stats">
      {stats.map(s => (
        <div class="track__stat">
          <p class="track__num">
            <span class="track__val">
              <span class="line-wrap"><span class="track__counter" data-target={s.value}>{s.value}</span></span>
            </span>
            <span class="track__suffix">{s.suffix}</span>
          </p>
          <p class="track__label">{s.label}</p>
          <p class="track__sub eyebrow">{s.sub}</p>
        </div>
      ))}
    </div>

  </div>

  <div class="track__sectors-wrap" data-anim="track-sectors">
    <div class="track__sectors-track">
      {sectors.map(s => (
        <span class="track__sector-item">
          <span class="track__sector-dot" aria-hidden="true">◆</span>
          {s}
        </span>
      ))}
    </div>
  </div>

</section>

<style>
  .track { background: var(--c-bg); padding-block: var(--s-9); }
  .track__inner { display: grid; gap: var(--s-8); }

  .track__head { display: grid; gap: var(--s-4); }
  .track__title {
    font-family: var(--f-display); font-weight: 400;
    font-size: clamp(2.5rem, 6vw, 5rem);
    letter-spacing: -0.025em; color: var(--c-ink); line-height: 1.0;
  }

  .track__stats {
    display: grid; gap: var(--s-7);
    grid-template-columns: repeat(2, 1fr);
    padding-block: var(--s-7);
    border-block: 1px solid var(--c-border);
  }
  @media (min-width: 900px) {
    .track__stats { grid-template-columns: repeat(4, 1fr); }
  }

  .track__stat { display: grid; gap: var(--s-2); }

  .track__num {
    display: flex; align-items: flex-start; gap: 0.1em;
    line-height: 1;
  }
  .track__val {
    font-family: var(--f-display); font-weight: 400; font-style: italic;
    font-size: clamp(4rem, 7vw, 6.5rem);
    color: var(--c-green); letter-spacing: -0.03em;
    display: block;
  }
  .track__suffix {
    font-family: var(--f-display); font-weight: 400; font-style: italic;
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    color: var(--c-green-2); letter-spacing: -0.02em;
    padding-top: 0.3em;
  }
  .track__label {
    font-family: var(--f-display); font-weight: 400;
    font-size: 1.125rem; color: var(--c-ink); margin-top: var(--s-2);
  }
  .track__sub { color: var(--c-ink-3); letter-spacing: 0.1em; }

  /* Sectors marquee */
  .track__sectors-wrap {
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
    padding-block: 0.875rem;
    overflow: hidden; white-space: nowrap;
  }
  .track__sectors-track {
    display: inline-flex; gap: var(--s-6);
    animation: sectors-scroll 28s linear infinite;
  }
  .track__sector-item {
    display: inline-flex; align-items: center; gap: var(--s-3);
    font-size: 0.6875rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--c-ink-2);
  }
  .track__sector-dot { color: var(--c-green-3); font-size: 0.35rem; }

  @keyframes sectors-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  [data-anim="track-head"],
  [data-anim="track-stats"],
  [data-anim="track-sectors"] { opacity: 0; }
  @media (prefers-reduced-motion: reduce) {
    [data-anim="track-head"],
    [data-anim="track-stats"],
    [data-anim="track-sectors"] { opacity: 1 !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.set('[data-anim="track-head"]', { y: 24 });
    gsap.set('[data-anim="track-stats"]', { y: 32 });
    gsap.set('[data-anim="track-sectors"]', { y: 16 });

    gsap.to('[data-anim="track-head"]', {
      opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
      scrollTrigger: { trigger: '[data-anim="track-head"]', start: 'top 85%' }
    });

    gsap.to('[data-anim="track-stats"]', {
      opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
      scrollTrigger: {
        trigger: '[data-anim="track-stats"]', start: 'top 80%',
        onEnter: () => {
          document.querySelectorAll('.track__counter').forEach(el => {
            const target = parseInt((el as HTMLElement).dataset.target || '0');
            gsap.fromTo(el, { textContent: 0 }, {
              textContent: target, duration: 1.8, ease: 'power2.out',
              delay: 0.25,
              snap: { textContent: 1 },
            });
          });
        }
      }
    });

    gsap.to('[data-anim="track-sectors"]', {
      opacity: 1, y: 0, duration: 0.6, ease: 'power2.out',
      scrollTrigger: { trigger: '[data-anim="track-sectors"]', start: 'top 88%' }
    });
  });
</script>
