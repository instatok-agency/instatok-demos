---
---

<section class="contact" id="contact" aria-label="Επικοινωνία">
  <div class="contact__inner con-inner">

    <div class="contact__head" data-anim="ct-head">
      <p class="eyebrow" style="color: rgba(255,255,255,0.35);">Επικοινωνία</p>
      <h2 class="contact__title">
        <span class="line-wrap"><span data-anim="ct-hl">Ας</span></span>
        <span class="line-wrap"><span data-anim="ct-hl">μιλήσουμε.</span></span>
      </h2>
      <p class="contact__sub">Πείτε μου για την εταιρεία σας. Απαντώ σε 24 ώρες.</p>
    </div>

    <form class="contact__form" onsubmit="return false" data-anim="ct-form">
      <div class="contact__row">
        <div class="contact__field">
          <label for="ct-name" class="contact__label">Όνομα</label>
          <input type="text" id="ct-name" name="name" class="contact__input" placeholder="Το όνομά σας" autocomplete="given-name" />
        </div>
        <div class="contact__field">
          <label for="ct-email" class="contact__label">Email</label>
          <input type="email" id="ct-email" name="email" class="contact__input" placeholder="email@company.gr" autocomplete="email" />
        </div>
      </div>
      <div class="contact__field">
        <label for="ct-company" class="contact__label">Εταιρεία & κλάδος</label>
        <input type="text" id="ct-company" name="company" class="contact__input" placeholder="Π.χ. ABC Α.Ε. — Retail" autocomplete="organization" />
      </div>
      <div class="contact__field">
        <label for="ct-msg" class="contact__label">Τι θέλετε να πετύχετε <span style="font-weight:300; opacity:0.5;">(προαιρετικό)</span></label>
        <textarea id="ct-msg" name="message" class="contact__input contact__textarea" placeholder="Πείτε μου σε λίγες γραμμές…" rows="4"></textarea>
      </div>
      <button type="submit" class="contact__submit">Αποστολή</button>
    </form>

  </div>

  <footer class="con-footer">
    <div class="con-footer__inner con-inner">
      <p class="con-footer__name">Νίκος Σταύρου</p>
      <div class="con-footer__links">
        <a href="mailto:nikos@stavrou-advisory.gr" class="con-footer__link">nikos@stavrou-advisory.gr</a>
        <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="con-footer__link">LinkedIn →</a>
      </div>
      <p class="eyebrow con-footer__demo" style="color: rgba(255,255,255,0.2);">Demo — Instatok Agency</p>
    </div>
  </footer>
</section>

<style>
  .contact {
    background: var(--c-ink);
    padding-block-start: var(--s-9);
  }
  .contact__inner {
    display: grid; gap: var(--s-8);
    padding-block-end: var(--s-9);
  }
  @media (min-width: 860px) {
    .contact__inner { grid-template-columns: 5fr 7fr; align-items: start; }
  }

  .contact__head { display: grid; gap: var(--s-5); }
  .contact__title {
    font-family: var(--f-display); font-weight: 400;
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 1.0; letter-spacing: -0.03em;
    color: var(--c-on-green);
  }
  .contact__title [data-anim="ct-hl"] { display: block; }
  .contact__sub {
    font-size: 0.9375rem; font-weight: 300;
    line-height: 1.75; color: rgba(234,240,236,0.5);
    max-width: 22rem;
  }

  .contact__form { display: grid; gap: var(--s-5); }
  .contact__row { display: grid; gap: var(--s-4); }
  @media (min-width: 480px) { .contact__row { grid-template-columns: 1fr 1fr; } }

  .contact__field { display: grid; gap: var(--s-2); }
  .contact__label {
    font-size: 0.75rem; font-weight: 500;
    color: rgba(234,240,236,0.6); letter-spacing: 0.04em;
  }
  .contact__input {
    padding: 0.8rem 1rem;
    background: rgba(234,240,236,0.05);
    border: 1px solid rgba(234,240,236,0.12);
    border-radius: var(--r-sm);
    font-family: var(--f-body); font-size: 0.9375rem;
    color: var(--c-on-green);
    outline: none; width: 100%; appearance: none; -webkit-appearance: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .contact__input::placeholder { color: rgba(234,240,236,0.25); }
  .contact__input:focus {
    border-color: var(--c-green-3);
    background: rgba(234,240,236,0.07);
  }
  .contact__textarea { resize: vertical; min-height: 7rem; }
  .contact__submit {
    padding: 0.9rem 2rem; width: 100%;
    background: var(--c-green); color: var(--c-on-green);
    border: 1px solid var(--c-green);
    border-radius: var(--r-sm);
    font-family: var(--f-body); font-size: 0.9375rem; font-weight: 500;
    cursor: pointer; transition: background 0.2s, border-color 0.2s;
  }
  .contact__submit:hover {
    background: var(--c-green-2); border-color: var(--c-green-2);
  }

  /* Footer */
  .con-footer {
    border-top: 1px solid rgba(234,240,236,0.08);
    padding-block: var(--s-6);
  }
  .con-footer__inner {
    display: flex; align-items: center;
    justify-content: space-between; flex-wrap: wrap; gap: var(--s-4);
  }
  .con-footer__name {
    font-family: var(--f-display); font-weight: 400;
    font-size: 1.125rem; color: var(--c-on-green); letter-spacing: -0.01em;
  }
  .con-footer__links { display: flex; gap: var(--s-5); flex-wrap: wrap; }
  .con-footer__link {
    font-size: 0.8125rem; font-weight: 400;
    color: rgba(234,240,236,0.45); transition: color 0.2s;
  }
  .con-footer__link:hover { color: var(--c-on-green-2); }

  /* Pre-hide */
  [data-anim="ct-hl"] { display: block; }
  [data-anim="ct-form"] { opacity: 0; }

  @media (prefers-reduced-motion: reduce) {
    [data-anim="ct-form"] { opacity: 1 !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.set('[data-anim="ct-hl"]', { yPercent: 110 });
    gsap.set('[data-anim="ct-form"]', { y: 32 });

    gsap.to('[data-anim="ct-hl"]', {
      yPercent: 0, stagger: 0.12, duration: 0.95, ease: 'power3.out',
      scrollTrigger: { trigger: '.contact__title', start: 'top 85%' }
    });
    gsap.to('[data-anim="ct-form"]', {
      opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
      scrollTrigger: { trigger: '[data-anim="ct-form"]', start: 'top 85%' }
    });
  });
</script>
