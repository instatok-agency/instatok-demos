---
---

<section class="hero" aria-labelledby="hero-headline">
  <div class="hero__inner con-inner">

    <div class="hero__top" data-anim="c-top">
      <hr class="hero__rule" aria-hidden="true" />
      <div class="hero__top-row">
        <p class="eyebrow eyebrow--on-dark">Νίκος Σταύρου · Στρατηγικός Σύμβουλος</p>
        <span class="pill pill--dark">Αθήνα · Remote</span>
      </div>
    </div>

    <h1 class="hero__headline" id="hero-headline">
      <span class="hero__hline" data-anim="c-line">Επιχειρήσεις</span>
      <span class="hero__hline" data-anim="c-line">που <em>αναπτύσσονται.</em></span>
      <span class="hero__hline" data-anim="c-line">Αποτελέσματα</span>
      <span class="hero__hline" data-anim="c-line">που μετρώνται.</span>
    </h1>

    <div class="hero__foot" data-anim="c-foot">
      <p class="hero__lead">
        15 χρόνια στρατηγικής συμβουλευτικής για ελληνικές
        εταιρείες ανάπτυξης, οικογενειακές επιχειρήσεις και
        startups πριν τη χρηματοδότηση.
      </p>
      <div class="hero__creds">
        <span class="pill pill--dark">MBA ALBA</span>
        <span class="pill pill--dark">40+ εταιρείες</span>
        <span class="pill pill--dark">Ex-McKinsey</span>
      </div>
      <div class="hero__actions">
        <a href="#contact" class="hero__cta hero__cta--primary">Κλείσε συνάντηση</a>
        <a href="#services" class="hero__cta hero__cta--ghost">Υπηρεσίες →</a>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    background: var(--c-dark);
    padding-block: 5rem var(--s-9);
    min-height: 85svh;
    display: flex;
    align-items: flex-end;
  }
  .hero__inner { display: grid; gap: var(--s-6); width: 100%; }

  .hero__top { display: grid; gap: var(--s-4); }
  .hero__rule {
    border: none; border-top: 1px solid var(--c-dark-border);
    transform-origin: left center; transform: scaleX(0);
  }
  .hero__top-row {
    display: flex; align-items: center;
    justify-content: space-between; flex-wrap: wrap; gap: var(--s-3);
  }

  .hero__headline {
    font-family: var(--f-display);
    font-weight: 600;
    font-size: clamp(2.6rem, 7vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--c-on-dark);
    margin: 0;
  }
  .hero__hline { display: block; }
  .hero__headline em {
    font-style: italic;
    font-weight: 300;
    color: var(--c-blue-light);
  }

  .hero__foot {
    display: grid; gap: var(--s-5);
    padding-top: var(--s-5);
    border-top: 1px solid var(--c-dark-border);
    max-width: 36rem;
  }
  .hero__lead {
    font-size: 1rem; line-height: 1.75; color: var(--c-on-dark-2);
    font-weight: 300;
  }
  .hero__creds { display: flex; flex-wrap: wrap; gap: var(--s-2); }
  .hero__actions { display: flex; flex-wrap: wrap; gap: var(--s-3); }

  .hero__cta {
    display: inline-flex; align-items: center;
    padding: 0.75rem 1.75rem;
    font-family: var(--f-body); font-size: 0.9375rem; font-weight: 500;
    text-decoration: none; border-radius: var(--r-sm);
    transition: background 0.18s, color 0.18s, border-color 0.18s;
    white-space: nowrap;
  }
  .hero__cta--primary {
    background: var(--c-blue); color: #fff; border: 1px solid var(--c-blue);
  }
  .hero__cta--primary:hover {
    background: var(--c-blue-dark); border-color: var(--c-blue-dark);
  }
  .hero__cta--ghost {
    background: transparent; color: var(--c-on-dark);
    border: 1px solid var(--c-dark-border);
  }
  .hero__cta--ghost:hover { border-color: var(--c-on-dark-2); }
</style>

<script>
  import { gsap } from 'gsap';
  import { initGSAP } from '../../scripts/gsap-consultant';
  initGSAP();

  const mm = gsap.matchMedia();
  mm.add(
    { isMotion: '(prefers-reduced-motion: no-preference)', isReduced: '(prefers-reduced-motion: reduce)' },
    (ctx) => {
      const { isReduced } = ctx.conditions ?? {};
      if (isReduced) return;

      gsap.set('[data-anim="c-top"]', { autoAlpha: 0, y: -10 });
      gsap.set('[data-anim="c-line"]', { autoAlpha: 0, y: 30 });
      gsap.set('[data-anim="c-foot"]', { autoAlpha: 0, y: 20 });

      const tl = gsap.timeline();
      tl.to('.hero__rule', { scaleX: 1, duration: 0.8, ease: 'power3.inOut' }, 0)
        .to('[data-anim="c-top"]', { autoAlpha: 1, y: 0, duration: 0.6 }, 0.3)
        .to('[data-anim="c-line"]', { autoAlpha: 1, y: 0, stagger: 0.1, duration: 0.75 }, 0.55)
        .to('[data-anim="c-foot"]', { autoAlpha: 1, y: 0, duration: 0.65 }, 1.1);
    }
  );
</script>
