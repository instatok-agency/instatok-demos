---
const services = [
  {
    num: '01',
    title: 'Εταιρική Στρατηγική',
    body: 'Ανάλυση αγοράς, ανταγωνιστική τοποθέτηση, 3-5ετή στρατηγικά σχέδια. Από startup έως established SME.',
    tags: ['Market Analysis', 'Competitive Positioning', 'Growth Roadmap'],
  },
  {
    num: '02',
    title: 'Αναδιάρθρωση & Βελτιστοποίηση',
    body: 'Operational excellence, cost optimization και reorganisation για εταιρείες σε μεταβατικές φάσεις ή κρίση.',
    tags: ['Process Redesign', 'Cost Reduction', 'Team Structure'],
  },
  {
    num: '03',
    title: 'Χρηματοδότηση & M&A',
    body: 'Προετοιμασία για επενδυτές, pitch decks, due diligence support και advisory σε M&A transactions.',
    tags: ['Investor Readiness', 'Pitch Deck', 'Due Diligence'],
  },
];
---

<section class="services" id="services" aria-label="Υπηρεσίες">
  <hr class="section-rule" aria-hidden="true" />
  <div class="services__inner con-inner">

    <div class="services__head" data-anim="srv-head">
      <p class="eyebrow eyebrow--blue">Υπηρεσίες</p>
      <h2 class="services__title">Τι κάνω.</h2>
    </div>

    <div class="services__grid">
      {services.map((s, i) => (
        <div class="service-card" data-anim="srv-card">
          <div class="service-card__top">
            <span class="service-card__num eyebrow">{s.num}</span>
            <h3 class="service-card__title">{s.title}</h3>
          </div>
          <p class="service-card__body">{s.body}</p>
          <div class="service-card__tags">
            {s.tags.map(t => <span class="pill pill--outline">{t}</span>)}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .services { background: var(--c-bg); padding-block: var(--s-9); }
  .services__inner { display: grid; gap: var(--s-8); }
  .services__head { display: grid; gap: var(--s-4); }
  .services__title {
    font-family: var(--f-display);
    font-weight: 600; font-size: clamp(2rem, 5vw, 3.5rem);
    letter-spacing: -0.02em; color: var(--c-ink); line-height: 1.05;
  }
  .services__grid { display: grid; gap: var(--s-1); }

  .service-card {
    padding: var(--s-6) 0;
    border-bottom: 1px solid var(--c-border);
    display: grid; gap: var(--s-4);
  }
  .service-card:first-child { border-top: 1px solid var(--c-border); }
  @media (min-width: 768px) {
    .service-card { grid-template-columns: 1fr 2fr auto; align-items: start; }
  }

  .service-card__top { display: grid; gap: var(--s-2); }
  .service-card__num { color: var(--c-ink-3); }
  .service-card__title {
    font-family: var(--f-display);
    font-weight: 600; font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--c-ink); line-height: 1.2;
  }
  .service-card__body {
    font-size: 0.9375rem; line-height: 1.75; color: var(--c-ink-2);
  }
  .service-card__tags { display: flex; flex-wrap: wrap; gap: var(--s-2); align-self: start; }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('[data-anim="srv-head"]', { autoAlpha: 0, y: 20 }, {
      autoAlpha: 1, y: 0, duration: 0.7,
      scrollTrigger: { trigger: '[data-anim="srv-head"]', start: 'top 85%' }
    });
    gsap.fromTo('[data-anim="srv-card"]', { autoAlpha: 0, y: 24 }, {
      autoAlpha: 1, y: 0, duration: 0.65, stagger: 0.1,
      scrollTrigger: { trigger: '.services__grid', start: 'top 80%' }
    });
  });
</script>
