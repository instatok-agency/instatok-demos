---
import '../styles/cafe-nyx.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nyx · Cocktail Bar & Specialty Coffee Αθήνα',
  description = 'Cocktails, φυσικά κρασιά και specialty coffee στο Γκάζι. Ανοιχτά κάθε μέρα.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07090F" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="/cafe" class="back-link">← demos</a>
    <slot />
  </body>
</html>

<style>
  body { position: relative; }
  .back-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 100;
    font-family: var(--f-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: rgba(192, 186, 177, 0.35);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--c-cream-2); }
</style>
