---
import '../styles/bnb-arch.css';
interface Props { title?: string; description?: string; }
const {
  title = 'Κυκλαδική Κατοικία · Σύρος',
  description = 'Αρχοντική κατοικία 19ου αιώνα, ανακαινισμένη το 2023. 3 υπνοδωμάτια, θέα στο Αιγαίο, Άνω Σύρος.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F9F8F5" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,500;6..12,600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="/bnb" class="back-link">← demos</a>
    <slot />
  </body>
</html>
<style>
  body { position: relative; }
  .back-link {
    position: fixed; top: 1rem; left: 1rem; z-index: 200;
    font-family: var(--f-body); font-size: 0.625rem; letter-spacing: 0.1em;
    color: rgba(154, 149, 144, 0.55); text-decoration: none;
    padding: 0.25rem 0.5rem; transition: color 0.2s;
  }
  .back-link:hover { color: var(--c-sage); }
</style>
