---
import '../styles/bnb-rivora.css';
interface Props { title?: string; description?: string; }
const {
  title = 'Αρχόντισσα · Άνω Σύρος',
  description = 'Κυκλαδική αρχοντική κατοικία 1847, ανακαινισμένη 2023. 3 υπνοδωμάτια, θέα Αιγαίο.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0D0B07" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="/hospitality" class="back-link">← demos</a>
    <slot />
  </body>
</html>
<style>
  body { position: relative; }
  .back-link {
    position: fixed; top: 1rem; left: 1rem; z-index: 300;
    font-family: var(--f-body); font-size: 0.625rem; letter-spacing: 0.1em;
    color: rgba(200,190,175,0.4); text-decoration: none;
    padding: 0.25rem 0.5rem; transition: color 0.2s;
  }
  .back-link:hover { color: var(--rv-gold); }
</style>
