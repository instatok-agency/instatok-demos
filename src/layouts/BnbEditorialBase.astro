---
import '../styles/bnb-editorial.css';
interface Props { title?: string; description?: string; }
const {
  title = 'Theodoraki Apartment · Κολωνάκι, Αθήνα',
  description = 'Boutique διαμέρισμα 2 υπνοδωματίων στο Κολωνάκι. Πλήρης εξοπλισμός, design interior, 5 λεπτά από το Σύνταγμα.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F6F1E8" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="/hospitality" class="back-link">← demos</a>
    <slot />
  </body>
</html>
<style>
  body { position: relative; }
  .back-link {
    position: fixed; top: 1rem; left: 1rem; z-index: 200;
    font-family: var(--f-body); font-size: 0.625rem; letter-spacing: 0.1em;
    color: rgba(158, 142, 130, 0.5); text-decoration: none;
    padding: 0.25rem 0.5rem; transition: color 0.2s;
  }
  .back-link:hover { color: var(--c-sand); }
</style>
