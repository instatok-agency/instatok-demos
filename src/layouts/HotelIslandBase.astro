---
import '../styles/hotel-island.css';
interface Props { title?: string; description?: string; }
const {
  title = 'Ithaca Bay Resort · Κεφαλονιά',
  description = 'Boutique ιδιωτικό νησιωτικό resort στην Κεφαλονιά. Πολυτελή δωμάτια, spa, γαστρονομία. Demo: Instatok Agency.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1E3B2C" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="/hotel" class="back-link">← demos</a>
    <slot />
  </body>
</html>
<style>
  body { position: relative; }
  .back-link {
    position: fixed; top: 1rem; left: 1rem; z-index: 300;
    font-family: var(--f-body); font-size: 0.625rem; letter-spacing: 0.1em;
    color: rgba(200,200,190,0.35); text-decoration: none;
    padding: 0.25rem 0.5rem; transition: color 0.2s;
  }
  .back-link:hover { color: var(--hi-gold); }
</style>
