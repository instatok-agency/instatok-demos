---
import '../styles/yoga-modern.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Studio Kali · Yoga & Pilates Αθήνα',
  description = 'Vinyasa, Pilates και Yin Yoga στο Κολωνάκι. Ομαδικά και ιδιωτικά μαθήματα, 6 ημέρες την εβδομάδα.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F8FAF8" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="/yoga" class="back-link">← demos</a>
    <slot />
  </body>
</html>

<style>
  body { position: relative; }
  .back-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 50;
    font-family: var(--f-body);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: rgba(122, 138, 123, 0.5);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--c-ink); }
</style>
