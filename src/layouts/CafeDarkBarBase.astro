---
import '../styles/cafe-darkbar.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Καβός · Specialty Coffee & Micro-Roastery Αθήνα',
  description = 'Micro-roastery single origins στον Νέο Κόσμο. Q-graded lots, εβδομαδιαίο ψήσιμο, wholesale. Demo: Dark Bar.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0F0E0D" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@500;600;700;800&family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="/cafe" class="back-link">← demos</a>
    <slot />
  </body>
</html>

<style>
  body { position: relative; }
  .back-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 50;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    color: rgba(138, 126, 114, 0.5);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    transition: color 0.25s;
  }
  .back-link:hover { color: #F0EBE3; }
</style>
