---
import '../styles/yoga-intelligence.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Έλενα Παπαδάκη · Yoga & Pilates Παγκράτι',
  description = 'Vinyasa flow και restorative yoga στο Παγκράτι. RYT-500 certified. Ιδιωτικά μαθήματα, ομαδικές τάξεις, stress relief για professionals.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F7F4F0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="/yoga" class="back-link">← demos</a>
    <slot />
  </body>
</html>

<style>
  body { position: relative; }
  .back-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 50;
    font-family: "DM Mono", ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: rgba(155, 142, 135, 0.6);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: #1A1A1A; }
</style>
