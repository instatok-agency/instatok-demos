---
import '../styles/bnb-dark.css';
interface Props { title?: string; description?: string; }
const {
  title = 'ROOM 12 · Boutique Studio, Αθήνα',
  description = 'Premium studio στον Κεραμεικό. Minimal design, 40m², private terrace. Κεντρική Αθήνα.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0C0B09" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="/bnb" class="back-link">← demos</a>
    <slot />
  </body>
</html>
<style>
  body { position: relative; }
  .back-link {
    position: fixed; top: 1rem; left: 1rem; z-index: 200;
    font-family: var(--f-sans); font-size: 0.5625rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(120, 110, 100, 0.5); text-decoration: none;
    padding: 0.25rem 0.5rem; transition: color 0.2s;
  }
  .back-link:hover { color: var(--c-amber); }
</style>
