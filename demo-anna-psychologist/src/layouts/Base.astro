---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Δρ. Άννα Δημητρίου · Ψυχοθεραπεύτρια στην Αθήνα",
  description = "Trauma-informed ψυχοθεραπεία στο Παγκράτι και online. Ειδίκευση σε burnout, άγχος, σχέσεις, κοινωνικά δίκτυα. Δρ. Άννα Δημητρίου.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#E8D5C4" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=GFS+Didot&family=Spectral:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
