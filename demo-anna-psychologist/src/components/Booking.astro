---
---

<section class="booking" id="booking" aria-labelledby="booking-heading">
  <div class="booking__inner section-inner">

    <header class="booking__header" data-book-anim="header">
      <div class="booking__eyebrow">
        <span class="booking__eyebrow-line"></span>
        <span>Κλείσε ραντεβού</span>
      </div>
      <h2 class="booking__heading" id="booking-heading">
        Το πρώτο σου<br>μήνυμα
      </h2>
      <p class="booking__subhead">
        Δεν χρειάζεται να είναι τέλειο.<br>Αρκεί να είναι αληθινό.
      </p>
    </header>

    <div class="booking__form-col" data-book-anim="form">
      <form class="booking__form" onsubmit="return false" novalidate>

        <div class="booking__prose-fields">
          <p class="booking__prose-line">
            Με λένε
            <span class="booking__field-inline">
              <input
                type="text"
                class="booking__input"
                placeholder="το όνομά σου"
                aria-label="Όνομα"
                autocomplete="given-name"
              />
            </span>.
          </p>
          <p class="booking__prose-line">
            Είμαι
            <span class="booking__field-inline booking__field-inline--short">
              <input
                type="text"
                class="booking__input"
                placeholder="ηλικία"
                aria-label="Ηλικία"
                inputmode="numeric"
                maxlength="3"
              />
            </span>
            χρονών.
          </p>
        </div>

        <div class="booking__field-group" data-book-anim="field">
          <label class="booking__label" for="booking-about">
            Θέλω να μιλήσουμε για:
          </label>
          <textarea
            id="booking-about"
            class="booking__textarea"
            rows="5"
            placeholder="Δεν χρειάζεται να είναι οργανωμένο. Γράψε όπως έρχεται…"
          ></textarea>
        </div>

        <div class="booking__field-group" data-book-anim="field">
          <p class="booking__label">Προτιμώ:</p>
          <div class="booking__pills" role="group" aria-label="Τύπος συνεδρίας">
            <label class="booking__pill-label">
              <input type="radio" name="session-type" value="office" class="booking__radio" />
              <span class="booking__pill">Παγκράτι</span>
            </label>
            <label class="booking__pill-label">
              <input type="radio" name="session-type" value="online" class="booking__radio" />
              <span class="booking__pill">Online</span>
            </label>
            <label class="booking__pill-label">
              <input type="radio" name="session-type" value="unsure" class="booking__radio" />
              <span class="booking__pill">Δεν ξέρω ακόμα</span>
            </label>
          </div>
        </div>

        <div class="booking__field-group" data-book-anim="field">
          <label class="booking__label" for="booking-contact">
            Με βρίσκετε στο:
          </label>
          <input
            type="text"
            id="booking-contact"
            class="booking__input booking__input--full"
            placeholder="email ή τηλέφωνο"
            aria-label="Επικοινωνία"
          />
        </div>

        <div class="booking__submit-row" data-book-anim="submit">
          <button
            type="submit"
            class="booking__submit"
            disabled
            aria-disabled="true"
          >
            <span>Στέλνω το πρώτο μήνυμα</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <p class="booking__mockup-note">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true" width="13">
              <circle cx="8" cy="8" r="6.5"/>
              <path d="M8 7v4M8 5.5v-.5" stroke-linecap="round"/>
            </svg>
            Mockup mode · Επικοινωνία: <a href="mailto:anna@example.com">anna@example.com</a>
          </p>
        </div>

      </form>

      <div class="booking__reassurance" data-book-anim="reassurance">
        <span>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
            <circle cx="8" cy="8" r="6.5"/><path d="M5.5 8l2 2 3-3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Απάντηση εντός 48 ωρών
        </span>
        <span>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
            <circle cx="8" cy="8" r="6.5"/><path d="M5.5 8l2 2 3-3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Χωρίς chatbot
        </span>
        <span>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
            <circle cx="8" cy="8" r="6.5"/><path d="M5.5 8l2 2 3-3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Απόλυτη εχεμύθεια
        </span>
      </div>
    </div>

  </div>
</section>

<style>
  .booking {
    padding-block: var(--s-8);
    background:
      radial-gradient(ellipse 60% 55% at 90% 10%, rgba(200, 85, 61, 0.12) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 0% 90%, rgba(122, 132, 113, 0.12) 0%, transparent 50%),
      #EACFBC;
    position: relative;
  }
  .booking::before {
    content: "";
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(to right, transparent, var(--c-clay-2), transparent);
  }

  .booking__inner { display: grid; gap: var(--s-7); align-items: start; }

  /* ── Header ──────────────────────────── */
  .booking__eyebrow {
    display: flex; align-items: center; gap: var(--s-3); margin-bottom: var(--s-4);
    font-family: var(--f-mono); font-size: 0.7rem;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--c-ink-soft);
  }
  .booking__eyebrow-line { width: 28px; height: 1px; background: var(--c-terra); }
  .booking__heading {
    font-family: var(--f-display); font-weight: 400;
    font-size: clamp(2rem, 7vw, 3rem); line-height: 1.02;
    letter-spacing: -0.01em; margin-bottom: var(--s-4);
  }
  .booking__subhead {
    font-family: var(--f-body); font-style: italic; font-weight: 300;
    font-size: 1.05rem; line-height: 1.6; color: var(--c-ink-soft);
  }

  /* ── Form ────────────────────────────── */
  .booking__form {
    display: grid; gap: var(--s-6);
    background: color-mix(in srgb, var(--c-bone) 50%, transparent);
    border: 1px solid color-mix(in srgb, var(--c-ink) 10%, transparent);
    border-radius: 6px; padding: var(--s-6);
    backdrop-filter: blur(4px);
  }

  .booking__prose-fields { display: grid; gap: var(--s-4); }
  .booking__prose-line {
    font-family: var(--f-body); font-size: 1.1rem;
    color: var(--c-ink); line-height: 1.4; display: flex;
    align-items: flex-end; flex-wrap: wrap; gap: 0.4rem;
  }

  .booking__field-inline {
    display: inline-flex; flex: 1; min-width: 8rem;
  }
  .booking__field-inline--short { min-width: 4rem; max-width: 6rem; flex: none; }

  .booking__input {
    width: 100%; background: transparent; border: none;
    border-bottom: 1.5px solid color-mix(in srgb, var(--c-terra) 45%, var(--c-ink) 20%);
    border-radius: 0; outline: none;
    font-family: var(--f-body); font-style: italic; font-size: 1.1rem;
    color: var(--c-ink); padding: 0.15rem 0.1rem 0.25rem;
    transition: border-color 0.2s;
  }
  .booking__input::placeholder { color: color-mix(in srgb, var(--c-ink) 28%, transparent); }
  .booking__input:focus { border-color: var(--c-terra); }
  .booking__input--full { font-size: 1rem; }

  .booking__field-group { display: grid; gap: var(--s-3); }
  .booking__label {
    font-family: var(--f-mono); font-size: 0.7rem;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--c-ink-soft);
  }

  .booking__textarea {
    width: 100%; background: transparent;
    border: 1.5px solid color-mix(in srgb, var(--c-ink) 15%, transparent);
    border-radius: 4px; padding: var(--s-3) var(--s-4);
    font-family: var(--f-body); font-size: 1rem;
    color: var(--c-ink); line-height: 1.65; resize: vertical;
    outline: none; transition: border-color 0.2s;
    min-height: 110px;
  }
  .booking__textarea::placeholder { color: color-mix(in srgb, var(--c-ink) 30%, transparent); }
  .booking__textarea:focus { border-color: var(--c-terra); }

  .booking__pills { display: flex; flex-wrap: wrap; gap: var(--s-3); }
  .booking__radio { position: absolute; opacity: 0; pointer-events: none; }
  .booking__pill-label { cursor: pointer; }
  .booking__pill {
    display: inline-block;
    padding: 0.55rem 1rem; border-radius: 999px;
    border: 1.5px solid color-mix(in srgb, var(--c-ink) 22%, transparent);
    font-family: var(--f-mono); font-size: 0.72rem; letter-spacing: 0.06em;
    color: var(--c-ink-soft);
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    user-select: none;
  }
  .booking__radio:checked + .booking__pill {
    background: var(--c-terra); border-color: var(--c-terra); color: var(--c-bone);
  }
  .booking__pill-label:hover .booking__pill {
    border-color: var(--c-terra);
    color: var(--c-terra);
  }

  /* ── Submit ──────────────────────────── */
  .booking__submit-row { display: grid; gap: var(--s-3); }
  .booking__submit {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.7rem; padding: 1.1rem 1.6rem; border-radius: 999px;
    background: var(--c-ink); color: var(--c-bone); border: none;
    font-family: var(--f-body); font-size: 1rem; font-weight: 500;
    cursor: not-allowed; opacity: 0.45;
    box-shadow: 0 8px 24px -6px color-mix(in srgb, var(--c-ink) 30%, transparent);
  }
  .booking__submit svg { width: 18px; height: 18px; }
  .booking__mockup-note {
    display: flex; align-items: center; gap: 0.4rem;
    font-family: var(--f-mono); font-size: 0.68rem;
    letter-spacing: 0.05em; color: var(--c-ink-soft); line-height: 1.5;
  }
  .booking__mockup-note a { color: var(--c-terra); text-decoration: underline; text-underline-offset: 3px; }

  /* ── Reassurance ─────────────────────── */
  .booking__reassurance {
    display: flex; flex-wrap: wrap; gap: var(--s-5);
    padding-top: var(--s-4);
  }
  .booking__reassurance span {
    display: flex; align-items: center; gap: 0.45rem;
    font-family: var(--f-mono); font-size: 0.7rem;
    letter-spacing: 0.06em; color: var(--c-ink-soft);
  }
  .booking__reassurance svg { color: var(--c-sage); }

  @media (min-width: 1024px) {
    .booking__inner { grid-template-columns: 1fr 1.4fr; gap: var(--s-8); }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initGSAP } from '../scripts/gsap-init';

  initGSAP();
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    const section = document.querySelector('.booking');
    if (!section) return;

    gsap.from('[data-book-anim="header"] > *', {
      autoAlpha: 0, y: 20, stagger: 0.1, duration: 1,
      scrollTrigger: { trigger: section, start: 'top 80%', once: true },
    });

    gsap.from('[data-book-anim="form"]', {
      autoAlpha: 0, y: 28, duration: 1.1,
      scrollTrigger: { trigger: section, start: 'top 75%', once: true },
    });

    gsap.from('[data-book-anim="field"]', {
      autoAlpha: 0, y: 14, stagger: 0.12, duration: 0.85,
      scrollTrigger: { trigger: '.booking__form', start: 'top 80%', once: true },
    });

    gsap.from('[data-book-anim="submit"]', {
      autoAlpha: 0, y: 10, duration: 0.8,
      scrollTrigger: { trigger: '.booking__submit-row', start: 'top 88%', once: true },
    });

    gsap.from('[data-book-anim="reassurance"] span', {
      autoAlpha: 0, y: 8, stagger: 0.1, duration: 0.7,
      scrollTrigger: { trigger: '.booking__reassurance', start: 'top 90%', once: true },
    });
  });
</script>
