---
---

<footer class="footer" aria-labelledby="footer-brand">
  <div class="footer__inner section-inner">

    <div class="footer__brand" data-foot-anim="brand" id="footer-brand">
      <svg class="footer__leaf" viewBox="0 0 80 140" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" aria-hidden="true">
        <path d="M40,8 C40,8 14,40 14,80 C14,108 28,128 40,132 C52,128 66,108 66,80 C66,40 40,8 40,8 Z" />
        <path d="M40,18 L40,128" />
        <path d="M40,40 L22,56 M40,52 L20,72 M40,66 L22,86 M40,80 L24,98" stroke-width="0.7" />
        <path d="M40,40 L58,56 M40,52 L60,72 M40,66 L58,86 M40,80 L56,98" stroke-width="0.7" />
      </svg>
      <div class="footer__brand-text">
        <strong>Δρ. Άννα Δημητρίου</strong>
        <span>Ψυχοθεραπεύτρια</span>
        <span class="footer__brand-reg">ΕΛΨΕ #ΧΧΧΧΧ · Somatic Experiencing®</span>
      </div>
    </div>

    <nav class="footer__cols" aria-label="Footer navigation">

      <div class="footer__col" data-foot-anim="col">
        <h3 class="footer__col-title">Γραφείο</h3>
        <address class="footer__address">
          <p>Αλεξάνδρας 44</p>
          <p>Παγκράτι, Αθήνα 11635</p>
          <p class="footer__hours">Δευτ–Παρ · 10:00–19:00</p>
        </address>
      </div>

      <div class="footer__col" data-foot-anim="col">
        <h3 class="footer__col-title">Επικοινωνία</h3>
        <ul class="footer__links">
          <li>
            <a href="mailto:anna@example.com" class="footer__link">anna@example.com</a>
          </li>
          <li>
            <a href="tel:+302101234567" class="footer__link">+30 210 123 4567</a>
          </li>
          <li>
            <span class="footer__signal">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true" width="13">
                <circle cx="8" cy="8" r="6.5"/><path d="M8 5.5v3l2 1" stroke-linecap="round"/>
              </svg>
              Signal: διαθέσιμη
            </span>
          </li>
        </ul>
      </div>

      <div class="footer__col" data-foot-anim="col">
        <h3 class="footer__col-title">Νομικά</h3>
        <ul class="footer__links">
          <li><a href="#" class="footer__link">Πολιτική Απορρήτου</a></li>
          <li><a href="#" class="footer__link">Όροι Χρήσης</a></li>
          <li><a href="#" class="footer__link">GDPR</a></li>
        </ul>
        <p class="footer__ethics">
          Δεσμευμένη από τον Κώδικα Δεοντολογίας της ΕΛΨΕ.
        </p>
      </div>

    </nav>

    <div class="footer__bottom" data-foot-anim="bottom">
      <p>
        <span>© 2026 · Δρ. Άννα Δημητρίου</span>
        <span class="footer__separator" aria-hidden="true">·</span>
        <span class="footer__made">Made slowly in Athens</span>
      </p>
      <a href="#" class="footer__back-top" aria-label="Πίσω στην αρχή">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
          <path d="M8 12V4M4 8l4-4 4 4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Επάνω</span>
      </a>
    </div>

  </div>
</footer>

<style>
  .footer {
    background: var(--c-ink);
    color: var(--c-bone);
    padding-top: var(--s-8);
    padding-bottom: var(--s-6);
    position: relative;
  }
  .footer::before {
    content: "";
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(to right, transparent, color-mix(in srgb, var(--c-bone) 15%, transparent), transparent);
  }

  .footer__inner { display: grid; gap: var(--s-7); }

  /* ── Brand ───────────────────────────── */
  .footer__brand {
    display: flex; align-items: center; gap: var(--s-5);
    padding-bottom: var(--s-6);
    border-bottom: 1px solid color-mix(in srgb, var(--c-bone) 10%, transparent);
  }
  .footer__leaf {
    width: 36px; height: auto; color: var(--c-sage);
    flex-shrink: 0; opacity: 0.7;
  }
  .footer__brand-text {
    display: flex; flex-direction: column; gap: 0.2rem;
  }
  .footer__brand-text strong {
    font-family: var(--f-display); font-weight: 400;
    font-size: 1.1rem; color: var(--c-bone);
  }
  .footer__brand-text span {
    font-family: var(--f-mono); font-size: 0.68rem;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: color-mix(in srgb, var(--c-bone) 50%, transparent);
  }
  .footer__brand-reg {
    font-size: 0.62rem !important; letter-spacing: 0.05em !important;
    color: color-mix(in srgb, var(--c-bone) 30%, transparent) !important;
  }

  /* ── Columns ─────────────────────────── */
  .footer__cols { display: grid; gap: var(--s-6); }
  .footer__col-title {
    font-family: var(--f-mono); font-size: 0.65rem;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: color-mix(in srgb, var(--c-bone) 40%, transparent);
    margin-bottom: var(--s-4);
  }

  .footer__address {
    font-style: normal; font-family: var(--f-body);
    font-size: 0.9rem; line-height: 1.7;
    color: color-mix(in srgb, var(--c-bone) 70%, transparent);
    display: grid; gap: 0.1rem;
  }
  .footer__hours {
    font-family: var(--f-mono); font-size: 0.68rem;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, var(--c-bone) 40%, transparent) !important;
    margin-top: var(--s-2);
  }

  .footer__links {
    list-style: none; display: grid; gap: 0.5rem;
  }
  .footer__link {
    font-family: var(--f-body); font-size: 0.9rem;
    color: color-mix(in srgb, var(--c-bone) 65%, transparent);
    text-decoration: none; transition: color 0.2s;
  }
  .footer__link:hover { color: var(--c-terra); }

  .footer__signal {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--f-mono); font-size: 0.68rem;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, var(--c-sage) 80%, transparent);
  }

  .footer__ethics {
    margin-top: var(--s-4); font-size: 0.78rem; line-height: 1.5;
    color: color-mix(in srgb, var(--c-bone) 30%, transparent);
    font-style: italic; max-width: 22ch;
  }

  /* ── Bottom bar ──────────────────────── */
  .footer__bottom {
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap;
    gap: var(--s-4);
    padding-top: var(--s-6);
    border-top: 1px solid color-mix(in srgb, var(--c-bone) 8%, transparent);
    font-family: var(--f-mono); font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: color-mix(in srgb, var(--c-bone) 35%, transparent);
  }
  .footer__bottom p { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
  .footer__separator { opacity: 0.4; }
  .footer__made { color: color-mix(in srgb, var(--c-bone) 22%, transparent); }

  .footer__back-top {
    display: flex; align-items: center; gap: 0.4rem;
    text-decoration: none;
    color: color-mix(in srgb, var(--c-bone) 40%, transparent);
    transition: color 0.2s;
  }
  .footer__back-top svg { width: 14px; height: 14px; }
  .footer__back-top:hover { color: var(--c-terra); }

  /* ── ≥ 640px ─────────────────────────── */
  @media (min-width: 640px) {
    .footer__cols { grid-template-columns: repeat(3, 1fr); gap: var(--s-6); }
  }

  @media (min-width: 1024px) {
    .footer__inner { grid-template-columns: 280px 1fr; gap: var(--s-8); }
    .footer__brand {
      flex-direction: column; align-items: flex-start;
      border-bottom: none; padding-bottom: 0;
      border-right: 1px solid color-mix(in srgb, var(--c-bone) 8%, transparent);
      padding-right: var(--s-7);
    }
    .footer__cols { grid-column: 2; }
    .footer__bottom { grid-column: 1 / -1; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initGSAP } from '../scripts/gsap-init';

  initGSAP();
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    const footer = document.querySelector('.footer');
    if (!footer) return;

    gsap.from('[data-foot-anim="brand"]', {
      autoAlpha: 0, y: 20, duration: 1,
      scrollTrigger: { trigger: footer, start: 'top 88%', once: true },
    });

    gsap.from('[data-foot-anim="col"]', {
      autoAlpha: 0, y: 18, stagger: 0.1, duration: 0.9,
      scrollTrigger: { trigger: '.footer__cols', start: 'top 90%', once: true },
    });

    gsap.from('[data-foot-anim="bottom"]', {
      autoAlpha: 0, y: 10, duration: 0.8,
      scrollTrigger: { trigger: '[data-foot-anim="bottom"]', start: 'top 95%', once: true },
    });
  });
</script>
