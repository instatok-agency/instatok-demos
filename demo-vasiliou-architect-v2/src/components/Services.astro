---
const services = [
  {
    index: '01',
    title: 'Κατοικία',
    subtitle: 'Residential',
    description: 'Νέες κατασκευές και ριζικές ανακατασκευές κατοικιών — από compact αστικές μονοκατοικίες έως εκτεταμένες εξοχικές επαύλεις. Εστιάζουμε στη μακροπρόθεσμη αξία: έργα που δεν θα ξεπεραστούν αισθητικά σε μία δεκαετία.',
    items: ['Πρωτογενής κατοικία', 'Εξοχική κατοικία', 'Επενδυτική κατοικία'],
  },
  {
    index: '02',
    title: 'Φιλοξενία',
    subtitle: 'Hospitality',
    description: 'Boutique hotels, αυτόνομα retreats και ξενοδοχειακές εγκαταστάσεις μικρής κλίμακας. Εξειδίκευση σε τοποθεσίες με ιδιαίτερες περιβαλλοντικές ή τοπογραφικές προκλήσεις.',
    items: ['Boutique hotel 8–40 δωμάτια', 'Private retreat / villa complex', 'Wellness & spa facilities'],
  },
  {
    index: '03',
    title: 'Εμπορικά',
    subtitle: 'Commercial',
    description: 'Χώροι γραφείων, retail και μικτής χρήσης σε αστικά κέντρα. Ιδιαίτερη εμπειρία σε ανακατασκευή ιστορικών κτιρίων με σύγχρονο πρόγραμμα.',
    items: ['Γραφεία / Office spaces', 'Retail & showroom', 'Μικτή χρήση / Mixed-use'],
  },
  {
    index: '04',
    title: 'Ανακαίνιση',
    subtitle: 'Renovation',
    description: 'Πλήρης αναδιαμόρφωση υφιστάμενου κτιρίου με στόχο τη σύγχρονη λειτουργικότητα χωρίς διάσπαση του υφιστάμενου χαρακτήρα. Ελάχιστος χρόνος παρέμβασης, μέγιστο αποτέλεσμα.',
    items: ['Ανακαίνιση κατοικίας', 'Ανακαίνιση εμπορικού χώρου', 'Αποκατάσταση παραδοσιακής κατασκευής'],
  },
  {
    index: '05',
    title: 'Consulting',
    subtitle: 'Consulting',
    description: 'Αρχιτεκτονική επίβλεψη για developers και ιδιοκτήτες που εργάζονται με άλλο σχεδιαστικό γραφείο. Project management, αξιολόγηση σχεδίων, εκπροσώπηση κατά τη φάση κατασκευής.',
    items: ['Design review & advisory', 'Construction supervision', 'Project management για ξένους πελάτες'],
  },
];
---

<section id="services" style="padding:6rem 0;">
  <div style="max-width:72rem; margin:0 auto; padding:0 2.5rem;">
    <!-- Section header -->
    <div style="display:flex; align-items:baseline; gap:1.5rem; margin-bottom:4rem; padding-bottom:1.5rem; border-bottom:1px solid #DCDCDC;">
      <span style="font-family:ui-monospace,'JetBrains Mono','Courier New',monospace; font-size:0.625rem; color:#ABABAB;">004</span>
      <h2 style="font-size:0.6875rem; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:#0A0A0A;">Υπηρεσίες</h2>
    </div>

    <!-- Services grid -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(min(100%, 13rem), 1fr)); gap:0; border-left:1px solid #DCDCDC;">
      {services.map(s => (
        <div style="padding:2rem 1.75rem 2.5rem; border-right:1px solid #DCDCDC; border-bottom:1px solid #DCDCDC; display:flex; flex-direction:column; gap:1.25rem;">
          <div style="display:flex; flex-direction:column; gap:0.25rem; padding-bottom:1rem; border-bottom:1px solid #DCDCDC;">
            <span style="font-family:ui-monospace,'JetBrains Mono','Courier New',monospace; font-size:0.5625rem; color:#ABABAB;">{s.index}</span>
            <h3 style="font-size:1rem; font-weight:400; color:#0A0A0A; line-height:1.2;">{s.title}</h3>
            <span style="font-size:0.5625rem; font-weight:400; letter-spacing:0.12em; text-transform:uppercase; color:#ABABAB;">{s.subtitle}</span>
          </div>
          <p style="font-size:0.75rem; font-weight:300; line-height:1.7; color:#6B6B6B;">{s.description}</p>
          <ul style="display:flex; flex-direction:column; gap:0.5rem; margin-top:auto;">
            {s.items.map(item => (
              <li style="display:flex; align-items:baseline; gap:0.625rem; font-size:0.6875rem; font-weight:400; color:#0A0A0A;">
                <span style="width:1rem; height:1px; background:#DCDCDC; flex-shrink:0; display:inline-block; margin-bottom:0.15rem;"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
